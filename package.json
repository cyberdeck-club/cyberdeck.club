{
  "name": "cyberdeck-club",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-pty % npm run astro:watch % npm run wrangler:delayed-watch",
    "dev:build": "npm run astro:build  && npm run wrangler:dev",
    "start": "npm run astro:build && npm run wrangler:dev",
    "build": "npm run astro:build",
    "preview": "npm run astro:build && npm run wrangler:dev",
    "deploy": "npm run astro:build && npm run wrangler:deploy",
    "deploy:beta": "npm run astro:build && npm run wrangler:deploy -- --env beta",
    "astro": "astro",
    "astro:build": "astro build",
    "astro:watch": "npm run astro:build && chokidar ./src/**/* -c \"npm run astro:build\"",
    "wrangler": "wrangler",
    "wrangler:dev": "CI=true wrangler dev",
    "wrangler:build": "wrangler build --config dist/server/wrangler.json",
    "wrangler:delayed-watch": "sleep 10 && while true; do npm run wrangler:watch; echo '[wrangler] exited, restarting in 8s...'; sleep 8; done",
    "wrangler:watch": "npm run wrangler:dev && chokidar ./src/**/* -c \"wrangler:dev\"",
    "wrangler:deploy": "wrangler deploy --config dist/server/wrangler.json",
    "auth:generate": "better-auth generate --output src/db/auth-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply cyberdeck-db --local",
    "db:migrate:beta": "wrangler d1 migrations apply cyberdeck-db-beta --env beta --remote",
    "db:migrate:prod": "wrangler d1 migrations apply cyberdeck-db --remote",
    "db:exec": "wrangler d1 execute cyberdeck-db --local",
    "db:exec:beta": "wrangler d1 execute cyberdeck-db-beta --env beta --remote",
    "db:exec:prod": "wrangler d1 execute cyberdeck-db --remote",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:beta": "tsx scripts/seed.ts beta",
    "db:seed:prod": "tsx scripts/seed.ts prod",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate && npm run db:seed",
    "lint": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.1.10",
    "@astrojs/react": "^5.0.0",
    "@mdxeditor/editor": "^3.55.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/y-tiptap": "^3.0.3",
    "astro": "6.1.7",
    "better-auth": "1.6.5",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "html2canvas": "^1.4.1",
    "marked": "18.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "resend": "6.12.2",
    "sanitize-html": "^2.17.3",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/html2canvas": "^0.5.35",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "chokidar-cli": "^3.0.0",
    "drizzle-kit": "0.31.10",
    "run-pty": "^6.0.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}