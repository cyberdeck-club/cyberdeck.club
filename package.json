{
  "name": "cyberdeck-club",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro build && wrangler dev",
    "start": "astro build && wrangler dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "astro build && wrangler pages deploy ./dist",
    "astro": "astro",
    "wrangler": "wrangler",
    "auth:generate": "better-auth generate --output src/db/auth-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply cyberdeck-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cyberdeck-db --remote",
    "db:exec": "wrangler d1 execute cyberdeck-db --local",
    "db:exec:prod": "wrangler d1 execute cyberdeck-db --remote",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && wrangler d1 migrations apply cyberdeck-db --local",
    "lint": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.1.10",
    "@astrojs/react": "^5.0.0",
    "@mdxeditor/editor": "^3.55.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/y-tiptap": "^3.0.3",
    "astro": "6.1.7",
    "better-auth": "1.6.5",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "marked": "18.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "resend": "6.12.2",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "drizzle-kit": "0.31.10",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}