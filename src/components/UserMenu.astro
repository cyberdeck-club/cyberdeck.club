---
// UserMenu component - shows Login/Register links or user avatar with logout
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
const user = Astro.locals.user;
---

{user ? (
  <div class={`user-menu-container ${className}`}>
    <div class="user-menu-wrapper">
      <button class="user-menu-trigger" id="user-menu-toggle" aria-expanded="false" aria-haspopup="true">
        {user.image ? (
          <img src={user.image} alt={user.name || user.email} class="user-avatar" />
        ) : (
          <div class="user-avatar-placeholder">
            {(user.name || user.email).charAt(0).toUpperCase()}
          </div>
        )}
        <span class="user-name">{user.name || user.email.split('@')[0]}</span>
        <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 9l6 6 6-6" />
        </svg>
      </button>

      <div class="user-dropdown" id="user-dropdown">
        <div class="dropdown-header">
          <span class="dropdown-email">{user.email}</span>
        </div>
        <hr class="dropdown-divider" />
        <button type="button" class="dropdown-item dropdown-logout" id="logout-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          Sign Out
        </button>
      </div>
    </div>
  </div>
) : (
  <div class={`auth-links ${className}`}>
    <a href="/login" class="auth-link auth-login">Log In</a>
    <a href="/register" class="auth-link auth-register">Sign Up</a>
  </div>
)}

<style>
  /* Auth Links (when not logged in) */
  .auth-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .auth-link {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0;
    transition: all 0.15s ease;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .auth-login {
    color: inherit;
    border: 2px solid currentColor;
  }

  .auth-login:hover {
    background: rgba(168, 85, 247, 0.1);
    color: #a855f7;
  }

  .auth-register {
    background: #a855f7;
    color: white;
    border: 2px solid #1a1a1a;
    box-shadow: 2px 2px 0 #1a1a1a;
  }

  @media (prefers-color-scheme: dark) {
    .auth-register {
      border-color: #f5f0fa;
    }
  }

  .auth-register:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 #1a1a1a;
  }

  .auth-register:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #1a1a1a;
  }

  /* User Menu (when logged in) */
  .user-menu-container {
    position: relative;
  }

  .user-menu-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: transparent;
    border: 2px solid transparent;
    border-radius: 0;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: inherit;
    transition: all 0.15s ease;
  }

  .user-menu-trigger:hover {
    background: rgba(168, 85, 247, 0.1);
    border-color: rgba(168, 85, 247, 0.3);
  }

  .user-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #1a1a1a;
    object-fit: cover;
  }

  @media (prefers-color-scheme: dark) {
    .user-avatar {
      border-color: #a855f7;
    }
  }

  .user-avatar-placeholder {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #a855f7;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    border: 2px solid #1a1a1a;
  }

  @media (prefers-color-scheme: dark) {
    .user-avatar-placeholder {
      border-color: #f5f0fa;
    }
  }

  .user-name {
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .chevron {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .user-menu-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .user-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 200px;
    background: white;
    border: 2px solid #1a1a1a;
    box-shadow: 4px 4px 0 #1a1a1a;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s ease;
    z-index: 100;
  }

  @media (prefers-color-scheme: dark) {
    .user-dropdown {
      background: #2a1a2a;
      border-color: #a855f7;
      box-shadow: 4px 4px 0 rgba(168, 85, 247, 0.4);
    }
  }

  .user-menu-trigger[aria-expanded="true"] + .user-dropdown,
  .user-dropdown:hover {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .user-menu-container:hover .user-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .dropdown-email {
    font-size: 0.875rem;
    font-weight: 500;
    color: #1a1a1a;
  }

  @media (prefers-color-scheme: dark) {
    .dropdown-email {
      color: #f5f0fa;
    }
  }

  .dropdown-role {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #a855f7;
    font-weight: 600;
  }

  .dropdown-divider {
    margin: 0;
    border: none;
    border-top: 1px solid #e5e5e5;
  }

  @media (prefers-color-scheme: dark) {
    .dropdown-divider {
      border-top-color: rgba(168, 85, 247, 0.3);
    }
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.625rem 1rem;
    font-size: 0.875rem;
    text-decoration: none;
    color: #1a1a1a;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.1s ease;
  }

  @media (prefers-color-scheme: dark) {
    .dropdown-item {
      color: #f5f0fa;
    }
  }

  .dropdown-item:hover {
    background: rgba(168, 85, 247, 0.1);
  }

  .dropdown-item svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .dropdown-form {
    margin: 0;
    padding: 0;
  }

  .dropdown-logout {
    width: 100%;
    font-family: inherit;
  }

  .dropdown-logout:hover {
    color: #dc2626;
  }

  @media (prefers-color-scheme: dark) {
    .dropdown-logout:hover {
      color: #f87171;
    }
  }
</style>

<script>
  // Toggle dropdown on click
  const trigger = document.getElementById('user-menu-toggle');
  const dropdown = document.getElementById('user-dropdown');

  if (trigger && dropdown) {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', (!isExpanded).toString());
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!trigger.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Handle logout
  const logoutBtn = document.getElementById('logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      try {
        const response = await fetch('/api/auth/signout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
        });

        if (response.ok) {
          // Redirect to home page after logout
          window.location.href = '/';
        } else {
          console.error('Logout failed:', response.status);
        }
      } catch (error) {
        console.error('Logout error:', error);
      }
    });
  }
</script>
