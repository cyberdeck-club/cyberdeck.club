---
/**
 * VideoSection Component
 * Displays embedded video players (YouTube/Vimeo using iframe).
 */

import type { VideosData } from "@/db/schema";

interface Props {
  videos: VideosData | null | undefined;
}

const { videos } = Astro.props;

// Helper to extract YouTube ID from various URL formats
function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}

// Helper to extract Vimeo ID from URL
function getVimeoId(url: string): string | null {
  const match = url.match(/vimeo\.com\/(\d+)/);
  return match ? match[1] : null;
}

// Determine video type and get embed URL
function getEmbedUrl(url: string): string | null {
  const ytId = getYouTubeId(url);
  if (ytId) {
    return `https://www.youtube.com/embed/${ytId}`;
  }
  
  const vimeoId = getVimeoId(url);
  if (vimeoId) {
    return `https://player.vimeo.com/video/${vimeoId}`;
  }
  
  // Return as-is if already an embed URL or unknown format
  if (url.includes('/embed/') || url.includes('player.vimeo.com')) {
    return url;
  }
  
  return null;
}
---

{videos && videos.mainVideoUrl && (
  <section class="video-section">
    <h2 class="section-heading">
      <span class="heading-icon">🎬</span>
      Videos
    </h2>
    
    {/* Main Video */}
    {(() => {
      const mainEmbedUrl = getEmbedUrl(videos.mainVideoUrl);
      if (!mainEmbedUrl) return null;
      return (
        <div class="video-wrapper main-video">
          <h3 class="video-label">Main Video</h3>
          <iframe
            src={mainEmbedUrl}
            title="Main build video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      );
    })()}
    
    {/* Demo Video */}
    {videos.demoVideoUrl && (() => {
      const demoEmbedUrl = getEmbedUrl(videos.demoVideoUrl);
      if (!demoEmbedUrl) return null;
      return (
        <div class="video-wrapper demo-video">
          <h3 class="video-label">Demo</h3>
          <iframe
            src={demoEmbedUrl}
            title="Build demo video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      );
    })()}
    
    {/* Build Step Videos */}
    {videos.buildStepVideos && videos.buildStepVideos.length > 0 && (
      <div class="step-videos">
        <h3 class="video-label">Build Step Videos</h3>
        <div class="step-videos-grid">
          {videos.buildStepVideos.map((videoUrl, index) => {
            const embedUrl = getEmbedUrl(videoUrl);
            if (!embedUrl) return null;
            return (
              <div class="step-video-wrapper">
                <iframe
                  src={embedUrl}
                  title={`Build step video ${index + 1}`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
                <span class="step-video-label">Step {index + 1}</span>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </section>
)}

<style>
  .video-section {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--border);
  }

  .heading-icon {
    font-size: 1.25rem;
  }

  .video-wrapper {
    margin-bottom: 1.5rem;
  }

  .video-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .main-video iframe,
  .demo-video iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border: 3px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
  }

  .step-videos {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--border);
  }

  .step-videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .step-video-wrapper {
    position: relative;
  }

  .step-video-wrapper iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border: 3px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
  }

  .step-video-label {
    display: block;
    margin-top: 0.375rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .video-section {
    background: var(--surface);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .video-section {
      padding: 1rem;
    }

    .step-videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>