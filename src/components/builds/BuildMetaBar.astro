---
/**
 * BuildMetaBar Component
 * Displays a compact horizontal metadata bar with difficulty, platform, cost, and build time.
 * Each item only renders if non-null.
 */

interface Props {
  difficulty?: string | null;
  computePlatform?: string | null;
  estimatedCost?: number | null;
  buildTime?: string | null;
}

const { difficulty, computePlatform, estimatedCost, buildTime } = Astro.props;

const difficultyConfig = {
  "beginner": { label: "Beginner", bg: "var(--color-accent-300)", text: "var(--text)" },
  "intermediate": { label: "Intermediate", bg: "var(--color-secondary-300)", text: "var(--text)" },
  "advanced": { label: "Advanced", bg: "var(--color-primary-600)", text: "var(--text-inverse)" }
};

const diff = difficulty ? difficultyConfig[difficulty as keyof typeof difficultyConfig] : null;

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(amount/100);
};

// Only render if at least one item has a value
const hasAnyMeta = difficulty || computePlatform || estimatedCost !== null || buildTime;
---

{hasAnyMeta && (
  <div class="build-meta-bar">
    {diff && (
      <div class="meta-item">
        <span class="meta-badge" style={`background: ${diff.bg}; color: ${diff.text}`}>
          {diff.label}
        </span>
      </div>
    )}
    
    {computePlatform && (
      <div class="meta-item">
        <span class="meta-icon">⚙</span>
        <span class="meta-value">{computePlatform}</span>
      </div>
    )}
    
    {estimatedCost !== null && estimatedCost !== undefined && estimatedCost > 0 && (
      <div class="meta-item">
        <span class="meta-icon">💰</span>
        <span class="meta-value">{formatCurrency(estimatedCost)}</span>
      </div>
    )}
    
    {buildTime && (
      <div class="meta-item">
        <span class="meta-icon">⏱</span>
        <span class="meta-value">{buildTime}</span>
      </div>
    )}
  </div>
)}

<style>
  .build-meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    padding: 0.875rem 1.25rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .meta-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--border);
    border-radius: 2px;
  }

  .meta-icon {
    font-size: 0.875rem;
  }

  .meta-value {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  /* Dark mode */
  :global([data-theme="dark"]) .build-meta-bar {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .meta-value {
    color: var(--text);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .build-meta-bar {
      padding: 0.75rem 1rem;
      gap: 0.75rem;
    }

    .meta-icon {
      display: none;
    }
  }
</style>