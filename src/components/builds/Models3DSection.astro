---
/**
 * Models3DSection Component
 * Displays 3D model files with download links and optional preview images.
 */

import type { Models3dData, Model3dFile } from "@/db/schema";

interface Props {
  models3d: Models3dData | null | undefined;
}

const { models3d } = Astro.props;
---

{models3d && models3d.files && models3d.files.length > 0 && (
  <section class="models-section">
    <h2 class="section-heading">
      <span class="heading-icon">📐</span>
      3D Models
    </h2>
    
    {models3d.description && (
      <p class="models-description">{models3d.description}</p>
    )}
    
    <div class="models-grid">
      {models3d.files.map((file: Model3dFile, index: number) => (
        <div class="model-card">
          {file.imageUrl && (
            <div class="model-thumbnail">
              <img
                src={file.imageUrl}
                alt={`Preview of ${file.name}`}
                loading="lazy"
              />
            </div>
          )}
          <div class="model-info">
            <span class="model-name">{file.name}</span>
            <a
              href={file.url}
              target="_blank"
              rel="noopener noreferrer"
              class="model-download"
            >
              <svg class="download-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
              </svg>
              Download
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .models-section {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--border);
  }

  .heading-icon {
    font-size: 1.25rem;
  }

  .models-description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 1.25rem;
  }

  .models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .model-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 3px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .model-card:hover {
    transform: translateY(-2px);
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .model-thumbnail {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--surface);
  }

  .model-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .model-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.875rem;
  }

  .model-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text);
    word-break: break-word;
  }

  .model-download {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-accent-200);
    color: var(--text);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    border: 2px solid var(--border);
    border-radius: 4px;
    transition: background 0.15s ease;
  }

  .model-download:hover {
    background: var(--color-accent-300);
  }

  .model-download:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .download-icon {
    width: 1rem;
    height: 1rem;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .models-section {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .model-card {
    background: var(--surface-alt);
  }

  :global([data-theme="dark"]) .model-download {
    background: var(--color-accent-800);
    color: var(--text-inverse);
  }

  :global([data-theme="dark"]) .model-download:hover {
    background: var(--color-accent-700);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .models-section {
      padding: 1rem;
    }

    .models-grid {
      grid-template-columns: 1fr;
    }
  }
</style>