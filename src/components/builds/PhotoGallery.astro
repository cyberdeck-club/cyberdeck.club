---
/**
 * PhotoGallery Component
 * Displays main image and grid of build step images.
 */

import type { PhotosData } from "@/db/schema";

interface Props {
  photos: PhotosData | null | undefined;
}

const { photos } = Astro.props;
---

{photos && photos.mainImageUrl && (
  <section class="photo-gallery-section">
    <h2 class="section-heading">
      <span class="heading-icon">📸</span>
      Photos
    </h2>
    
    {/* Main Image */}
    {photos.mainImageUrl && (
      <div class="main-image-wrapper">
        <img
          src={photos.mainImageUrl}
          alt="Main build image"
          class="main-image"
        />
      </div>
    )}
    
    {/* Build Step Images */}
    {photos.buildStepImages && photos.buildStepImages.length > 0 && (
      <div class="step-images-grid">
        <h3 class="subsection-heading">Build Steps</h3>
        <div class="step-images">
          {photos.buildStepImages.map((imageUrl, index) => (
            <div class="step-image-wrapper">
              <img
                src={imageUrl}
                alt={`Build step ${index + 1}`}
                loading="lazy"
                class="step-image"
              />
              <span class="step-number">Step {index + 1}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
)}

<style>
  .photo-gallery-section {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--border);
  }

  .heading-icon {
    font-size: 1.25rem;
  }

  .main-image-wrapper {
    margin-bottom: 1.5rem;
    overflow: hidden;
    border: 4px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
  }

  .main-image {
    width: 100%;
    height: auto;
    display: block;
    max-height: 500px;
    object-fit: cover;
  }

  .step-images-grid {
    margin-top: 1.5rem;
  }

  .subsection-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-muted);
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .step-images {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.875rem;
  }

  .step-image-wrapper {
    position: relative;
    overflow: hidden;
    border: 3px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    transition: transform 0.2s ease;
  }

  .step-image-wrapper:hover {
    transform: scale(1.03);
  }

  .step-image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  .step-number {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.375rem;
    background: var(--color-ink-900);
    color: var(--text-inverse);
    font-size: 0.7rem;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .photo-gallery-section {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .step-number {
    background: var(--color-ink-800);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .photo-gallery-section {
      padding: 1rem;
    }

    .step-images {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
  }
</style>