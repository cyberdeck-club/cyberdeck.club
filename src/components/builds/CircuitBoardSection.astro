---
/**
 * CircuitBoardSection Component
 * Displays circuit board description, file download links, and schematic image gallery.
 */

import type { CircuitBoardsData } from "@/db/schema";

interface Props {
  circuitBoards: CircuitBoardsData | null | undefined;
}

const { circuitBoards } = Astro.props;
---

{circuitBoards && (
  <section class="circuit-section">
    <h2 class="section-heading">
      <span class="heading-icon">🔧</span>
      Circuit Boards
    </h2>
    
    {circuitBoards.description && (
      <p class="circuit-description">{circuitBoards.description}</p>
    )}
    
    {/* File Downloads */}
    {circuitBoards.fileUrls && circuitBoards.fileUrls.length > 0 && (
      <div class="file-downloads">
        <h3 class="subsection-heading">Downloads</h3>
        <div class="file-links">
          {circuitBoards.fileUrls.map((fileUrl, index) => {
            // Extract filename from URL
            const urlParts = fileUrl.split('/');
            const filename = urlParts[urlParts.length - 1] || `File ${index + 1}`;
            // Decode URL encoding
            const displayName = decodeURIComponent(filename).replace(/[-_]/g, ' ');
            
            return (
              <a
                href={fileUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="file-link"
              >
                <svg class="file-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
                </svg>
                <span class="file-name">{displayName}</span>
                <svg class="download-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                </svg>
              </a>
            );
          })}
        </div>
      </div>
    )}
    
    {/* Schematic Images */}
    {circuitBoards.imageUrls && circuitBoards.imageUrls.length > 0 && (
      <div class="schematic-gallery">
        <h3 class="subsection-heading">Schematics</h3>
        <div class="schematic-images">
          {circuitBoards.imageUrls.map((imageUrl, index) => (
            <div class="schematic-image-wrapper">
              <img
                src={imageUrl}
                alt={`Circuit schematic ${index + 1}`}
                loading="lazy"
                class="schematic-image"
              />
              <span class="schematic-label">Schematic {index + 1}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
)}

<style>
  .circuit-section {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--border);
  }

  .heading-icon {
    font-size: 1.25rem;
  }

  .circuit-description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 1.5rem;
  }

  .subsection-heading {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .file-downloads {
    margin-bottom: 1.5rem;
  }

  .file-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .file-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--color-accent-100);
    color: var(--text);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    border: 2px solid var(--border);
    border-radius: 4px;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .file-link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--shadow-hard);
    background: var(--color-accent-200);
  }

  .file-link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .file-icon {
    width: 1.125rem;
    height: 1.125rem;
    color: var(--color-accent-700);
  }

  .file-name {
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .download-icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.5;
  }

  .schematic-gallery {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--border);
  }

  .schematic-images {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .schematic-image-wrapper {
    position: relative;
    overflow: hidden;
    border: 3px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
  }

  .schematic-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.2s ease;
  }

  .schematic-image-wrapper:hover .schematic-image {
    transform: scale(1.03);
  }

  .schematic-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.375rem;
    background: var(--color-ink-900);
    color: var(--text-inverse);
    font-size: 0.7rem;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .circuit-section {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .file-link {
    background: var(--color-accent-800);
    color: var(--text-inverse);
  }

  :global([data-theme="dark"]) .file-link:hover {
    background: var(--color-accent-700);
  }

  :global([data-theme="dark"]) .file-icon {
    color: var(--color-accent-300);
  }

  :global([data-theme="dark"]) .schematic-label {
    background: var(--color-ink-800);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .circuit-section {
      padding: 1rem;
    }

    .file-links {
      flex-direction: column;
    }

    .file-link {
      width: 100%;
      justify-content: flex-start;
    }

    .schematic-images {
      grid-template-columns: 1fr;
    }
  }
</style>