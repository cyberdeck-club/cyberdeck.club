---
interface Props {
  title: string;
  date: string;
  location: string;
  region: string;
  status: "upcoming" | "in-progress" | "completed" | "cancelled";
  attendeeCount: number;
  maxAttendees?: number;
  href: string;
}

const { title, date, location, region, status, attendeeCount, maxAttendees, href } = Astro.props;

const statusConfig = {
  "upcoming": { label: "Upcoming", bgColor: "var(--color-pop-mint)", textColor: "var(--color-text)" },
  "in-progress": { label: "In Progress", bgColor: "var(--color-pop-lemon)", textColor: "var(--color-text)" },
  "completed": { label: "Completed", bgColor: "var(--color-base-400)", textColor: "var(--color-white)" },
  "cancelled": { label: "Cancelled", bgColor: "var(--color-accent)", textColor: "var(--color-white)" }
};

const statusStyle = statusConfig[status] ?? statusConfig["upcoming"];
---

<article class="meetup-card">
  <a href={href} class="meetup-link">
    <div class="meetup-header">
      <span class="meetup-date">{date}</span>
      <span 
        class="meetup-status" 
        style={`background: ${statusStyle.bgColor}; color: ${statusStyle.textColor}`}
      >
        {statusStyle.label}
      </span>
    </div>
    <h3 class="meetup-name">{title}</h3>
    <div class="meetup-location">
      <svg class="icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M7 1.5C5 1.5 3.5 3 3.5 5C3.5 7.5 7 11.5 7 11.5C7 11.5 10.5 7.5 10.5 5C10.5 3 9 1.5 7 1.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="7" cy="5" r="1.5" stroke="currentColor" stroke-width="1"/>
      </svg>
      {location}
    </div>
    <div class="meetup-footer">
      <span class="meetup-region">
        <svg class="icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1C4.5 1 3.5 2 3.5 3.5C3.5 5 6 8 6 8C6 8 8.5 5 8.5 3.5C8.5 2 7.5 1 6 1Z" stroke="currentColor" stroke-width="1.2"/>
          <circle cx="6" cy="3.5" r="1" stroke="currentColor" stroke-width="1"/>
        </svg>
        {region}
      </span>
      <span class="meetup-attendees">
        {attendeeCount}{maxAttendees ? `/${maxAttendees}` : ''} attending
      </span>
    </div>
  </a>
</article>

<style>
  .meetup-card {
    background: var(--surface);
    border: 4px solid var(--color-text);
    border-radius: 0;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 6px 6px 0 var(--color-primary);
  }

  .meetup-card:hover {
    transform: translate(-6px, -6px);
    box-shadow: 12px 12px 0 var(--color-accent);
  }

  .meetup-link {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .meetup-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .meetup-date {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-pop-lemon);
    color: var(--color-text);
    border-radius: 0;
    border: 2px solid var(--color-text);
  }

  .meetup-status {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 0;
    border: 2px solid var(--color-text);
  }

  .meetup-name {
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--text);
    margin: 0 0 1rem;
    transition: color 0.15s ease;
  }

  .meetup-card:hover .meetup-name {
    color: var(--color-primary);
  }

  .meetup-location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .meetup-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 3px solid var(--border);
  }

  .meetup-region {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 800;
    background: var(--color-secondary);
    color: white;
    border-radius: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-text);
  }

  .meetup-attendees {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
  }

  .icon {
    opacity: 0.8;
    flex-shrink: 0;
  }

  /* Dark mode */
  :global(html.dark) .meetup-card {
    box-shadow: 6px 6px 0 var(--color-primary);
  }

  :global(html.dark) .meetup-card:hover {
    box-shadow: 10px 10px 0 var(--color-secondary);
  }

  :global(html.dark) .meetup-date {
    background: var(--color-primary);
    color: white;
  }

  :global(html.dark) .meetup-name {
    color: var(--text);
  }

  :global(html.dark) .meetup-location,
  :global(html.dark) .meetup-attendees {
    color: var(--text-muted);
  }
</style>
