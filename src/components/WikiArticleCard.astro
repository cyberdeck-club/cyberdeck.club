---
interface Props {
  title: string;
  category: string;
  excerpt: string;
  href: string;
}

const { title, category, excerpt, href } = Astro.props;
---

<article class="wiki-card">
  <a href={href} class="wiki-card-link">
    <div class="wiki-card-content">
      <span class="wiki-category">{category}</span>
      <h3 class="wiki-title">{title}</h3>
      <p class="wiki-excerpt">{excerpt}</p>
    </div>
    <span class="wiki-read-more">
      Read more
      <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M4 3L8 7L4 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
</article>

<style>
  .wiki-card {
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .wiki-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .wiki-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .wiki-card-content {
    flex: 1;
  }

  .wiki-category {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-primary-600);
    color: var(--text-inverse);
    border-radius: 4px;
    margin-bottom: 1rem;
    border: 2px solid var(--border);
  }

  .wiki-title {
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--text);
    margin: 0 0 0.75rem;
    transition: color 0.15s ease;
  }

  .wiki-card:hover .wiki-title {
    color: var(--color-primary-700);
  }

  .wiki-excerpt {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .wiki-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1.25rem;
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--color-primary-700);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.15s ease;
  }

  .wiki-card:hover .wiki-read-more {
    color: var(--color-accent-600);
  }

  .arrow {
    transition: transform 0.15s ease;
  }

  .wiki-card:hover .arrow {
    transform: translateX(4px);
  }

  /* Dark mode */
  :global([data-theme="dark"]) .wiki-card {
    background: var(--surface);
    border-color: var(--border);
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  :global([data-theme="dark"]) .wiki-card:hover {
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  :global([data-theme="dark"]) .wiki-category {
    background: var(--color-secondary-600);
  }

  :global([data-theme="dark"]) .wiki-title,
  :global([data-theme="dark"]) .wiki-excerpt {
    color: var(--text);
  }

  :global([data-theme="dark"]) .wiki-excerpt {
    color: var(--text-muted);
  }
</style>