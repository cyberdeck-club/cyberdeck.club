---
// Define prop types for better type checking
type ButtonProps = {
  variant?: "primary" | "secondary" | "ghost" | "muted";
  size?: "xs" | "sm" | "base" | "md" | "lg";
  iconOnly?: boolean;
  class?: string;
  // allow any other HTML attributes
  [key: string]: any;
};

const {
  variant = "primary",
  size = "base",
  iconOnly = false,
  class: className,
  ...rest
} = Astro.props as ButtonProps;

// Size classes
const sizes = {
  xs: iconOnly 
    ? ["size-8", "text-xs"] 
    : ["h-8", "px-4", "py-2", "text-xs"],
  sm: iconOnly 
    ? ["size-9", "text-xs"] 
    : ["h-9", "px-5", "py-2.5", "text-xs"],
  base: iconOnly 
    ? ["size-10", "text-sm"] 
    : ["h-10", "px-5", "py-2.5", "text-sm"],
  md: iconOnly 
    ? ["size-11", "text-base"] 
    : ["h-11", "px-6", "py-3", "text-base"],
  lg: iconOnly 
    ? ["size-12", "text-lg"] 
    : ["h-12", "px-8", "py-3", "text-lg"],
};

// Variant classes per DESIGN.md §7.1 Button recipes
const variantClasses = {
  primary: [
    "bg-primary-600",
    "text-ink-950",
    "border-3",
    "border-border",
    "rounded-sm",
    "shadow-[4px_4px_0_0_var(--shadow-hard)]",
    "hover:translate-x-[2px]",
    "hover:translate-y-[2px]",
    "hover:shadow-[1px_1px_0_0_var(--shadow-hard)]",
    "active:translate-x-1",
    "active:translate-y-1",
    "active:shadow-none",
    "font-display",
    "font-extrabold",
    "text-base",
  ],
  secondary: [
    "bg-secondary-200",
    "text-ink-800",
    "border-3",
    "border-border",
    "rounded-sm",
    "shadow-[3px_3px_0_0_var(--shadow-hard)]",
    "hover:translate-x-[2px]",
    "hover:translate-y-[2px]",
    "hover:shadow-[1px_1px_0_0_var(--shadow-hard)]",
    "active:translate-x-1",
    "active:translate-y-1",
    "active:shadow-none",
    "font-sans",
    "font-bold",
    "text-base",
  ],
  ghost: [
    "bg-transparent",
    "text-text",
    "border-3",
    "border-border",
    "rounded-sm",
    "font-sans",
    "font-bold",
    "text-base",
  ],
  muted: [
    "bg-transparent",
    "text-primary-700",
    "border-3",
    "border-border",
    "rounded-sm",
    "font-sans",
    "font-bold",
    "text-base",
    "hover:bg-primary-100",
    "focus:bg-primary-100",
  ],
};

// Build class list
const sizeClass = sizes[size as keyof typeof sizes] || sizes.base;
const variantClass = variantClasses[variant] || variantClasses.primary;
const additionalClasses = className ? className.split(" ") : [];
const baseClass = [
  "inline-flex",
  "items-center",
  "justify-center",
  "gap-2",
  "ease-in-out",
  "text-center",
  "duration-75",
  "transition-[transform,box-shadow]",
  "focus:outline-none",
  "focus-visible:ring-2",
  "focus-visible:ring-focus",
  "focus-visible:ring-offset-2",
];
---

{
  rest.href ? (
    <a
      href={rest.href}
      class:list={[
        baseClass,
        variantClass,
        sizeClass,
        additionalClasses,
      ]}
      {...rest}
    >
      <slot name="icon" />
      <slot />
    </a>
  ) : (
    <button
      class:list={[
        baseClass,
        variantClass,
        sizeClass,
        additionalClasses,
      ]}
      {...rest}
    >
      <slot name="icon" />
      <slot />
    </button>
  )
}
