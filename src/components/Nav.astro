---
import ThemeToggle from "./ThemeToggle.astro";
import UserMenu from "./UserMenu.astro";
import { requireRole, ROLES } from "@/lib/roles";

const navigationLinks = [
  { title: "Wiki", href: "/wiki/" },
  { title: "Forum", href: "/forum/" },
  { title: "Builds", href: "/builds/" },
  { title: "Meetups", href: "/meetups/" },
  { title: "About", href: "/about/" },
];

// Get current path for active state
const currentPath = Astro.url.pathname;

// Get current user for role-based nav items
const user = Astro.locals.user;
const canSeeModQueue = requireRole(user?.role, ROLES.TRUSTED_MAKER);
const isAdmin = requireRole(user?.role, ROLES.ADMIN);
---
<div id="nav-wrapper" class="fixed inset-x-0 top-0 z-50 w-full mx-auto">
  <div
    class="nav-bar py-4 px-6 border-y-8"
    style="border-color: var(--accent-border);"
  >
    <div
      id="navigation-wrapper"
      class="relative flex flex-col w-full md:items-center md:justify-between md:flex-row max-w-6xl mx-auto"
    >
      <div class="flex flex-row items-center justify-between">
        <a href="/" class="nav-logo flex items-center gap-2 text-xl font-bold tracking-tight no-underline">
          <span class="sr-only">Go to homepage</span>
          <svg class="logo-icon w-8 h-8" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="10" y="10" width="80" height="80" rx="15" fill="var(--color-primary)"/>
            <rect x="25" y="25" width="50" height="50" rx="10" fill="var(--color-secondary)"/>
            <rect x="35" y="35" width="30" height="30" rx="5" fill="currentColor"/>
          </svg>
          <span class="logo-text">cyberdeck<span class="logo-dot-club">.club</span></span>
        </a>
        <button
          id="menu-toggle"
          class="nav-toggle md:hidden p-2 rounded-md"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6 menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 menu-icon-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <nav
        id="navigation-menu"
        class="nav-menu fixed inset-0 flex flex-col justify-between h-full py-12 opacity-0 pointer-events-none md:bg-none md:bg-transparent lg:p-0 md:p-0 transform transition-all duration-300 ease-in-out -translate-y-4 md:relative md:inset-auto md:opacity-100 md:pointer-events-auto md:translate-y-0"
        aria-hidden="true"
      >
        <div class="nav-overlay absolute inset-0 pointer-events-none md:hidden">
        </div>

        <div class="relative flex md:bg-transparent flex-col items-start justify-start w-full h-full px-8 list-none md:ml-auto gap-8 md:px-0 md:flex-row md:items-center md:justify-center md:text-left md:gap-4">
          <a href="/" class="nav-home-link md:hidden flex items-center gap-2 text-2xl font-bold no-underline">
            <svg class="w-8 h-8" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="10" y="10" width="80" height="80" rx="15" fill="var(--color-primary)"/>
              <rect x="25" y="25" width="50" height="50" rx="10" fill="var(--color-secondary)"/>
              <rect x="35" y="35" width="30" height="30" rx="5" fill="currentColor"/>
            </svg>
            <span class="logo-text">cyberdeck<span class="logo-dot-club">.club</span></span>
          </a>

          <div class="flex flex-col gap-3 md:gap-4 md:flex-row">
            {navigationLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "nav-link text-xl md:text-base font-medium transition-colors duration-200",
                  { "active": currentPath.startsWith(link.href) }
                ]}
                aria-current={currentPath.startsWith(link.href) ? "page" : undefined}
              >
                {link.title}
              </a>
            ))}
          </div>

          <div class="flex flex-col md:flex-row gap-4 items-start md:items-center">
            <!-- Search placeholder -->
            <button
              class="nav-search p-2 rounded-md transition-colors duration-200"
              aria-label="Search"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>

            <!-- Theme Toggle -->
            <ThemeToggle />

            <!-- User Menu (Login/Register or User Dropdown) -->
            <UserMenu />
          </div>
        </div>
      </nav>
    </div>
  </div>
</div>

<style>
  /* Light mode nav styles */
  .nav-bar {
    background-color: var(--color-surface-light);
    border-color: var(--color-border-light);
  }

  .nav-logo,
  .nav-link {
    color: var(--color-text-light);
  }

  .logo-text {
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .logo-dot-club {
    color: var(--color-primary);
  }

  .nav-toggle,
  .nav-search {
    color: var(--color-text-light);
  }

  .nav-menu {
    background-color: var(--color-surface-light);
  }

  .nav-overlay {
    background-color: var(--color-border-light);
  }

  /* Dark mode nav styles */
  :global([data-theme="dark"]) .nav-bar {
    background-color: var(--color-surface-dark);
    border-color: var(--color-border-dark);
  }

  :global([data-theme="dark"]) .nav-logo,
  :global([data-theme="dark"]) .nav-link {
    color: var(--color-text-dark);
  }

  :global([data-theme="dark"]) .nav-toggle,
  :global([data-theme="dark"]) .nav-search {
    color: var(--color-text-dark);
  }

  :global([data-theme="dark"]) .nav-menu {
    background-color: var(--color-surface-dark);
  }

  :global([data-theme="dark"]) .nav-overlay {
    background-color: var(--color-border-dark);
  }

  /* Hover states */
  .nav-link:hover,
  .nav-logo:hover,
  .nav-toggle:hover,
  .nav-search:hover {
    color: var(--color-primary);
  }

  .nav-link.active {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* Admin button */
  .nav-admin-link {
    background-color: var(--color-secondary);
    color: white;
    border: 2px solid var(--color-secondary);
  }

  .nav-admin-link:hover {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* Mobile menu button icons */
  .menu-icon-open {
    display: block;
  }

  .menu-icon-close {
    display: none;
  }

  body.menu-open .menu-icon-open {
    display: none;
  }

  body.menu-open .menu-icon-close {
    display: block;
  }
</style>

<script>
  function initNav() {
    const menuToggle = document.getElementById('menu-toggle')!;
    const navMenu = document.getElementById('navigation-menu')!;
    const body = document.body;

    if (!menuToggle || !navMenu) return;

    function openMenu() {
      navMenu!.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
      navMenu!.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      navMenu!.setAttribute('aria-hidden', 'false');
      menuToggle!.setAttribute('aria-expanded', 'true');
      body.classList.add('menu-open');
    }

    function closeMenu() {
      navMenu!.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
      navMenu!.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      navMenu!.setAttribute('aria-hidden', 'true');
      menuToggle!.setAttribute('aria-expanded', 'false');
      body.classList.remove('menu-open');
    }

    menuToggle.addEventListener('click', () => {
      const isOpen = navMenu.classList.contains('opacity-100');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close menu when clicking a link
    navMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navMenu.classList.contains('opacity-100')) {
        closeMenu();
        menuToggle.focus();
      }
    });
  }

  // Run on initial load
  initNav();

  // Re-run on Astro page transitions
  document.addEventListener('astro:after-swap', initNav);
</script>
