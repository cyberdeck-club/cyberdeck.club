---
interface ImageData {
  url: string;
  alt?: string;
  width?: number;
  height?: number;
}

interface Props {
  title: string;
  builderName: string;
  featuredImage?: ImageData;
  difficulty: "beginner" | "intermediate" | "advanced";
  computePlatform?: string;
  estimatedCost?: number;
  href: string;
  variant?: "default" | "featured";
}

const { 
  title, 
  builderName, 
  featuredImage, 
  difficulty, 
  computePlatform,
  estimatedCost,
  href,
  variant = "default"
} = Astro.props;

const difficultyConfig = {
  "beginner": {
    label: "Beginner",
    color: "var(--color-accent-300)",
    textColor: "var(--text)"
  },
  "intermediate": {
    label: "Intermediate",
    color: "var(--color-secondary-300)",
    textColor: "var(--text)"
  },
  "advanced": {
    label: "Advanced",
    color: "var(--color-accent-600)",
    textColor: "var(--text-inverse)"
  }
};

const config = difficultyConfig[difficulty] ?? difficultyConfig["beginner"];

// Solid placeholder color for when no image
const placeholderColor = {
  "beginner": "var(--color-accent-200)",
  "intermediate": "var(--color-secondary-200)",
  "advanced": "var(--color-accent-400)"
}[difficulty] ?? "var(--color-primary-200)";

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(amount);
};
---

<article class:list={["build-card", { "build-card--featured": variant === "featured" }]}>
  <a href={href} class="build-link">
    <div class="build-image" style={featuredImage?.url ? undefined : `background-color: ${placeholderColor}`}>
      {featuredImage?.url ? (
        <img 
          src={featuredImage.url} 
          alt={featuredImage.alt || title}
          width={featuredImage.width || 400}
          height={featuredImage.height || 300}
          loading="lazy"
        />
      ) : (
        <div class="build-sparkles">
          <span class="sparkle">✦</span>
          <span class="sparkle">✧</span>
          <span class="sparkle">✦</span>
        </div>
      )}
      <div class="build-image-overlay">
        <span 
          class="build-difficulty"
          style={`background: ${config.color}; color: ${config.textColor}`}
        >
          {config.label}
        </span>
        {computePlatform && (
          <span class="build-platform">{computePlatform}</span>
        )}
      </div>
    </div>
    <div class="build-content">
      <h3 class="build-title">{title}</h3>
      <div class="build-meta">
        <span class="build-builder">
          <svg class="builder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
          </svg>
          {builderName}
        </span>
        {estimatedCost !== undefined && (
          <span class="build-cost">{formatCurrency(estimatedCost)}</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .build-card {
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .build-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .build-card--featured {
    border-width: 4px;
  }

  .build-card--featured .build-image {
    height: 200px;
  }

  .build-card--featured .build-title {
    font-size: 1.375rem;
  }

  .build-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .build-image {
    height: 160px;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid var(--border);
  }

  .build-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .build-card:hover .build-image img {
    transform: scale(1.05);
  }

  .build-image-overlay {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .build-sparkles {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
  }

  .sparkle {
    font-size: 1.75rem;
    color: rgba(255, 255, 255, 0.9);
    animation: sparkle 2s ease-in-out infinite;
  }

  .sparkle:nth-child(1) { animation-delay: 0s; }
  .sparkle:nth-child(2) { animation-delay: 0.5s; }
  .sparkle:nth-child(3) { animation-delay: 1s; }

  @keyframes sparkle {
    0%, 100% { opacity: 0.4; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  .build-difficulty {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 4px;
    border: 2px solid var(--border);
  }

  .build-platform {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--text);
    color: var(--text-inverse);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .build-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .build-title {
    font-size: 1.125rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--text);
    margin: 0 0 0.75rem;
    transition: color 0.15s ease;
  }

  .build-card:hover .build-title {
    color: var(--color-primary-700);
  }

  .build-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .build-builder {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .builder-icon {
    width: 1rem;
    height: 1rem;
  }

  .build-cost {
    font-size: 0.9375rem;
    font-weight: 800;
    color: var(--color-primary-700);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .build-difficulty {
    border-color: var(--color-secondary-600);
  }

  :global([data-theme="dark"]) .build-card {
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  :global([data-theme="dark"]) .build-card:hover {
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  :global([data-theme="dark"]) .build-title {
    color: var(--text);
  }

  :global([data-theme="dark"]) .build-builder {
    color: var(--text-muted);
  }

  :global([data-theme="dark"]) .sparkle {
    color: rgba(255, 255, 255, 0.7);
  }

  :global([data-theme="dark"]) .build-platform {
    background: var(--color-primary-400);
    color: var(--text-inverse);
  }
</style>
