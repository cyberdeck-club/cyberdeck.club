---
/**
 * ForumSidebar.astro
 * Left sidebar navigation for forum pages showing all categories
 */

interface Props {
  currentCategory?: string;
}

const { currentCategory } = Astro.props;

// Forum categories with slugs and descriptions
const categories = [
  { 
    slug: "introductions", 
    name: "Introductions", 
    description: "New members introduce themselves"
  },
  { 
    slug: "build-help", 
    name: "Build Help", 
    description: "Questions and troubleshooting"
  },
  { 
    slug: "build-logs", 
    name: "Build Logs", 
    description: "Step-by-step build documentation"
  },
  { 
    slug: "showcase", 
    name: "Showcase", 
    description: "Completed cyberdeck show-and-tell"
  },
  { 
    slug: "parts-sourcing", 
    name: "Parts & Sourcing", 
    description: "Where to find components"
  },
  { 
    slug: "meetups-events", 
    name: "Meetups & Events", 
    description: "Local build meetups"
  },
  { 
    slug: "off-topic", 
    name: "Off-Topic", 
    description: "General community chat"
  },
];

// Placeholder stats
const stats = {
  totalThreads: 847,
  totalPosts: 12453,
  totalMembers: 3421,
};
---

<nav class="forum-sidebar" aria-label="Forum categories">
  <div class="sidebar-header">
    <a href="/forum" class="forum-home-link">
      <svg class="forum-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M17 8H12V3L7 8H3V17H7L12 12V17H17V8Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Forum Home</span>
    </a>
  </div>

  <div class="sidebar-section">
    <h3 class="sidebar-section-title">Categories</h3>
    <ul class="category-list">
      {categories.map((category) => (
        <li class="category-item">
          <a 
            href={`/forum/${category.slug}`}
            class:list={["category-link", { active: currentCategory === category.slug }]}
          >
            <span class="category-name">{category.name}</span>
            <span class="category-description">{category.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-section">
    <a href="/forum/new-thread" class="new-thread-btn">
      <svg class="btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      New Thread ✨
    </a>
  </div>

  <div class="sidebar-section forum-stats">
    <h3 class="sidebar-section-title">Community Stats</h3>
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-value">{stats.totalThreads.toLocaleString()}</span>
        <span class="stat-label">Threads</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">{stats.totalPosts.toLocaleString()}</span>
        <span class="stat-label">Posts</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">{stats.totalMembers.toLocaleString()}</span>
        <span class="stat-label">Members</span>
      </div>
    </div>
  </div>
</nav>

<style>
  .forum-sidebar {
    width: 280px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-header {
    padding-bottom: 1.25rem;
    border-bottom: 4px solid var(--color-primary);
  }

  .forum-home-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    box-shadow: 5px 5px 0 var(--color-primary);
  }

  .forum-home-link:hover {
    background: var(--color-primary);
    border-color: var(--color-secondary);
    color: white;
    transform: translateY(-3px);
    box-shadow: 8px 8px 0 var(--color-secondary);
  }

  .forum-icon {
    flex-shrink: 0;
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-section-title {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary);
    margin: 0;
    padding: 0 0.5rem;
  }

  .category-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-item {
    margin: 0;
  }

  .category-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.85rem 1rem;
    background: var(--surface);
    border: 3px solid transparent;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s ease;
  }

  .category-link:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--text);
    transform: translateX(5px);
    box-shadow: 4px 4px 0 var(--text);
  }

  .category-link.active {
    background: var(--color-secondary);
    color: white;
    border-color: var(--text);
    box-shadow: 4px 4px 0 var(--text);
  }

  .category-name {
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .category-description {
    font-size: 0.7rem;
    opacity: 0.85;
    line-height: 1.3;
    font-weight: 500;
  }

  .new-thread-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-primary);
    border: 4px solid var(--text);
    border-radius: 10px;
    text-decoration: none;
    color: white;
    font-weight: 800;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    box-shadow: 5px 5px 0 var(--text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .new-thread-btn:hover {
    background: var(--color-secondary);
    transform: translateY(-3px);
    box-shadow: 8px 8px 0 var(--text);
  }

  .btn-icon {
    flex-shrink: 0;
  }

  .forum-stats {
    padding: 1.25rem;
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 12px;
    box-shadow: 5px 5px 0 var(--color-primary);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.75rem 0.5rem;
    background: var(--color-pop-mint);
    border: 2px solid var(--color-primary);
    border-radius: 6px;
  }

  .stat-value {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-secondary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    margin-top: 0.35rem;
    font-weight: 700;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .forum-sidebar {
      width: 250px;
    }
  }
</style>
