---
const footerLinks = [
  { label: "Wiki", url: "/wiki/", ariaLabel: "Go to Wiki" },
  { label: "Forum", url: "/forum/", ariaLabel: "Go to Forum" },
  { label: "Builds", url: "/builds/", ariaLabel: "Go to Builds" },
  { label: "Meetups", url: "/meetups/", ariaLabel: "Go to Meetups" },
  { label: "About", url: "/about/", ariaLabel: "Go to About" },
];

const socialLinks = [
  { label: "GitHub", url: "https://github.com", icon: "github" },
  { label: "Discord", url: "https://discord.gg", icon: "discord" },
  { label: "Twitter", url: "https://twitter.com", icon: "twitter" },
];
---

<footer class="footer overflow-hidden mt-auto border-t-8" style="border-color: var(--accent-border);">
  <div class="footer-main pt-12 pb-8" style="background-color: var(--accent-bg);">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Main footer content -->
      <div class="pb-12 grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-32 lg:pb-16">
        <!-- Brand column -->
        <div class="flex flex-col max-w-xl gap-6 lg:col-span-2">
          <div class="footer-brand">
            <h2 class="footer-tagline text-3xl font-bold tracking-tight lg:text-4xl text-white">
              Build. Hack. Connect.
            </h2>
            <p class="footer-description mt-4 text-lg text-white/85">
              The community for cyberdeck builders, DIY enthusiasts, and retro-computing fans.
              Share your builds, learn new skills, and connect with fellow makers.
            </p>
          </div>

          <!-- Social links -->
          <div class="flex flex-wrap gap-4 mt-4">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                class="social-link px-5 py-2 rounded-full font-medium transition-all duration-200 hover:scale-105"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Visit us on ${link.label}`}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Quick links column -->
        <nav
          class="footer-nav flex flex-col justify-between text-base gap-y-4"
          role="navigation"
          aria-label="Footer navigation"
        >
          <h3 class="footer-nav-title font-bold text-lg mb-2 text-white">Quick Links</h3>
          {footerLinks.map((link) => (
            <a
              class="footer-nav-link transition-colors duration-200 text-white hover:text-primary"
              href={link.url}
              aria-label={link.ariaLabel}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Divider -->
      <div class="footer-divider border-t border-white/30"></div>

      <!-- Bottom bar -->
      <div class="pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6">
          <p class="footer-copyright text-sm text-white">
            © 2026 cyberdeck.club. Built with 💖 and too much caffeine.
          </p>
        </div>

        <div class="flex items-center gap-6">
          <a
            href="/login"
            class="footer-admin-link text-sm transition-colors duration-200 text-white hover:text-primary"
          >
            Admin Login
          </a>
          <p class="footer-credit text-sm text-white/75">
            Built with 💖 by the cyberdeck community
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative sparkles -->
  <div class="footer-sparkles hidden md:block" aria-hidden="true">
    <div class="sparkle sparkle-1"></div>
    <div class="sparkle sparkle-2"></div>
    <div class="sparkle sparkle-3"></div>
  </div>
</footer>

<style>
  /* Light mode footer */
  .footer {
    background-color: var(--color-surface-light);
    border-color: var(--color-border-light);
  }

  .footer-main {
    border-top: 4px solid var(--color-secondary);
  }

  .footer-tagline,
  .footer-description,
  .footer-nav-title {
    color: var(--color-text-light);
  }

  .footer-description {
    color: var(--color-text-light);
    opacity: 0.85;
  }

  .social-link {
    background-color: var(--color-primary);
    color: white;
    border: 2px solid var(--color-primary);
  }

  .social-link:hover {
    background-color: var(--color-secondary);
    border-color: var(--color-secondary);
  }

  .footer-nav-link {
    color: var(--color-text-light);
  }

  .footer-nav-link:hover {
    color: var(--color-primary);
  }

  .footer-divider {
    border-color: var(--color-border-light);
    opacity: 0.3;
  }

  .footer-copyright,
  .footer-admin-link,
  .footer-credit {
    color: var(--color-text-light);
  }

  .footer-admin-link:hover {
    color: var(--color-primary);
  }

  /* Dark mode footer */
  :global(html.dark) .footer {
    background-color: var(--color-surface-dark);
    border-color: var(--color-border-dark);
  }

  :global(html.dark) .footer-main {
    border-top-color: var(--color-secondary);
  }

  :global(html.dark) .footer-tagline,
  :global(html.dark) .footer-description,
  :global(html.dark) .footer-nav-title {
    color: var(--color-text-dark);
  }

  :global(html.dark) .footer-description {
    color: var(--color-text-dark);
    opacity: 0.85;
  }

  :global(html.dark) .footer-nav-link {
    color: var(--color-text-dark);
  }

  :global(html.dark) .footer-nav-link:hover {
    color: var(--color-primary);
  }

  :global(html.dark) .footer-divider {
    border-color: var(--color-border-dark);
    opacity: 0.3;
  }

  :global(html.dark) .footer-copyright,
  :global(html.dark) .footer-admin-link,
  :global(html.dark) .footer-credit {
    color: var(--color-text-dark);
  }

  :global(html.dark) .footer-admin-link:hover {
    color: var(--color-primary);
  }

  /* Decorative sparkles */
  .sparkle {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    opacity: 0.6;
  }

  .sparkle-1 {
    background-color: var(--color-pop-mint);
    bottom: 20%;
    right: 15%;
    animation: sparkle-pulse 3s ease-in-out infinite;
  }

  .sparkle-2 {
    background-color: var(--color-pop-sky);
    bottom: 35%;
    right: 25%;
    animation: sparkle-pulse 3s ease-in-out infinite 1s;
  }

  .sparkle-3 {
    background-color: var(--color-pop-lemon);
    bottom: 15%;
    right: 20%;
    animation: sparkle-pulse 3s ease-in-out infinite 2s;
  }

  @keyframes sparkle-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.5);
      opacity: 1;
    }
  }
</style>
