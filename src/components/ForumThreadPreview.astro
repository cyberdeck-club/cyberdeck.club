---
interface Props {
  title: string;
  category: string;
  replyCount: number;
  lastActivity: string;
  href: string;
}

const { title, category, replyCount, lastActivity, href } = Astro.props;
---

<article class="thread-card">
  <a href={href} class="thread-link">
    <div class="thread-content">
      <span class="thread-category">{category}</span>
      <h3 class="thread-title">{title}</h3>
    </div>
    <div class="thread-meta">
      <span class="thread-replies">
        <svg class="icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M12 8.5L9 5.5L5 9.5L1 5.5L2.5 4L5 6.5L9 2.5L12 5.5L10.5 7L9 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" transform="scale(1,-1) translate(0,-12)"/>
        </svg>
        {replyCount} replies
      </span>
      <span class="thread-activity">{lastActivity}</span>
    </div>
  </a>
</article>

<style>
  .thread-card {
    background: var(--surface);
    border: 4px solid var(--color-pop-sky);
    border-radius: 0;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 6px 6px 0 var(--color-pop-sky);
  }

  .thread-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0 var(--color-primary);
  }

  .thread-link {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .thread-content {
    flex: 1;
  }

  .thread-category {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-pop-sky);
    color: var(--color-text);
    border-radius: 0;
    margin-bottom: 0.75rem;
    border: 2px solid var(--color-text);
  }

  .thread-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--text);
    margin: 0;
    transition: color 0.15s ease;
  }

  .thread-card:hover .thread-title {
    color: var(--color-primary);
  }

  .thread-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    padding-top: 0.75rem;
    border-top: 2px solid var(--border);
  }

  .thread-replies {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
  }

  .icon {
    opacity: 0.8;
  }

  .thread-activity {
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Dark mode */
  :global(html.dark) .thread-card {
    box-shadow: 6px 6px 0 var(--color-primary);
  }

  :global(html.dark) .thread-card:hover {
    box-shadow: 10px 10px 0 var(--color-secondary);
  }

  :global(html.dark) .thread-category {
    background: var(--color-secondary);
    color: white;
    border-color: white;
  }

  :global(html.dark) .thread-title,
  :global(html.dark) .thread-replies {
    color: var(--text);
  }

  :global(html.dark) .thread-activity {
    color: var(--text-muted);
  }
</style>