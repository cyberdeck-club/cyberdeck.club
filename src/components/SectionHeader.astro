---
interface Props {
  title: string;
  subtitle?: string;
  linkText?: string;
  linkHref?: string;
}

const { title, subtitle, linkText, linkHref } = Astro.props;
---

<header class="section-header">
  <div class="section-header-content">
    <h2 class="section-title">{title}</h2>
    {subtitle && <p class="section-subtitle">{subtitle}</p>}
  </div>
  {linkText && linkHref && (
    <a href={linkHref} class="section-link">
      {linkText}
      <svg class="link-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  )}
</header>

<style>
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 4px solid var(--color-primary);
  }

  .section-header-content {
    flex: 1;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-primary);
    margin: 0;
    border: 4px solid var(--color-primary);
    display: inline-block;
    padding: 0.5rem 1.5rem;
    box-shadow: 4px 4px 0 var(--color-primary);
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin: 1rem 0 0;
    max-width: 600px;
    font-weight: 500;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.6rem 1.25rem;
    border: 3px solid var(--color-text);
    box-shadow: 4px 4px 0 var(--color-primary);
    transition: all 0.15s ease;
  }

  .section-link:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-accent);
  }

  .link-arrow {
    transition: transform 0.15s ease;
  }

  .section-link:hover .link-arrow {
    transform: translateX(4px);
  }

  /* Dark mode */
  :global(html.dark) .section-title {
    color: var(--color-secondary);
    border-color: var(--color-secondary);
    box-shadow: 4px 4px 0 var(--color-secondary);
  }

  :global(html.dark) .section-subtitle {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .section-header {
      flex-direction: column;
      gap: 1rem;
    }

    .section-title {
      font-size: 1.25rem;
      padding: 0.4rem 1rem;
    }

    .section-link {
      align-self: flex-start;
    }
  }
</style>