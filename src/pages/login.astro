---
import BaseLayout from "@/layouts/BaseLayout.astro";
export const prerender = false;
---

<BaseLayout title="Login - CyberDeck" hideNav={true} hideFooter={true}>
  <div class="login-page">
    <div class="login-container">
      <div class="login-header">
        <h1 class="login-title">sign in / register</h1>
        <p class="login-subtitle">enter your email — we'll send a magic link to sign in or create your account</p>
      </div>

      <div id="message" class="message" style="display: none;">
        <p id="message-text"></p>
      </div>

      <form id="login-form">
        <div class="form-group">
          <label for="email" class="form-label">email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="you@example.com"
            required
            autocomplete="email"
          />
        </div>
        <button type="submit" class="submit-btn" id="submit-btn">
          send magic link
        </button>
      </form>

      <a href="/" class="back-link">← back to cyberdeck</a>
    </div>
  </div>
</BaseLayout>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .login-container {
    background: var(--surface);
    border: 3px solid var(--text);
    border-radius: 0;
    box-shadow: 6px 6px 0 var(--text);
    padding: 2.5rem;
    max-width: 420px;
    width: 100%;
  }
  :global([data-theme="dark"]) .login-container {
    box-shadow: 6px 6px 0 var(--color-primary);
  }
  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .login-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    text-transform: lowercase;
    letter-spacing: -0.02em;
  }
  .login-subtitle {
    font-size: 0.95rem;
    opacity: 0.7;
    margin: 0;
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-label {
    display: block;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 2px solid var(--text);
    border-radius: 0;
    background: var(--bg);
    color: var(--text);
    transition: box-shadow 0.15s ease;
  }
  :global([data-theme="dark"]) .form-input {
    border-color: var(--color-primary);
  }
  .form-input:focus {
    outline: none;
    box-shadow: 3px 3px 0 var(--color-primary);
  }
  .submit-btn {
    width: 100%;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--text);
    border-radius: 0;
    background: var(--text);
    color: var(--bg);
    cursor: pointer;
    transition: box-shadow 0.15s ease, transform 0.1s ease;
  }
  :global([data-theme="dark"]) .submit-btn {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }
  .submit-btn:hover {
    box-shadow: 4px 4px 0 var(--color-primary);
    transform: translate(-2px, -2px);
  }
  .submit-btn:active {
    transform: translate(0, 0);
    box-shadow: none;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .message {
    padding: 1rem;
    margin-bottom: 1.5rem;
    border: 2px solid var(--text);
    background: var(--surface);
  }
  .message.success {
    border-color: var(--color-signal);
    background: var(--color-signal) / 10%;
  }
  :global([data-theme="dark"]) .message.success {
    background: var(--color-signal) / 20%;
    border-color: var(--color-signal);
  }
  .message.error {
    border-color: var(--color-danger);
    background: var(--color-danger) / 10%;
  }
  :global([data-theme="dark"]) .message.error {
    background: var(--color-danger) / 20%;
    border-color: var(--color-danger);
  }
  .message p {
    margin: 0;
    font-size: 0.95rem;
  }
  .back-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: inherit;
    opacity: 0.7;
  }
  .back-link:hover {
    opacity: 1;
  }
</style>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement;
  const messageEl = document.getElementById("message") as HTMLDivElement;
  const messageText = document.getElementById("message-text") as HTMLParagraphElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  function showMessage(text: string, type: "success" | "error") {
    messageEl.style.display = "block";
    messageEl.className = `message ${type}`;
    messageText.textContent = text;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (document.getElementById("email") as HTMLInputElement).value;
    const siteUrl = window.location.origin;

    submitBtn.disabled = true;
    submitBtn.textContent = "sending...";

    try {
      const res = await fetch("/api/auth/sign-in/magic-link", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, callbackURL: siteUrl }),
      });

      if (!res.ok) {
        let errorMessage = "Failed to send magic link";
        try {
          const data = await res.json();
          errorMessage = data.error?.message || errorMessage;
        } catch {
          // response body not JSON — use default message
        }
        throw new Error(errorMessage);
      }

      showMessage(
        "check your email for the sign-in link. it expires in 5 minutes.",
        "success"
      );
      form.style.display = "none";
    } catch (err) {
      showMessage(
        err instanceof Error ? err.message : "something went wrong",
        "error"
      );
      submitBtn.disabled = false;
      submitBtn.textContent = "send magic link";
    }
  });
</script>
