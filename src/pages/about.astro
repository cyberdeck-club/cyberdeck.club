---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getEmDashCollection } from 'emdash';

// Query about page content from EmDash
const { entries, cacheHint } = await getEmDashCollection('about_page');
Astro.cache.set(cacheHint);

const aboutPage = entries[0]?.data;
const pageTitle = aboutPage?.page_title || 'About cyberdeck.club';
const pageSubtitle = aboutPage?.page_subtitle || 'Build Your Cyberdeck. Meet Your People.';
const whatIsCyberdeckContent = aboutPage?.what_is_cyberdeck_content || [];
const communityContent = aboutPage?.community_content || [];
const howToGetInvolvedContent = aboutPage?.how_to_get_involved_content || [];
const aboutThisSiteContent = aboutPage?.about_this_site_content || [];
---

<BaseLayout title={`${pageTitle} - cyberdeck.club`} description="Learn about the cyberdeck.club community and how to get involved.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <SectionHeader
      title={pageTitle}
      subtitle={pageSubtitle}
    />
    
    <div class="prose prose-pink max-w-none">
      <section class="mb-12">
        <h2>What is cyberdeck.club?</h2>
        {whatIsCyberdeckContent.map((block: any) => (
          <p>{block.children?.[0]?.text || ''}</p>
        ))}
      </section>

      <section class="mb-12">
        <h2>The Community</h2>
        {communityContent.map((block: any) => (
          <p>{block.children?.[0]?.text || ''}</p>
        ))}
        <ul>
          <li><strong>Beginners</strong> — Starting their first build with a Raspberry Pi and a dream</li>
          <li><strong>Experienced builders</strong> — Refining their craft over years of iteration</li>
          <li><strong>Electronics enthusiasts</strong> — Soldering, debugging, and optimizing</li>
          <li><strong>Software developers</strong> — Writing custom OS configurations and applications</li>
          <li><strong>Designer-makers</strong> — Creating beautiful enclosures and interfaces</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2>How to Get Involved</h2>
        
        <div class="grid gap-6 mt-6">
          <div class="card bg-base-200 p-6 rounded-lg">
            <h3 class="text-lg font-bold mb-2">📖 Start with the Wiki</h3>
            <p>
              New to cyberdeck building? Our wiki has guides covering everything from component
              selection to soldering techniques. Check out the
              <a href="/wiki/getting-started" class="link link-primary">Getting Started guide</a>
              to begin your journey.
            </p>
          </div>
          
          <div class="card bg-base-200 p-6 rounded-lg">
            <h3 class="text-lg font-bold mb-2">💬 Join the Forum</h3>
            <p>
              Have questions? Want to share your progress? The forum is where the conversation
              happens. Introduce yourself in
              <a href="/forum/introductions" class="link link-primary">Introductions</a> and
              say hello.
            </p>
          </div>
          
          <div class="card bg-base-200 p-6 rounded-lg">
            <h3 class="text-lg font-bold mb-2">🛠️ Share Your Build</h3>
            <p>
              Built something cool? The Builds section is for showcasing your work. Share your
              schematics, your design decisions, and your build story. Inspire others!
            </p>
          </div>
          
          <div class="card bg-base-200 p-6 rounded-lg">
            <h3 class="text-lg font-bold mb-2">📅 Attend Meetups</h3>
            <p>
              We hold regular virtual meetups and occasional in-person events. It's a great
              way to meet fellow builders, get feedback on your projects, and learn from
              the community.
            </p>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2>Quick Links</h2>
        <div class="flex flex-wrap gap-4 mt-4">
          <a href="/wiki/getting-started" class="btn btn-primary">
            Getting Started Guide
          </a>
          <a href="/forum/introductions" class="btn btn-outline btn-primary">
            Introduce Yourself
          </a>
          <a href="/builds" class="btn btn-outline btn-primary">
            Browse Builds
          </a>
          <a href="/meetups" class="btn btn-outline btn-primary">
            Upcoming Meetups
          </a>
        </div>
      </section>

      <section class="text-sm text-base-content/70">
        <h2>About This Site</h2>
        {aboutThisSiteContent.map((block: any) => (
          <p>{block.children?.[0]?.text || ''}</p>
        ))}
        <p class="mt-4">
          Questions about the site itself? Drop them in the forum's
          <a href="/forum/off-topic" class="link">Off Topic</a> section.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
