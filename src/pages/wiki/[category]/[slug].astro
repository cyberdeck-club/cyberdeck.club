const canEditAny = hasMinRole(user, "editor");
const canDelete = hasMinRole(user, "author") && isArticleOwner(user, article?.author ?? "");
const canDeleteAny = hasMinRole(user, "admin");

// Combined permissions for the article
const articleCanEdit = canEdit || canEditAny;
const articleCanDelete = canDelete || canDeleteAny;

