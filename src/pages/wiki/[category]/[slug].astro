              {article.relatedArticles.map((relatedSlug) => (
                <li>
                  <a href={`/wiki/${category}/${relatedSlug}`}>
                    {relatedSlug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </footer>
    </article>
  </WikiLayout>
) : (
  <WikiLayout title="Article Not Found" currentCategory={category}>
    <div class="not-found">
      <h1>Article Not Found</h1>
      <p>Sorry, we couldn't find the wiki article you're looking for.</p>
      <a href="/wiki" class="back-link">← Back to Wiki Home</a>
    </div>
  </WikiLayout>
)}

