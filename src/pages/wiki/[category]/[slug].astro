---
/**
 * Wiki Article Page
 * Shows a single wiki article with full content
 * Dynamic route: /wiki/[category]/[slug]
 */

import WikiLayout from "@/layouts/WikiLayout.astro";
import { WikiEditor } from "@/components/wiki/WikiEditor";
import { InlineEditor } from "@/components/wiki/InlineEditor";
import { getWikiArticle, incrementWikiViewCount } from "@/lib/wiki";
import { marked } from "marked";

// Server-rendered page
export const prerender = false;

// Parse edit mode from URL params
const editParam = Astro.url.searchParams.get("edit");
const isEditingFromUrl = editParam === "true";

// Role values for permission checking
const ROLE_VALUES = {
  subscriber: 10,
  contributor: 20,
  author: 30,
  editor: 40,
  admin: 50,
} as const;

type Role = keyof typeof ROLE_VALUES;

function getUserRole(user: any): Role {
  if (!user) return "subscriber";
  if (typeof user.role === "string") {
    const role = user.role.toLowerCase() as Role;
    if (role in ROLE_VALUES) return role;
  }
  if (typeof user.role === "number") {
    for (const [r, value] of Object.entries(ROLE_VALUES)) {
      if (user.role === value) return r as Role;
    }
  }
  return "subscriber";
}

function hasMinRole(user: any, minRole: Role): boolean {
  if (!user) return false;
  const userRole = getUserRole(user);
  return ROLE_VALUES[userRole] >= ROLE_VALUES[minRole];
}

function isArticleOwner(user: any, articleAuthor: string): boolean {
  if (!user || !articleAuthor) return false;
  const userId = user.id ?? user._id;
  return String(userId) === String(articleAuthor);
}

// Get user from Astro.locals
const user = Astro.locals.user;
const userRole = getUserRole(user);

// Get category and slug from URL params
const { category, slug } = Astro.params;

if (!category || !slug) {
  return Astro.redirect("/wiki");
}

// Fetch article from database
const db = Astro.locals.db!;
const articleResult = await getWikiArticle(db, category, slug);

// Article not found
const notFound = !articleResult || articleResult.length === 0;

// Article data (only if found)
let article: any = null;
let authorName: string | null = null;
let categoryName: string | null = null;
let breadcrumbs: Array<{ label: string; href: string }> = [];
let canEdit = false;
let canEditAny = false;
let canDelete = false;
let canDeleteAny = false;
let articleCanEdit = false;
let articleCanDelete = false;
let articleId = "";
let contentHtml = "";
let lastUpdated = "";
let statusClass = "good";

if (!notFound) {
  const result = articleResult[0];
  article = result.article;
  authorName = result.authorName;
  categoryName = result.categoryName;

  // Increment view count (fire and forget)
  incrementWikiViewCount(db, article.id).catch(console.error);

  // Build breadcrumbs
  breadcrumbs = [
    { label: categoryName ?? category, href: `/wiki/${category}` },
    { label: article.title, href: `/wiki/${category}/${slug}` }
  ];

  // Calculate permissions
  canEdit = hasMinRole(user, "contributor") && isArticleOwner(user, article.authorId ?? "");
  canEditAny = hasMinRole(user, "editor");
  canDelete = hasMinRole(user, "author") && isArticleOwner(user, article.authorId ?? "");
  canDeleteAny = hasMinRole(user, "admin");

  // Combined permissions for the article
  articleCanEdit = canEdit || canEditAny;
  articleCanDelete = canDelete || canDeleteAny;

  // Article ID for API calls (using article.id)
  articleId = article.id;

  // Render markdown content to HTML
  contentHtml = await marked.parse(article.content ?? "");

  // Format dates
  lastUpdated = article.updatedAt 
    ? new Date(article.updatedAt).toISOString().split('T')[0] 
    : new Date().toISOString().split('T')[0];

  // Determine status badge class
  statusClass = article.status === "published" ? "good" : article.status;
}
---

{notFound ? (
  <WikiLayout title="Article Not Found" currentCategory={category}>
    <div class="not-found">
      <h1>Article Not Found</h1>
      <p>Sorry, we couldn't find the wiki article you're looking for.</p>
      <a href="/wiki" class="back-link">← Back to Wiki Home</a>
    </div>
  </WikiLayout>
) : (
  <WikiLayout
    title={article.title}
    description={`Wiki article: ${article.title}`}
    currentCategory={category}
    breadcrumb={breadcrumbs}
  >
    <article class="wiki-article">
      <header class="article-header">
        <h1 class="article-title">{article.title}</h1>
        <div class="article-meta">
          <span class="meta-item">
            <svg class="meta-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="6" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 14C2 11.2386 4.68629 9 8 9C11.3137 9 14 11.2386 14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            {authorName ?? "Unknown"}
          </span>
          <span class="meta-item">
            <svg class="meta-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="3" width="12" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 6H14" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 1V3M11 1V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            {lastUpdated}
          </span>
          <span class={`status-badge status-${statusClass}`}>
            {article.status}
          </span>
        </div>
      </header>

      {/* Conditional rendering: view mode shows content, edit mode shows InlineEditor */}
      {isEditingFromUrl && articleCanEdit ? (
        <InlineEditor
          client:only="react"
          value={article.content ?? ""}
          articleId={articleId}
          category={category}
          slug={slug}
          editPermission={true}
          minHeight="400px"
        />
      ) : (
        <>
          <div class="article-content" set:html={contentHtml} />

          {/* WikiEditor shows edit/delete buttons when in view mode */}
          {!isEditingFromUrl && (
            <WikiEditor
              client:only="react"
              articleId={articleId}
              title={article.title}
              content={article.content ?? ""}
              category={category}
              canEdit={articleCanEdit}
              canDelete={articleCanDelete}
            />
          )}
        </>
      )}
    </article>
  </WikiLayout>
)}

<style>
  .wiki-article {
    max-width: 65ch;
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
  }

  .article-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .meta-icon {
    flex-shrink: 0;
  }

  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    color: white;
  }

  .status-badge.status-good {
    background: var(--color-pop-mint);
    color: var(--text);
  }

  .status-badge.status-stub {
    background: var(--color-text-muted);
  }

  .status-badge.status-needs-review {
    background: var(--color-accent);
    color: var(--text);
  }

  .status-badge.status-featured {
    background: var(--color-primary);
  }

  .article-content {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
  }

  .article-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 2rem 0 0.75rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-secondary);
    margin: 1.5rem 0 0.5rem 0;
  }

  .article-content :global(p) {
    margin: 0 0 1rem 0;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0 0 1rem 0;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
  }

  .article-content :global(th),
  .article-content :global(td) {
    padding: 0.5rem 0.75rem;
    border: 2px solid var(--border);
    text-align: left;
  }

  .article-content :global(th) {
    background: var(--color-secondary-100);
    font-weight: 600;
  }

  :global(html.dark) .article-content :global(th) {
    background: var(--color-secondary-800);
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--text);
  }

  .not-found {
    text-align: center;
    padding: 3rem 1rem;
  }

  .not-found h1 {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem 0;
  }

  .not-found p {
    color: var(--text-muted);
    margin: 0 0 1.5rem 0;
  }

  .back-link {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    background: var(--color-primary);
    color: white;
    text-decoration: none;
    font-weight: 600;
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .back-link:hover {
    background: var(--color-primary-hover);
  }
</style>
