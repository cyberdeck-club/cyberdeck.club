---
/**
 * Wiki Category Listing Page
 * Shows all articles in a specific wiki category
 * Dynamic route: /wiki/[category]
 */

import WikiLayout from "@/layouts/WikiLayout.astro";
import WikiArticleCard from "@/components/WikiArticleCard.astro";

// Server-rendered page
export const prerender = false;

// Get category from URL params
const { category } = Astro.params;

// Category data with descriptions and placeholder articles
const categoryData: Record<string, { 
  name: string; 
  description: string;
  articles: Array<{
    slug: string;
    title: string;
    excerpt: string;
    lastUpdated: string;
    author: string;
  }>;
}> = {
  "getting-started": {
    name: "Getting Started",
    description: "Begin your cyberdeck journey with these essential guides. Learn what a cyberdeck is, why you might want to build one, and get your first project started with confidence.",
    articles: [
      {
        slug: "what-is-a-cyberdeck",
        title: "What is a Cyberdeck?",
        excerpt: "A cyberdeck is a portable, often handcrafted computer system that combines modern computing hardware with a retro-futuristic or unique aesthetic. Learn the history and philosophy behind these builds.",
        lastUpdated: "2026-04-10",
        author: "NeonBuilder"
      },
      {
        slug: "why-build-a-cyberdeck",
        title: "Why Build a Cyberdeck?",
        excerpt: "From practical portability to creative expression, there are many reasons builders create cyberdecks. Discover what motivates the community and find your own inspiration.",
        lastUpdated: "2026-04-08",
        author: "CircuitWitch"
      },
      {
        slug: "essential-tools",
        title: "Essential Tools for Beginners",
        excerpt: "Starting your first build? Here's a comprehensive list of tools you'll need, from basic hand tools to specialized equipment for electronics and 3D printing.",
        lastUpdated: "2026-04-05",
        author: "MakerMike"
      },
      {
        slug: "planning-your-build",
        title: "Planning Your First Build",
        excerpt: "Before you start cutting or soldering, plan your cyberdeck build with our step-by-step guide. Define your goals, set a budget, and create a realistic timeline.",
        lastUpdated: "2026-04-02",
        author: "NeonBuilder"
      },
      {
        slug: "safety-precautions",
