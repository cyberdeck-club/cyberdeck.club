      {
        slug: "charging-circuits",
        title: "Charging Circuit Fundamentals",
        excerpt: "Understand charging ICs, protection circuits, and how to safely charge and balance battery packs.",
        lastUpdated: "2026-04-08",
        author: "CircuitDoctor"
      },
    ],
  },
  "networking": {
    name: "Networking",
    description: "WiFi, LoRa, mesh networking, cellular modems, and offline-first setups. Connect your cyberdeck to the world (or keep it isolated).",
