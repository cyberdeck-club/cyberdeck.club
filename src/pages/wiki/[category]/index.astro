        excerpt: "Give old electronics, vintage equipment, or unexpected objects new life as cyberdeck enclosures. Creative reuse at its finest.",
        lastUpdated: "2026-04-06",
        author: "ReClaimer"
      },
    ],
  },
  "compute": {
    name: "Compute",
    description: "Choose the right computing module for your project. Compare single-board computers, understand x86 vs ARM tradeoffs, and optimize performance for your use case.",
    articles: [
      {
        slug: "raspberry-pi-guide",
