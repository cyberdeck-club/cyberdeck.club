---
/**
 * Wiki Category Listing Page
 * Shows all articles in a specific wiki category
 * Dynamic route: /wiki/[category]
 */

import WikiLayout from "@/layouts/WikiLayout.astro";
import WikiArticleCard from "@/components/WikiArticleCard.astro";
import { CreateArticleButton } from "@/components/wiki/CreateArticleButton";
import { getWikiArticles, getWikiCategories } from "@/lib/wiki";

// Server-rendered page
export const prerender = false;

// Role values for permission checking - wiki article creation requires maker role or above
const ROLE_VALUES = {
  member: 10,
  maker: 20,
  moderator: 30,
  admin: 40,
} as const;

type Role = keyof typeof ROLE_VALUES;

function getUserRole(user: any): Role {
  if (!user) return "member";
  if (typeof user.role === "string") {
    const role = user.role.toLowerCase() as Role;
    if (role in ROLE_VALUES) return role;
  }
  if (typeof user.role === "number") {
    for (const [r, value] of Object.entries(ROLE_VALUES)) {
      if (user.role === value) return r as Role;
    }
  }
  return "member";
}

function hasMinRole(user: any, minRole: Role): boolean {
  if (!user) return false;
  const userRole = getUserRole(user);
  return ROLE_VALUES[userRole] >= ROLE_VALUES[minRole];
}

// Get user from Astro.locals
const user = Astro.locals.user;
// Only maker, moderator, or admin can create wiki articles
const canCreate = hasMinRole(user, "maker");

// Get category from URL params
const { category } = Astro.params;

if (!category) {
  return Astro.redirect("/wiki");
}

// Fetch data from database
const db = Astro.locals.db!;

// Get all categories to find the current one
const allCategories = await getWikiCategories(db);
const currentCategoryData = allCategories.find(c => c.slug === category);

// If category doesn't exist, show 404
if (!currentCategoryData) {
  return Astro.redirect("/wiki");
}

// Get articles for this category
const articlesResult = await getWikiArticles(db, category);

// Format articles for display
const articles = articlesResult.map(({ article, authorName }) => ({
  slug: article.slug,
  title: article.title,
  excerpt: article.excerpt ?? "",
  lastUpdated: article.updatedAt ? new Date(article.updatedAt).toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
  author: authorName ?? "Unknown"
}));
---

<WikiLayout
  title={`${currentCategoryData.name} Wiki`}
  description={currentCategoryData.description ?? ""}
  currentCategory={category}
  breadcrumb={[{ label: currentCategoryData.name, href: `/wiki/${category}` }]}
>
  <div class="category-header">
    <div class="category-header-row">
      <div>
        <h1 class="category-title">{currentCategoryData.name}</h1>
        <p class="category-description">{currentCategoryData.description ?? ""}</p>
      </div>
      {canCreate && (
        <CreateArticleButton
          client:load
          buttonLabel="New Article"
          defaultCategory={category}
        />
      )}
    </div>
  </div>

  <div class="articles-section">
    <div class="articles-grid">
      {articles.map((article) => (
        <WikiArticleCard
          title={article.title}
          category={currentCategoryData.name}
          excerpt={article.excerpt}
          href={`/wiki/${category}/${article.slug}`}
        />
      ))}
    </div>
  </div>

  {category !== "getting-started" && (
    <div class="new-to-wiki-prompt">
      <p>
        <svg class="prompt-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 18C14.4183 18 18 14.4183 18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10C2 14.4183 5.58172 18 10 18Z" stroke="currentColor" stroke-width="2"/>
          <path d="M10 14V10M10 6H10.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        New to the wiki? <a href="/wiki/getting-started">Start with Getting Started</a>
      </p>
    </div>
  )}
</WikiLayout>

<style>
  .category-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
  }

  .category-header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .category-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 0.75rem 0;
  }

  .category-description {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: 65ch;
  }

  .articles-section {
    margin-bottom: 2rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .new-to-wiki-prompt {
    background: var(--color-accent);
    border: 2px solid var(--color-accent);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    margin-top: 2rem;
  }

  .new-to-wiki-prompt p {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.9375rem;
    color: var(--text);
  }

  .prompt-icon {
    flex-shrink: 0;
    color: var(--color-secondary);
  }

  .new-to-wiki-prompt a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .new-to-wiki-prompt a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
    .category-header-row {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
