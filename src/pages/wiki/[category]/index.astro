      {
        slug: "filament-selection",
        title: "Filament Selection Guide",
        excerpt: "PLA, PETG, ABS, ASA, and specialty filaments. Choose the right material for durability, aesthetics, and printability.",
        lastUpdated: "2026-04-08",
        author: "FilamentFan"
      },
      {
        slug: "hinge-designs",
        title: "Hinge Design for Cyberdecks",
        excerpt: "Integrate hinges into your 3D printed designs for foldable and adjustable cyberdeck configurations.",
        lastUpdated: "2026-04-04",
        author: "PrintMaster"
      },
    ],
  },
  "soldering-electronics": {
    name: "Soldering & Electronics",
    description: "Basic skills, connector types, wiring techniques, and PCB design fundamentals for cyberdeck builders.",
    articles: [
      {
        slug: "soldering-basics",
        title: "Soldering 101",
        excerpt: "Learn or refresh essential soldering skills. From through-hole to surface mount, master the basics of making solid electrical connections.",
        lastUpdated: "2026-04-09",
        author: "SolderKing"
      },
      {
        slug: "connector-guide",
        title: "Common Connectors Reference",
        excerpt: "USB-C, JST, Dupont, Molex, and more. Understand when to use which connector and how to properly wire them.",
        lastUpdated: "2026-04-05",
        author: "ConnectorPro"
      },
    ],
  },
};

// Get the category info or redirect/404
const currentCategory = categoryData[category ?? ""];

// Server-rendered with dynamic content
---

{currentCategory ? (
  <WikiLayout 
    title={`${currentCategory.name} Wiki`}
    description={currentCategory.description}
    currentCategory={category}
    breadcrumb={[{ label: currentCategory.name, href: `/wiki/${category}` }]}
  >
    <div class="category-header">
      <h1 class="category-title">{currentCategory.name}</h1>
      <p class="category-description">{currentCategory.description}</p>
    </div>

    <div class="articles-section">
      <div class="articles-grid">
        {currentCategory.articles.map((article) => (
          <WikiArticleCard
            title={article.title}
            category={currentCategory.name}
            excerpt={article.excerpt}
            href={`/wiki/${category}/${article.slug}`}
          />
        ))}
      </div>
    </div>

    {category !== "getting-started" && (
      <div class="new-to-wiki-prompt">
        <p>
          <svg class="prompt-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 18C14.4183 18 18 14.4183 18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10C2 14.4183 5.58172 18 10 18Z" stroke="currentColor" stroke-width="2"/>
            <path d="M10 14V10M10 6H10.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          New to the wiki? <a href="/wiki/getting-started">Start with Getting Started</a>
        </p>
      </div>
    )}
  </WikiLayout>
) : (
  <WikiLayout title="Category Not Found" currentCategory={category}>
    <div class="not-found">
      <h1>Category Not Found</h1>
      <p>Sorry, we couldn't find the wiki category you're looking for.</p>
      <a href="/wiki" class="back-link">← Back to Wiki Home</a>
    </div>
  </WikiLayout>
)}

<style>
  .category-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
  }

  .category-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 0.75rem 0;
  }

  .category-description {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: 65ch;
  }

  .articles-section {
    margin-bottom: 2rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .new-to-wiki-prompt {
    background: var(--color-pop-mint);
    border: 2px solid var(--color-pop-mint);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-top: 2rem;
  }

  .new-to-wiki-prompt p {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.9375rem;
    color: var(--text);
  }

  .prompt-icon {
    flex-shrink: 0;
    color: var(--color-secondary);
  }

  .new-to-wiki-prompt a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .new-to-wiki-prompt a:hover {
    text-decoration: underline;
  }

  .not-found {
    text-align: center;
    padding: 3rem 1rem;
  }

  .not-found h1 {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem 0;
  }

  .not-found p {
    color: var(--text-muted);
    margin: 0 0 1.5rem 0;
  }

  .back-link {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    background: var(--color-primary);
    color: white;
    text-decoration: none;
    font-weight: 600;
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .back-link:hover {
    background: var(--color-primary-hover);
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
