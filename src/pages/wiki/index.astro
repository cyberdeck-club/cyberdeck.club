---
/**
 * Wiki Landing Page
 * Shows all wiki categories in a grid layout
 */

import WikiLayout from "@/layouts/WikiLayout.astro";

// Server-rendered page
export const prerender = false;

// Wiki categories with slugs, descriptions, and placeholder article counts
const categories = [
  { 
    slug: "getting-started", 
    name: "Getting Started", 
    description: "What is a cyberdeck, why build one, first steps, tool requirements",
    articleCount: 5,
    badge: "Start here",
    accent: "var(--color-pop-mint)"
  },
  { 
    slug: "enclosures", 
    name: "Enclosures", 
    description: "Pelican cases, 3D printed cases, upcycled enclosures, custom builds",
    articleCount: 8,
    accent: "var(--color-pop-sky)"
  },
  { 
    slug: "compute", 
    name: "Compute", 
    description: "Raspberry Pi, Orange Pi, Intel NUC, Framework Mainboard, SBCs, x86 vs ARM tradeoffs",
    articleCount: 12,
    accent: "var(--color-primary)"
  },
  { 
    slug: "displays", 
    name: "Displays", 
    description: "E-ink, LCD, OLED, round displays, multiple display setups, driver boards",
    articleCount: 7,
    accent: "var(--color-secondary)"
  },
  { 
    slug: "input", 
    name: "Input", 
    description: "Mechanical keyboards, split keyboards, trackballs, trackpads, custom input devices",
    articleCount: 6,
    accent: "var(--color-accent)"
  },
  { 
    slug: "power", 
    name: "Power", 
    description: "Battery selection (LiPo, 18650), charging circuits, solar, UPS modules, power management",
    articleCount: 9,
    accent: "var(--color-pop-lemon)"
  },
  { 
    slug: "networking", 
    name: "Networking", 
    description: "WiFi, LoRa, mesh networking, cellular modems, offline-first setups",
    articleCount: 4,
    accent: "var(--color-pop-sky)"
  },
  { 
    slug: "software", 
    name: "Software", 
    description: "OS choices (Debian, Armbian, custom), window managers, cyberdeck-specific tools",
    articleCount: 11,
    accent: "var(--color-secondary)"
  },
  { 
    slug: "3d-printing-for-cyberdecks", 
    name: "3D Printing for Cyberdecks", 
    description: "Designing enclosures, hinges, mounts, filament selection",
    articleCount: 6,
    accent: "var(--color-accent)"
  },
  { 
    slug: "soldering-electronics", 
    name: "Soldering & Electronics", 
    description: "Basic skills, connectors, wiring, PCB design basics",
    articleCount: 7,
    accent: "var(--color-primary)"
  },
];

// Server-rendered with dynamic content
---

<style>
  .wiki-hero {
    text-align: center;
    padding: 4rem 1.5rem;
    background: var(--color-primary);
    border-bottom: 8px solid var(--text);
    position: relative;
  }

  .wiki-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 10px,
      rgba(255,255,255,0.05) 10px,
      rgba(255,255,255,0.05) 20px
    );
    pointer-events: none;
  }

  .wiki-title {
    font-size: 3.5rem;
    font-weight: 900;
    color: white;
    margin: 0 0 0.75rem 0;
    text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
    letter-spacing: -0.02em;
    line-height: 1;
    position: relative;
    z-index: 1;
  }

  .wiki-subtitle {
    font-size: 1.25rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .wiki-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1.5rem 0;
    padding-bottom: 1rem;
    border-bottom: 4px solid var(--border);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .category-card {
    background: var(--surface);
    border: 4px solid var(--text);
    border-radius: 0;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 6px 6px 0 var(--text);
  }

  .category-card:hover {
    transform: translate(4px, 4px);
    box-shadow: 2px 2px 0 var(--text);
  }

  .category-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    border-bottom: 4px solid var(--text);
  }

  .category-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    margin-top: 0.5rem;
  }

  .category-name {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .start-here-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: var(--color-pop-mint);
    color: var(--text);
    font-size: 0.6875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 2px solid var(--text);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .category-description {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
    flex: 1;
  }

  .category-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 3px solid var(--border);
  }

  .article-count {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
  }

  .article-count strong {
    color: var(--color-primary);
    font-weight: 900;
  }

  .view-link {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 800;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .arrow {
    transition: transform 0.15s ease;
  }

  .category-card:hover .arrow {
    transform: translateX(4px);
  }

  .wiki-footer {
    text-align: center;
    padding: 2.5rem 2rem;
    border: 4px solid var(--border);
    margin-top: 3rem;
    background: var(--surface);
    box-shadow: 6px 6px 0 var(--border);
  }

  .wiki-footer p {
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 500;
    margin: 0;
  }

  .wiki-footer a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .wiki-footer a:hover {
    color: var(--color-secondary);
  }

  @media (max-width: 640px) {
    .wiki-title {
      font-size: 2.5rem;
    }

    .category-grid {
      grid-template-columns: 1fr;
    }

    .wiki-hero {
      padding: 2.5rem 1rem;
    }
  }
</style>

<WikiLayout title="Wiki" description="The knowledge base for cyberdeck builders">
  <div class="wiki-hero">
  <h1 class="wiki-title">Wiki ✨</h1>
  <p class="wiki-subtitle">The knowledge base for cyberdeck builders</p>
</div>

<div class="wiki-container">
  <p class="section-label">Browse all {categories.length} categories</p>

  <div class="category-grid">
    {categories.map((category) => (
      <a href={`/wiki/${category.slug}`} class="category-card">
        <div class="category-card-accent" style={`background: ${category.accent};`}></div>
        <div class="category-card-header">
          <h2 class="category-name">{category.name}</h2>
          {category.badge && (
            <span class="start-here-badge">{category.badge}</span>
          )}
        </div>
        <p class="category-description">{category.description}</p>
        <div class="category-meta">
          <span class="article-count">
            <strong>{category.articleCount}</strong> articles
          </span>
          <span class="view-link">
            Browse
            <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M4 3L8 7L4 11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="wiki-footer">
    <p>Can't find what you're looking for? <a href="/forum">Ask in the forum</a> or <a href="/forum/new-thread">start a new discussion</a>.</p>
  </div>
</div>
</WikiLayout>
