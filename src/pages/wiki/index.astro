---
/**
 * Wiki Landing Page
 * Shows all wiki categories in a grid layout
 */

import WikiLayout from "@/layouts/WikiLayout.astro";
import { CreateArticleButton } from "@/components/wiki/CreateArticleButton";
import { getWikiCategories } from "@/lib/wiki";

// Server-rendered page
export const prerender = false;

// Role values for permission checking
const ROLE_VALUES = {
  subscriber: 10,
  contributor: 20,
  author: 30,
  editor: 40,
  admin: 50,
} as const;

type Role = keyof typeof ROLE_VALUES;

function getUserRole(user: any): Role {
  if (!user) return "subscriber";
  if (typeof user.role === "string") {
    const role = user.role.toLowerCase() as Role;
    if (role in ROLE_VALUES) return role;
  }
  if (typeof user.role === "number") {
    for (const [r, value] of Object.entries(ROLE_VALUES)) {
      if (user.role === value) return r as Role;
    }
  }
  return "subscriber";
}

function hasMinRole(user: any, minRole: Role): boolean {
  if (!user) return false;
  const userRole = getUserRole(user);
  return ROLE_VALUES[userRole] >= ROLE_VALUES[minRole];
}

// Get user from Astro.locals
const user = Astro.locals.user;
const canCreate = hasMinRole(user, "contributor");

// Fetch categories from database
const db = Astro.locals.db!;
const categoriesResult = await getWikiCategories(db);
const categories = categoriesResult.map(cat => ({
  slug: cat.slug,
  name: cat.name,
  description: cat.description ?? "",
  articleCount: 0, // Will be populated if we add article counts
  badge: cat.slug === "getting-started" ? "Start here" : undefined,
  accent: "var(--color-primary)"
}));
---

<WikiLayout title="Wiki" description="The knowledge base for cyberdeck builders">
  <div class="wiki-hero">
  <h1 class="wiki-title">Wiki ✨</h1>
  <p class="wiki-subtitle">The knowledge base for cyberdeck builders</p>
</div>

<div class="wiki-container">
  <div class="wiki-header-actions" style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "1.5rem" }}>
    <p class="section-label">Browse all {categories.length} categories</p>
    {canCreate && (
      <CreateArticleButton
        client:load
        buttonLabel="Create New Article"
        categories={categories.map(c => ({ id: c.slug, label: c.name }))}
      />
    )}
  </div>

  <div class="category-grid">
    {categories.map((category) => (
      <a href={`/wiki/${category.slug}`} class="category-card">
        <div class="category-card-accent" style={`background: ${category.accent};`}></div>
        <div class="category-card-header">
          <h2 class="category-name">{category.name}</h2>
          {category.badge && (
            <span class="start-here-badge">{category.badge}</span>
          )}
        </div>
        <p class="category-description">{category.description}</p>
        <div class="category-meta">
          <span class="article-count">
            <strong>{category.articleCount}</strong> articles
          </span>
          <span class="view-link">
            Browse
            <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M4 3L8 7L4 11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="wiki-footer">
    <p>Can't find what you're looking for? <a href="/forum">Ask in the forum</a> or <a href="/forum/new-thread">start a new discussion</a>.</p>
  </div>
</div>
</WikiLayout>

<style>
  .wiki-hero {
    text-align: center;
    padding: 4rem 1.5rem;
    background: var(--color-primary);
    border-bottom: 8px solid var(--text);
    position: relative;
  }

  .wiki-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 10px,
      rgba(255,255,255,0.05) 10px,
      rgba(255,255,255,0.05) 20px
    );
    pointer-events: none;
  }

  .wiki-title {
    font-size: 3.5rem;
    font-weight: 900;
    color: white;
    margin: 0 0 0.75rem 0;
    text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
    letter-spacing: -0.02em;
    line-height: 1;
    position: relative;
    z-index: 1;
  }

  .wiki-subtitle {
    font-size: 1.25rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .wiki-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1.5rem 0;
    padding-bottom: 1rem;
    border-bottom: 4px solid var(--border);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .category-card {
    background: var(--surface);
    border: 4px solid var(--text);
    border-radius: 0;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 6px 6px 0 var(--text);
  }

  .category-card:hover {
    transform: translate(4px, 4px);
    box-shadow: 2px 2px 0 var(--text);
  }

  .category-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    border-bottom: 4px solid var(--text);
  }

  .category-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    margin-top: 0.5rem;
  }

  .category-name {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .start-here-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: var(--color-pop-mint);
    color: var(--text);
    font-size: 0.6875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 2px solid var(--text);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .category-description {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
    flex: 1;
  }

  .category-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 3px solid var(--border);
  }

  .article-count {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
  }

  .article-count strong {
    color: var(--color-primary);
    font-weight: 900;
  }

  .view-link {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 800;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .arrow {
    transition: transform 0.15s ease;
  }

  .category-card:hover .arrow {
    transform: translateX(4px);
  }

  .wiki-footer {
    text-align: center;
    padding: 2.5rem 2rem;
    border: 4px solid var(--border);
    margin-top: 3rem;
    background: var(--surface);
    box-shadow: 6px 6px 0 var(--border);
  }

  .wiki-footer p {
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 500;
    margin: 0;
  }

  .wiki-footer a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .wiki-footer a:hover {
    color: var(--color-secondary);
  }

  @media (max-width: 640px) {
    .wiki-title {
      font-size: 2.5rem;
    }

    .category-grid {
      grid-template-columns: 1fr;
    }

    .wiki-hero {
      padding: 2.5rem 1rem;
    }
  }
</style>
