---
/**
 * Moderator Nominations Page
 * Lists all users nominated for moderator.
 * Only visible to ADMIN role users.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";
import Button from "@/components/fundations/elements/Button.astro";
import * as schema from "@/db/schema";
import { eq, desc } from "drizzle-orm";
import { alias } from "drizzle-orm/sqlite-core";

export const prerender = false;

// Get current user
const currentUser = Astro.locals.user!;
const currentUserRole = (currentUser as any).role;

// Require ADMIN role
if (currentUserRole !== "admin") {
  return Astro.redirect("/");
}

// Fetch all nominated users
const db = Astro.locals.db;
const nominator = alias(schema.user, "nominator");
const nominationsResult = await db
  .select({
    id: schema.user.id,
    name: schema.user.name,
    email: schema.user.email,
    role: schema.user.role,
    image: schema.user.image,
    createdAt: schema.user.createdAt,
    acceptedBuildCount: schema.user.acceptedBuildCount,
    isModNominated: schema.user.isModNominated,
    modNominatedBy: schema.user.modNominatedBy,
    modNominatedAt: schema.user.modNominatedAt,
    nominatorName: nominator.name,
  })
  .from(schema.user)
  .leftJoin(nominator, eq(schema.user.modNominatedBy, nominator.id))
  .where(eq(schema.user.isModNominated, true))
  .orderBy(desc(schema.user.modNominatedAt));

// Helper for role badge colors
function getRoleBadgeClass(role: string) {
  switch (role) {
    case "admin": return "role-admin";
    case "moderator": return "role-moderator";
    case "trusted_maker": return "role-trusted-maker";
    case "maker": return "role-maker";
    default: return "role-member";
  }
}

// Helper to format date
function formatDate(timestamp: number | null): string {
  if (!timestamp) return "Unknown";
  return new Date(timestamp).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<AdminLayout title="Moderator Nominations" section="nominations">
  <div class="admin-header">
    <div>
      <h1 class="admin-title">Moderator Nominations</h1>
      <p class="admin-subtitle">
        {nominationsResult.length === 0
          ? "No pending nominations"
          : `${nominationsResult.length} pending nomination${nominationsResult.length === 1 ? "" : "s"}`}
      </p>
    </div>
  </div>

  {nominationsResult.length === 0 ? (
    <div class="empty-state">
      <div class="empty-state-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="empty-state-text">
        No moderator nominations right now. Trusted makers can nominate community members they believe would make great mods.
      </p>
    </div>
  ) : (
    <div class="nominations-list">
      {nominationsResult.map((nomination) => (
        <div class="nomination-card" data-user-id={nomination.id}>
          <div class="nomination-card-header">
            <div class="nomination-user">
              <div class="user-avatar">
                {nomination.image ? (
                  <img src={nomination.image} alt={nomination.name} />
                ) : (
                  <span class="user-initials">{nomination.name?.charAt(0) || "?"}</span>
                )}
              </div>
              <div class="user-info">
                <a href={`/admin/users/${nomination.id}`} class="author-link">{nomination.name}</a>
                <span class={`role-badge ${getRoleBadgeClass(nomination.role || "member")}`}>
                  {nomination.role || "member"}
                </span>
              </div>
            </div>
            <div class="nomination-meta">
              <span class="meta-label">Nominated</span>
              <span class="meta-value">{formatDate(nomination.modNominatedAt ? new Date(nomination.modNominatedAt).getTime() / 1000 : null)}</span>
            </div>
          </div>

          <div class="nomination-card-body">
            <div class="nomination-stats">
              <div class="stat">
                <span class="stat-label">Accepted Builds</span>
                <span class="stat-value">{nomination.acceptedBuildCount ?? 0}</span>
              </div>
              <div class="stat">
                <span class="stat-label">Member Since</span>
                <span class="stat-value">{formatDate(nomination.createdAt ? nomination.createdAt.getTime() / 1000 : null)}</span>
              </div>
            </div>

            {nomination.modNominatedBy && (
              <div class="nominator-info">
                <span class="nominator-label">Nominated by</span>
                <span class="nominator-name">Community member</span>
              </div>
            )}
          </div>

          <div class="nomination-card-actions">
            <Button
              variant="primary"
              size="sm"
              class="appoint-btn"
              data-user-id={nomination.id}
              data-user-name={nomination.name}
            >
              Appoint as Moderator
            </Button>
            <Button
              variant="ghost"
              size="sm"
              class="dismiss-btn"
              data-user-id={nomination.id}
              data-user-name={nomination.name}
            >
              Dismiss Nomination
            </Button>
          </div>
        </div>
      ))}
    </div>
  )}
</AdminLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const appointBtns = document.querySelectorAll(".appoint-btn");
    const dismissBtns = document.querySelectorAll(".dismiss-btn");

    appointBtns.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const target = e.target as HTMLElement;
        const userId = target.getAttribute("data-user-id");
        const userName = target.getAttribute("data-user-name");

        if (!userId) return;

        const confirmed = confirm(`Are you sure you want to appoint ${userName} as a moderator?`);
        if (!confirmed) return;

        try {
          const response = await fetch(`/api/admin/nominations/${userId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "appoint" }),
          });

          if (response.ok) {
            // Remove the card from the list
            const card = target.closest(".nomination-card");
            card?.remove();
            updateEmptyState();
          } else {
            const data = await response.json();
            alert(data.error || "Failed to appoint moderator");
          }
        } catch (err) {
          alert("Failed to appoint moderator");
        }
      });
    });

    dismissBtns.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const target = e.target as HTMLElement;
        const userId = target.getAttribute("data-user-id");
        const userName = target.getAttribute("data-user-name");

        if (!userId) return;

        const confirmed = confirm(`Dismiss the nomination for ${userName}? Their role will remain unchanged.`);
        if (!confirmed) return;

        try {
          const response = await fetch(`/api/admin/nominations/${userId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "dismiss" }),
          });

          if (response.ok) {
            // Remove the card from the list
            const card = target.closest(".nomination-card");
            card?.remove();
            updateEmptyState();
          } else {
            const data = await response.json();
            alert(data.error || "Failed to dismiss nomination");
          }
        } catch (err) {
          alert("Failed to dismiss nomination");
        }
      });
    });

    function updateEmptyState() {
      const remainingCards = document.querySelectorAll(".nomination-card");
      const emptyState = document.querySelector(".empty-state");
      const subtitle = document.querySelector(".admin-subtitle");

      if (remainingCards.length === 0 && emptyState) {
        // Show empty state
        const list = document.querySelector(".nominations-list");
        if (list) list.remove();

        // Create and insert empty state
        const container = document.querySelector(".admin-header")?.parentElement;
        if (container && !container.querySelector(".empty-state")) {
          const emptyDiv = document.createElement("div");
          emptyDiv.className = "empty-state";
          emptyDiv.innerHTML = `
            <div class="empty-state-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <p class="empty-state-text">No moderator nominations right now. Trusted makers can nominate community members they believe would make great mods.</p>
          `;
          container.appendChild(emptyDiv);
        }

        if (subtitle) {
          subtitle.textContent = "No pending nominations";
        }
      } else if (subtitle) {
        subtitle.textContent = `${remainingCards.length} pending nomination${remainingCards.length === 1 ? "" : "s"}`;
      }
    }
  });
</script>

<style>
  .nominations-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nomination-card {
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .nomination-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
  }

  .nomination-user {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .user-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--border);
  }

  .user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .user-initials {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text-muted);
  }

  .user-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .user-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text);
  }

  .role-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    width: fit-content;
  }

  .role-badge.role-admin {
    background: var(--primary);
    color: var(--text-inverse);
  }

  .role-badge.role-moderator {
    background: var(--secondary);
    color: var(--text-inverse);
  }

  .role-badge.role-trusted-maker {
    background: var(--accent);
    color: var(--text);
  }

  .role-badge.role-maker {
    background: var(--ink-200);
    color: var(--text);
  }

  .role-badge.role-member {
    background: var(--surface-alt);
    color: var(--text-muted);
  }

  .nomination-meta {
    text-align: right;
  }

  .meta-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-value {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
  }

  .nomination-card-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    background: var(--surface-alt);
    border-radius: 2px;
    margin-bottom: 1.25rem;
  }

  .nomination-stats {
    display: flex;
    gap: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    font-family: var(--font-mono);
  }

  .nominator-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 2px solid var(--border);
  }

  .nominator-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .nominator-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .nomination-card-actions {
    display: flex;
    gap: 0.75rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
  }

  .empty-state-icon {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .empty-state-text {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 400px;
    margin: 0 auto;
    line-height: 1.6;
  }
</style>
