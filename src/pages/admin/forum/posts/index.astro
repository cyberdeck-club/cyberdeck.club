---
/**
 * Forum Posts Moderation Page
 * Lists all posts with moderation actions.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";
import Button from "@/components/fundations/elements/Button.astro";
import * as schema from "@/db/schema";
import { eq, desc, like, or, and } from "drizzle-orm";

export const prerender = false;

// Get query params for filtering
const url = new URL(Astro.request.url);
const search = url.searchParams.get("search") || "";
const page = parseInt(url.searchParams.get("page") || "1", 10);
const perPage = 25;

// Build where clause - join posts with threads to search by thread title
const db = Astro.locals.db;

let threadsMap: Record<string, string> = {};
if (search) {
  const threadsWithSearch = await db
    .select({ id: schema.forumThreads.id })
    .from(schema.forumThreads)
    .where(like(schema.forumThreads.title, `%${search}%`));
  
  threadsMap = Object.fromEntries(threadsWithSearch.map(t => [t.id, t.id]));
}

const conditions = [];
if (search && threadsMap) {
  const threadIds = Object.keys(threadsMap);
  if (threadIds.length > 0) {
    conditions.push(or(
      like(schema.forumPosts.content, `%${search}%`),
    ));
  }
}

// Get posts with pagination
const offset = (page - 1) * perPage;

const postsResult = await db
  .select({
    id: schema.forumPosts.id,
    content: schema.forumPosts.content,
    createdAt: schema.forumPosts.createdAt,
    threadId: schema.forumPosts.threadId,
    threadTitle: schema.forumThreads.title,
    authorId: schema.forumPosts.authorId,
    authorName: schema.user.name,
  })
  .from(schema.forumPosts)
  .leftJoin(schema.forumThreads, eq(schema.forumPosts.threadId, schema.forumThreads.id))
  .leftJoin(schema.user, eq(schema.forumPosts.authorId, schema.user.id))
  .where(conditions.length > 0 ? or(...conditions) : undefined)
  .orderBy(desc(schema.forumPosts.createdAt))
  .limit(perPage)
  .offset(offset);

const totalCountResult = await db
  .select({ count: schema.forumPosts.id })
  .from(schema.forumPosts)
  .where(conditions.length > 0 ? or(...conditions) : undefined);

const totalPosts = totalCountResult.length;
const totalPages = Math.ceil(totalPosts / perPage);

// Truncate content for preview
function truncateContent(content: string, maxLength: number = 150) {
  if (content.length <= maxLength) return content;
  return content.substring(0, maxLength) + '...';
}
---

<AdminLayout title="Forum Posts" section="forum">
  <div class="admin-header">
    <div>
      <h1 class="admin-title">Forum Posts</h1>
      <p class="admin-subtitle">{totalPosts} posts</p>
    </div>
  </div>

  <!-- Filters -->
  <form class="filters" method="get">
    <div class="search-box">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <path d="M21 21l-4.35-4.35"/>
      </svg>
      <input 
        type="text" 
        name="search" 
        placeholder="Search post content..." 
        value={search}
        class="search-input"
      />
    </div>
    
    <Button type="submit" variant="default" size="sm">Search</Button>
    <a href="/admin/forum/posts" class="btn-reset">
      <Button variant="muted" size="sm">Reset</Button>
    </a>
  </form>

  <!-- Posts List -->
  <div class="posts-list">
    {postsResult.map(post => (
      <div class="post-card">
        <div class="post-header">
          <div class="post-meta">
            <a href={`/forum/thread/${post.threadId}`} target="_blank" class="thread-link">
              {post.threadTitle || "Unknown Thread"}
            </a>
            <span class="meta-separator">•</span>
            <span class="author">{post.authorName || "Unknown"}</span>
            <span class="meta-separator">•</span>
            <span class="date">{new Date(post.createdAt).toLocaleDateString()}</span>
          </div>
          <button 
            class="delete-btn"
            data-post-id={post.id}
            title="Delete post"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
          </button>
        </div>
        <div class="post-content">
          <p>{truncateContent(post.content)}</p>
        </div>
      </div>
    ))}
  </div>

  <!-- Pagination -->
  {totalPages > 1 && (
    <div class="pagination">
      {page > 1 && (
        <a href={`?page=${page - 1}&search=${search}`} class="page-btn">
          ← Previous
        </a>
      )}
      
      <span class="page-info">
        Page {page} of {totalPages}
      </span>
      
      {page < totalPages && (
        <a href={`?page=${page + 1}&search=${search}`} class="page-btn">
          Next →
        </a>
      )}
    </div>
  )}
</AdminLayout>

<style>
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .admin-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
  }

  .admin-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0.5rem 0 0;
  }

  .filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: var(--surface);
    border: 3px solid var(--color-primary);
    border-radius: 8px;
    flex: 1;
    max-width: 500px;
  }

  .search-box svg {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 0.9rem;
    color: var(--text);
    outline: none;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .btn-reset {
    text-decoration: none;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 8px;
    padding: 1.25rem;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    transition: transform 0.2s;
  }

  .post-card:hover {
    transform: translateY(-2px);
  }

  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .thread-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .thread-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .meta-separator {
    color: var(--text-muted);
  }

  .author {
    color: var(--text);
    font-weight: 600;
  }

  .date {
    color: var(--text-muted);
  }

  .delete-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-bg);
    border: 2px solid var(--color-danger);
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-danger);
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .delete-btn:hover {
    background: var(--color-danger);
    color: var(--text-inverse);
    transform: translateY(-2px);
  }

  .delete-btn.loading {
    opacity: 0.5;
    pointer-events: none;
  }

  .post-content {
    background: var(--color-bg);
    border-radius: 8px;
    padding: 1rem;
  }

  .post-content p {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
    font-size: 0.95rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .page-btn {
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .page-btn:hover {
    transform: translateY(-2px);
    box-shadow: 4px 4px 0 var(--color-primary);
  }

  .page-info {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .filters {
      flex-direction: column;
      align-items: stretch;
    }

    .search-box {
      max-width: none;
    }
  }
</style>

<script>
  // Handle delete
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLElement;
      const postId = target.dataset.postId;
      
      if (!postId) return;
      
      if (!confirm('Are you sure you want to delete this post? This action cannot be undone.')) {
        return;
      }
      
      target.classList.add('loading');
      
      try {
        const response = await fetch(`/api/admin/forum/posts/${postId}`, {
          method: 'DELETE'
        });

        if (response.ok) {
          // Remove the card from the DOM
          const card = target.closest('.post-card');
          if (card) {
            const el = card as HTMLElement;
            el.style.transition = 'opacity 0.3s, transform 0.3s';
            el.style.opacity = '0';
            el.style.transform = 'scale(0.95)';
            setTimeout(() => el.remove(), 300);
          }
        } else {
          const data = await response.json();
          alert(`Failed: ${data.error}`);
          target.classList.remove('loading');
        }
      } catch (err) {
        alert('Failed to delete post');
        target.classList.remove('loading');
      }
    });
  });
</script>
