---
/**
 * Admin User Detail Page
 * Shows ALL database information about a specific user.
 * Admin-only access.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";
import Button from "@/components/fundations/elements/Button.astro";
import * as schema from "@/db/schema";
import {
  builds,
  forumThreads,
  forumPosts,
  wikiArticles,
  wikiRevisions,
  wikiComments,
  buildComments,
  meetups,
  staticPages,
} from "@/db/schema";
import { eq, desc, count } from "drizzle-orm";
import { ROLES, getRoleLevel, getRoleName } from "@/lib/roles";

export const prerender = false;

// Get current user for auth check
const currentUser = Astro.locals.user!;
const currentUserRole = (currentUser as any).role;

// Admin-only access check
if (getRoleLevel(currentUserRole) < ROLES.ADMIN) {
  return Astro.redirect("/");
}

// Get user ID from URL
const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/admin/users");
}

const db = Astro.locals.db;

// Fetch the user by ID
const userResult = await db
  .select()
  .from(schema.user)
  .where(eq(schema.user.id, id))
  .limit(1);

if (!userResult || userResult.length === 0) {
  return Astro.redirect("/admin/users");
}

const targetUser = userResult[0];

// Fetch user's sessions
const userSessions = await db
  .select()
  .from(schema.session)
  .where(eq(schema.session.userId, id))
  .orderBy(desc(schema.session.createdAt));

// Fetch user's builds (all statuses)
const userBuildsResult = await db
  .select({ count: count() })
  .from(schema.builds)
  .where(eq(schema.builds.authorId, id));

const buildCount = userBuildsResult[0]?.count ?? 0;

// Fetch user's forum threads
const userThreadsResult = await db
  .select({ count: count() })
  .from(schema.forumThreads)
  .where(eq(schema.forumThreads.authorId, id));

const threadCount = userThreadsResult[0]?.count ?? 0;

// Fetch user's wiki articles
const userArticlesResult = await db
  .select({ count: count() })
  .from(schema.wikiArticles)
  .where(eq(schema.wikiArticles.authorId, id));

const articleCount = userArticlesResult[0]?.count ?? 0;

// Helper for role badge colors
function getRoleBadgeClass(role: string | null) {
  switch (role) {
    case "admin": return "role-admin";
    case "moderator": return "role-moderator";
    case "maker": return "role-maker";
    case "trusted_maker": return "role-trusted-maker";
    default: return "role-member";
  }
}

// Helper to format date
function formatDate(date: Date | string | number | null | undefined): string {
  if (!date) return "Not set";
  const d = new Date(date);
  if (isNaN(d.getTime())) return "Invalid date";
  return d.toLocaleString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

// Helper to format relative time
function formatRelativeTime(date: Date | string | number | null | undefined): string {
  if (!date) return "Never";
  const d = new Date(date);
  if (isNaN(d.getTime())) return "Invalid date";
  const now = new Date();
  const diffMs = now.getTime() - d.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return "Today";
  if (diffDays === 1) return "Yesterday";
  if (diffDays < 7) return `${diffDays} days ago`;
  if (diffDays < 30) return `${Math.floor(diffDays / 7)} weeks ago`;
  if (diffDays < 365) return `${Math.floor(diffDays / 30)} months ago`;
  return `${Math.floor(diffDays / 365)} years ago`;
}

// Get role display name
const roleDisplayName = getRoleName(targetUser.role);
const roleLevel = getRoleLevel(targetUser.role);

// Check if user is banned
const isBanned = !!targetUser.bannedAt;

// Check if user is mod nominated
const isModNominated = !!targetUser.isModNominated;

// Fetch all content authored by this user
const userBuilds = await db
  .select()
  .from(builds)
  .where(eq(builds.authorId, id))
  .orderBy(desc(builds.createdAt))
  .limit(50);

const userForumThreads = await db
  .select()
  .from(forumThreads)
  .where(eq(forumThreads.authorId, id))
  .orderBy(desc(forumThreads.createdAt))
  .limit(50);

const userForumPosts = await db
  .select()
  .from(forumPosts)
  .where(eq(forumPosts.authorId, id))
  .orderBy(desc(forumPosts.createdAt))
  .limit(50);

const userWikiArticles = await db
  .select()
  .from(wikiArticles)
  .where(eq(wikiArticles.authorId, id))
  .orderBy(desc(wikiArticles.createdAt))
  .limit(50);

const userMeetups = await db
  .select()
  .from(meetups)
  .where(eq(meetups.organizerId, id))
  .orderBy(desc(meetups.createdAt))
  .limit(50);

const userBuildComments = await db
  .select()
  .from(buildComments)
  .where(eq(buildComments.authorId, id))
  .orderBy(desc(buildComments.createdAt))
  .limit(50);

const userWikiComments = await db
  .select()
  .from(wikiComments)
  .where(eq(wikiComments.authorId, id))
  .orderBy(desc(wikiComments.createdAt))
  .limit(50);

const userStaticPages = await db
  .select()
  .from(staticPages)
  .where(eq(staticPages.authorId, id))
  .orderBy(desc(staticPages.createdAt))
  .limit(50);
---

<AdminLayout title={`User: ${targetUser.name}`} section="users">
  <!-- Back link -->
  <div class="back-link">
    <a href="/admin/users" class="back-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to Users
    </a>
  </div>

  <!-- User Header -->
  <div class="user-header">
    <div class="user-avatar-large">
      {targetUser.image ? (
        <img src={targetUser.image} alt={targetUser.name} />
      ) : (
        <span class="user-initials">{targetUser.name?.charAt(0) || "?"}</span>
      )}
    </div>
    <div class="user-header-info">
      <h1 class="user-name">{targetUser.name}</h1>
      <div class="user-meta">
        <span class={`role-badge ${getRoleBadgeClass(targetUser.role)}`}>
          {roleDisplayName}
        </span>
        {isBanned && (
          <span class="banned-badge">Banned</span>
        )}
        {isModNominated && (
          <span class="nominated-badge">Mod Nominated</span>
        )}
        {!targetUser.emailVerified && (
          <span class="unverified-badge" title="Email not verified">⚠️ Unverified</span>
        )}
      </div>
      <div class="user-actions">
        <a href={`/user/${targetUser.id}`} class="btn-link" target="_blank">
          <Button variant="primary" size="sm">
            View Public Profile
          </Button>
        </a>
      </div>
    </div>
  </div>

  <!-- Content Grid -->
  <div class="detail-grid">
    <!-- Account Info Section -->
    <section class="detail-section">
      <h2 class="section-title">Account Information</h2>
      <dl class="detail-list">
        <div class="detail-row">
          <dt>User ID</dt>
          <dd class="mono">{targetUser.id}</dd>
        </div>
        <div class="detail-row">
          <dt>Email</dt>
          <dd>{targetUser.email}</dd>
        </div>
        <div class="detail-row">
          <dt>Display Name</dt>
          <dd>{targetUser.name}</dd>
        </div>
        <div class="detail-row">
          <dt>Avatar URL</dt>
          <dd class="mono">{targetUser.image || "Not set"}</dd>
        </div>
        <div class="detail-row">
          <dt>Bio</dt>
          <dd>{targetUser.bio || "Not set"}</dd>
        </div>
        <div class="detail-row">
          <dt>Email Verified</dt>
          <dd>
            {targetUser.emailVerified ? (
              <span class="status-yes">✓ Yes</span>
            ) : (
              <span class="status-no">✗ No</span>
            )}
          </dd>
        </div>
      </dl>
    </section>

    <!-- Role & Status Section -->
    <section class="detail-section">
      <h2 class="section-title">Role & Status</h2>
      <dl class="detail-list">
        <div class="detail-row">
          <dt>Current Role</dt>
          <dd>
            <span class={`role-badge ${getRoleBadgeClass(targetUser.role)}`}>
              {roleDisplayName}
            </span>
          </dd>
        </div>
        <div class="detail-row">
          <dt>Role Value</dt>
          <dd class="mono">{roleLevel} ({targetUser.role || "null"})</dd>
        </div>
        <div class="detail-row">
          <dt>Role Level</dt>
          <dd class="mono">
            {roleLevel === ROLES.VISITOR && "Visitor (0)"}
            {roleLevel === ROLES.MEMBER && "Member (10)"}
            {roleLevel === ROLES.MAKER && "Maker (20)"}
            {roleLevel === ROLES.TRUSTED_MAKER && "Trusted Maker (30)"}
            {roleLevel === ROLES.MODERATOR && "Moderator (40)"}
            {roleLevel === ROLES.ADMIN && "Admin (50)"}
          </dd>
        </div>
      </dl>
    </section>

    <!-- Ban Info Section -->
    <section class="detail-section">
      <h2 class="section-title">Ban Information</h2>
      <dl class="detail-list">
        <div class="detail-row">
          <dt>Is Banned</dt>
          <dd>
            {isBanned ? (
              <span class="status-no">✓ Yes</span>
            ) : (
              <span class="status-yes">✗ No</span>
            )}
          </dd>
        </div>
        {isBanned && (
          <>
            <div class="detail-row">
              <dt>Banned At</dt>
              <dd>{formatDate(targetUser.bannedAt)}</dd>
            </div>
            <div class="detail-row">
              <dt>Banned By</dt>
              <dd class="mono">{targetUser.bannedBy || "Unknown"}</dd>
            </div>
            <div class="detail-row">
              <dt>Ban Reason</dt>
              <dd>{targetUser.banReason || "No reason provided"}</dd>
            </div>
          </>
        )}
      </dl>
    </section>

    <!-- Mod Nomination Section -->
    <section class="detail-section">
      <h2 class="section-title">Moderator Nomination</h2>
      <dl class="detail-list">
        <div class="detail-row">
          <dt>Is Mod Nominated</dt>
          <dd>
            {isModNominated ? (
              <span class="status-yes">✓ Yes</span>
            ) : (
              <span class="status-no">✗ No</span>
            )}
          </dd>
        </div>
        {isModNominated && (
          <>
            <div class="detail-row">
              <dt>Nominated By</dt>
              <dd class="mono">{targetUser.modNominatedBy || "Unknown"}</dd>
            </div>
            <div class="detail-row">
              <dt>Nominated At</dt>
              <dd>{formatDate(targetUser.modNominatedAt)}</dd>
            </div>
          </>
        )}
      </dl>
    </section>

    <!-- Build Stats Section -->
    <section class="detail-section">
      <h2 class="section-title">Build Statistics</h2>
      <dl class="detail-list">
        <div class="detail-row">
          <dt>Accepted Build Count</dt>
          <dd>{targetUser.acceptedBuildCount ?? 0}</dd>
        </div>
        <div class="detail-row">
          <dt>First Build Published At</dt>
          <dd>{formatDate(targetUser.firstBuildPublishedAt)}</dd>
        </div>
        <div class="detail-row">
          <dt>Total Builds (all statuses)</dt>
          <dd>{buildCount}</dd>
        </div>
        <div class="detail-row">
          <dt>Forum Threads Created</dt>
          <dd>{threadCount}</dd>
        </div>
        <div class="detail-row">
          <dt>Wiki Articles Created</dt>
          <dd>{articleCount}</dd>
        </div>
      </dl>
    </section>

    <!-- Timestamps Section -->
    <section class="detail-section">
      <h2 class="section-title">Timestamps</h2>
      <dl class="detail-list">
        <div class="detail-row">
          <dt>Created At</dt>
          <dd>{formatDate(targetUser.createdAt)}</dd>
        </div>
        <div class="detail-row">
          <dt>Account Age</dt>
          <dd>{formatRelativeTime(targetUser.createdAt)}</dd>
        </div>
        <div class="detail-row">
          <dt>Updated At</dt>
          <dd>{formatDate(targetUser.updatedAt)}</dd>
        </div>
      </dl>
    </section>

    <!-- Active Sessions Section -->
    <section class="detail-section full-width">
      <h2 class="section-title">Active Sessions ({userSessions.length})</h2>
      {userSessions.length > 0 ? (
        <div class="sessions-table-container">
          <table class="sessions-table">
            <thead>
              <tr>
                <th>Session ID</th>
                <th>Created</th>
                <th>Expires</th>
                <th>IP Address</th>
                <th>User Agent</th>
              </tr>
            </thead>
            <tbody>
              {userSessions.map(session => (
                <tr>
                  <td class="mono">{session.id}</td>
                  <td>{formatDate(session.createdAt)}</td>
                  <td class={new Date(session.expiresAt) < new Date() ? "expired" : ""}>
                    {formatDate(session.expiresAt)}
                  </td>
                  <td class="mono">{session.ipAddress || "Unknown"}</td>
                  <td class="user-agent">{session.userAgent || "Unknown"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="no-sessions">No active sessions found for this user.</p>
      )}
    </section>

    <!-- Content by this user Section -->
    <section class="detail-section full-width">
      <h2 class="section-title">Content by this user</h2>
      
      {userBuilds.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Builds ({userBuilds.length})</h3>
          <div class="content-list">
            {userBuilds.map(build => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/builds/${build.slug}`} target="_blank" class="content-link">
                    {build.title}
                  </a>
                  <span class="content-meta">
                    <span class={`status-badge status-${build.status}`}>{build.status}</span>
                    <span class="content-date">{formatDate(build.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="builds" data-record-id={build.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userForumThreads.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Forum Threads ({userForumThreads.length})</h3>
          <div class="content-list">
            {userForumThreads.map(thread => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/forum/thread/${thread.id}`} target="_blank" class="content-link">
                    {thread.title}
                  </a>
                  <span class="content-meta">
                    <span class={`status-badge status-${thread.isLocked ? 'locked' : 'open'}`}>
                      {thread.isLocked ? "Locked" : "Open"}
                    </span>
                    <span class="content-date">{formatDate(thread.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="forumThreads" data-record-id={thread.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userForumPosts.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Forum Posts ({userForumPosts.length})</h3>
          <div class="content-list">
            {userForumPosts.map(post => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/forum/thread/${post.threadId}#post-${post.id}`} target="_blank" class="content-link">
                    Post #{post.id}
                  </a>
                  <span class="content-meta">
                    <span class="content-date">{formatDate(post.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="forumPosts" data-record-id={post.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userWikiArticles.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Wiki Articles ({userWikiArticles.length})</h3>
          <div class="content-list">
            {userWikiArticles.map(article => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/wiki/articles/${article.id}`} target="_blank" class="content-link">
                    {article.title}
                  </a>
                  <span class="content-meta">
                    <span class={`status-badge status-${article.status}`}>{article.status}</span>
                    <span class="content-date">{formatDate(article.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="wikiArticles" data-record-id={article.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userMeetups.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Meetups ({userMeetups.length})</h3>
          <div class="content-list">
            {userMeetups.map(meetup => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/meetups/${meetup.slug}`} target="_blank" class="content-link">
                    {meetup.title}
                  </a>
                  <span class="content-meta">
                    <span class={`status-badge status-${meetup.status}`}>{meetup.status}</span>
                    <span class="content-date">{formatDate(meetup.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="meetups" data-record-id={meetup.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userBuildComments.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Build Comments ({userBuildComments.length})</h3>
          <div class="content-list">
            {userBuildComments.map(comment => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/builds/${comment.buildSlug}#comment-${comment.id}`} target="_blank" class="content-link">
                    Comment on build #{comment.buildSlug}
                  </a>
                  <span class="content-meta">
                    <span class="content-date">{formatDate(comment.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="buildComments" data-record-id={comment.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userWikiComments.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Wiki Comments ({userWikiComments.length})</h3>
          <div class="content-list">
            {userWikiComments.map(comment => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/wiki/articles/${comment.articleId}#comment-${comment.id}`} target="_blank" class="content-link">
                    Comment on article #{comment.articleId}
                  </a>
                  <span class="content-meta">
                    <span class="content-date">{formatDate(comment.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="wikiComments" data-record-id={comment.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userStaticPages.length > 0 && (
        <div class="content-subsection">
          <h3 class="subsection-title">Static Pages ({userStaticPages.length})</h3>
          <div class="content-list">
            {userStaticPages.map(page => (
              <div class="content-item">
                <div class="content-item-info">
                  <a href={`/${page.slug}`} target="_blank" class="content-link">
                    {page.title}
                  </a>
                  <span class="content-meta">
                    <span class="content-date">{formatDate(page.createdAt)}</span>
                  </span>
                </div>
                <form class="reassign-form" data-table="staticPages" data-record-id={page.id}>
                  <select name="newAuthorId" class="user-select reassign-input" required>
                    <option value="">Loading users...</option>
                  </select>
                  <button type="submit" class="reassign-btn">Reassign</button>
                  <span class="reassign-feedback"></span>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}

      {userBuilds.length === 0 && userForumThreads.length === 0 && userForumPosts.length === 0 && userWikiArticles.length === 0 && userMeetups.length === 0 && userBuildComments.length === 0 && userWikiComments.length === 0 && userStaticPages.length === 0 && (
        <p class="no-content">No authored content found for this user.</p>
      )}
    </section>
  </div>
</AdminLayout>

<script>
  // Fetch all users for the reassign dropdowns
  let allUsers: Array<{ id: string; name: string; email: string }> = [];

  async function loadUsers() {
    try {
      const res = await fetch('/api/admin/users?limit=100');
      const data = await res.json();
      allUsers = data.users || [];
      populateAllSelects();
    } catch (err) {
      console.error('Failed to load users for reassign:', err);
    }
  }

  function populateAllSelects() {
    document.querySelectorAll('.user-select').forEach(select => {
      populateSelect(select as HTMLSelectElement);
    });
  }

  function populateSelect(select: HTMLSelectElement) {
    // Preserve the currently selected value
    const currentValue = select.value;
    select.innerHTML = '<option value="">Select user...</option>';
    allUsers.forEach(user => {
      const opt = document.createElement('option');
      opt.value = user.id;
      opt.textContent = `${user.name || 'Unnamed'} (${user.email})`;
      select.appendChild(opt);
    });
    // Restore selection if it still exists
    if (currentValue && allUsers.some(u => u.id === currentValue)) {
      select.value = currentValue;
    }
  }

  document.querySelectorAll('.reassign-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const target = e.target as HTMLFormElement;
      const table = target.dataset.table;
      const recordId = target.dataset.recordId;
      const newAuthorId = (target.querySelector('.user-select') as HTMLSelectElement).value;
      const feedback = target.querySelector('.reassign-feedback') as HTMLSpanElement;
      
      if (!table || !recordId) return;
      
      if (!newAuthorId) {
        feedback.textContent = '✗ Select a user';
        feedback.style.color = 'var(--color-danger)';
        return;
      }
      
      feedback.textContent = 'Reassigning...';
      feedback.style.color = 'var(--text-muted)';
      
      try {
        const res = await fetch('/api/admin/reassign', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ table, recordId, newAuthorId })
        });
        const data = await res.json();
        if (res.ok) {
          feedback.textContent = '✓ Reassigned!';
          feedback.style.color = 'var(--color-signal)';
        } else {
          feedback.textContent = `✗ ${data.error || 'Error'}`;
          feedback.style.color = 'var(--color-danger)';
        }
      } catch (err) {
        feedback.textContent = '✗ Network error';
        feedback.style.color = 'var(--color-danger)';
      }
    });
  });

  // Initialize user dropdowns on page load
  loadUsers();
</script>

