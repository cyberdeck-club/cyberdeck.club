---
/**
 * Announcements Management Page
 * CRUD for site-wide announcements. Admin-only.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";
import Button from "@/components/fundations/elements/Button.astro";
import { StaticPageEditor } from "@/components/editor/StaticPageEditor";
import * as schema from "@/db/schema";
import { eq, desc, isNull, and } from "drizzle-orm";

export const prerender = false;

// Get current user for role checking
const currentUser = Astro.locals.user!;
const currentUserRole = (currentUser as any).role;
const isAdmin = currentUserRole === "admin";

// Get announcements from DB (excluding soft-deleted)
const db = Astro.locals.db;
const announcements = await db
  .select({
    id: schema.announcements.id,
    title: schema.announcements.title,
    isPublished: schema.announcements.isPublished,
    publishedAt: schema.announcements.publishedAt,
    createdAt: schema.announcements.createdAt,
    updatedAt: schema.announcements.updatedAt,
    authorName: schema.user.name,
  })
  .from(schema.announcements)
  .leftJoin(schema.user, eq(schema.announcements.authorId, schema.user.id))
  .where(isNull(schema.announcements.deletedAt))
  .orderBy(desc(schema.announcements.createdAt));

// URL params for editing
const url = new URL(Astro.request.url);
const editId = url.searchParams.get("edit");
const isCreating = url.searchParams.get("create") === "true";

// Fetch full announcement data server-side when editing
let editContent = "";
let editTitle = "";
let editIsPublished = false;
let editPublishedAt: number | null = null;
if (editId) {
  try {
    const editResults = await db
      .select()
      .from(schema.announcements)
      .where(
        and(
          eq(schema.announcements.id, editId),
          isNull(schema.announcements.deletedAt)
        )
      )
      .limit(1);
    if (editResults.length > 0) {
      editContent = editResults[0].content || "";
      editTitle = editResults[0].title || "";
      editIsPublished = editResults[0].isPublished ?? false;
      editPublishedAt = editResults[0].publishedAt;
    }
  } catch (err) {
    console.warn("Could not fetch announcement for editing:", err);
  }
}
---

<AdminLayout title="Announcements" section="announcements">
  <div class="admin-header">
    <div>
      <h1 class="admin-title">Announcements</h1>
      <p class="admin-subtitle">{announcements.length} announcements</p>
    </div>
    {isAdmin && (
      <a href="?create=true" class="create-btn">
        <Button variant="default" size="sm">
          <svg slot="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New Announcement
        </Button>
      </a>
    )}
  </div>

  <!-- Editor Panel (shown when editing/creating) -->
  {(editId || isCreating) && (
    <div class="editor-panel">
      <div class="editor-header">
        <h2>{editId ? `Edit: ${editTitle || editId}` : "Create New Announcement"}</h2>
        <a href="/admin/announcements" class="close-btn">&times;</a>
      </div>
      <form id="announcement-form" class="editor-form">
        <input type="hidden" name="id" id="announcement-id" value={editId || ""} />

        <div class="form-group">
          <label for="announcement-title">Title</label>
          <input
            type="text"
            id="announcement-title"
            name="title"
            placeholder="Announcement title"
            value={editTitle}
            required
          />
        </div>

        <div class="form-group">
          <label>Content (Markdown)</label>
          <input type="hidden" id="announcement-content" name="content" value={editContent} />
          <StaticPageEditor
            client:only="react"
            hiddenInputId="announcement-content"
            initialContent={editContent}
          />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="checkbox-label">
              <input
                type="checkbox"
                id="announcement-published"
                name="isPublished"
                value="true"
                checked={editIsPublished}
              />
              Published
            </label>
            <span class="hint">Unpublished announcements are only visible to admins</span>
          </div>

          {editPublishedAt && (
            <div class="form-group">
              <span class="published-date-label">Published: {new Date(editPublishedAt * 1000).toLocaleDateString()}</span>
            </div>
          )}
        </div>

        <div class="form-actions">
          <Button type="submit" variant="default" id="save-btn">
            {editId ? "Update Announcement" : "Create Announcement"}
          </Button>
          {editId && (
            <Button type="button" variant="muted" id="delete-btn" class="delete-btn">
              Delete Announcement
            </Button>
          )}
        </div>
      </form>
    </div>
  )}

  <!-- Announcements List -->
  <div class="pages-list">
    {announcements.length > 0 ? (
      <div class="table-container">
        <table class="pages-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Published Date</th>
              <th>Created Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {announcements.map(announcement => (
              <tr>
                <td class="title-cell">
                  <span class="page-title">{announcement.title}</span>
                </td>
                <td>
                  <span class={`status-badge ${announcement.isPublished ? "published" : "draft"}`}>
                    {announcement.isPublished ? "Published" : "Draft"}
                  </span>
                </td>
                <td class="date-cell">
                  {announcement.publishedAt
                    ? new Date(announcement.publishedAt * 1000).toLocaleDateString()
                    : "—"}
                </td>
                <td class="date-cell">
                  {new Date(announcement.createdAt * 1000).toLocaleDateString()}
                </td>
                <td class="actions-cell">
                  <a href={`?edit=${announcement.id}`} class="edit-link">
                    <Button variant="muted" size="xs">Edit</Button>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M22 2L11 13"/>
            <path d="M22 2L15 22"/>
            <path d="M22 2H2"/>
            <path d="M11 13L15 22"/>
          </svg>
        </div>
        <h3>No announcements yet</h3>
        <p>Create your first announcement to share with the community.</p>
        {isAdmin && (
          <a href="?create=true">
            <Button variant="default">Create Announcement</Button>
          </a>
        )}
      </div>
    )}
  </div>
</AdminLayout>

<style>
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .admin-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
  }

  .admin-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0.5rem 0 0;
  }

  .create-btn {
    text-decoration: none;
  }

  /* Editor Panel */
  .editor-panel {
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 6px 6px 0 var(--color-primary);
  }

  .editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 3px solid var(--color-primary);
  }

  .editor-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    color: var(--text);
  }

  .close-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 2px solid var(--color-primary);
    border-radius: 8px;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s;
  }

  .close-btn:hover {
    background: var(--color-primary);
    color: white;
  }

  .editor-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: 1.25rem;
    height: 1.25rem;
    accent-color: var(--color-primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  .checkbox-label input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .published-date-label {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .form-group input:not([type="checkbox"]):not([type="radio"]),
  .form-group select,
  .form-group textarea {
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 3px solid var(--color-primary);
    border-radius: 8px;
    font-size: 0.95rem;
    color: var(--text);
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-secondary);
    box-shadow: 4px 4px 0 var(--color-secondary);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 150px;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.85rem;
  }

  .hint {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 2px solid var(--color-primary);
  }

  .form-actions .delete-btn {
    background: #e74c3c;
    border-color: #e74c3c;
    color: white;
  }

  .form-actions .delete-btn:hover {
    background: #c0392b;
    border-color: #c0392b;
  }

  /* Table */
  .table-container {
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    box-shadow: 6px 6px 0 var(--color-primary);
    -webkit-overflow-scrolling: touch;
  }

  .pages-table {
    width: 100%;
    border-collapse: collapse;
  }

  .pages-table th {
    text-align: left;
    padding: 1rem 1.25rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 700;
    background: var(--color-bg);
    border-bottom: 3px solid var(--color-primary);
  }

  .pages-table td {
    padding: 1rem 1.25rem;
    border-bottom: 2px solid var(--color-bg);
    vertical-align: middle;
  }

  .pages-table tr:last-child td {
    border-bottom: none;
  }

  .pages-table tr:hover td {
    background: var(--color-bg);
  }

  .title-cell {
    max-width: 300px;
  }

  .page-title {
    font-weight: 600;
    color: var(--text);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .status-badge.published {
    background: #2ecc71;
    color: white;
  }

  .status-badge.draft {
    background: #f39c12;
    color: white;
  }

  .date-cell {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .actions-cell {
    display: flex;
    gap: 0.5rem;
  }

  .edit-link {
    text-decoration: none;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 12px;
    box-shadow: 6px 6px 0 var(--color-primary);
  }

  .empty-icon {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .empty-state h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--text);
  }

  .empty-state p {
    color: var(--text-muted);
    margin: 0 0 1.5rem 0;
  }

  @media (max-width: 768px) {
    .pages-table {
      display: block;
      overflow-x: auto;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .form-actions {
      flex-direction: column;
    }
  }
</style>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const editId = urlParams.get('edit');
  const isCreating = urlParams.get('create') === 'true';

  // Save announcement
  document.getElementById('announcement-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    const isPublished = formData.get('isPublished') === 'true';

    const data: Record<string, unknown> = {
      title: formData.get('title') as string,
      content: formData.get('content') as string,
      isPublished,
    };

    const announcementId = (document.getElementById('announcement-id') as HTMLInputElement).value;

    try {
      let url: string;
      let method: string;

      if (announcementId && !isCreating) {
        // Update existing
        url = `/api/admin/announcements/${announcementId}`;
        method = 'PUT';
      } else {
        // Create new
        url = '/api/admin/announcements';
        method = 'POST';
      }

      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        window.location.href = '/admin/announcements';
      } else {
        const error = await response.json();
        alert(`Failed: ${error.error}`);
        saveBtn.disabled = false;
        saveBtn.textContent = announcementId && !isCreating ? 'Update Announcement' : 'Create Announcement';
      }
    } catch (err) {
      alert('Failed to save announcement');
      saveBtn.disabled = false;
      saveBtn.textContent = announcementId && !isCreating ? 'Update Announcement' : 'Create Announcement';
    }
  });

  // Delete announcement
  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    const announcementId = (document.getElementById('announcement-id') as HTMLInputElement).value;

    if (!announcementId) return;

    if (!confirm('Are you sure you want to delete this announcement? This cannot be undone.')) {
      return;
    }

    const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement;
    deleteBtn.disabled = true;
    deleteBtn.textContent = 'Deleting...';

    try {
      const response = await fetch(`/api/admin/announcements/${announcementId}`, {
        method: 'DELETE',
      });

      if (response.ok) {
        window.location.href = '/admin/announcements';
      } else {
        const error = await response.json();
        alert(`Failed: ${error.error}`);
        deleteBtn.disabled = false;
        deleteBtn.textContent = 'Delete Announcement';
      }
    } catch (err) {
      alert('Failed to delete announcement');
      deleteBtn.disabled = false;
      deleteBtn.textContent = 'Delete Announcement';
    }
  });
</script>