---
/**
 * Forum Category Page
 * Shows all threads in a specific forum category
 */

import ForumLayout from "@/layouts/ForumLayout.astro";
import ForumThreadPreview from "@/components/ForumThreadPreview.astro";

// Server-rendered (no static paths)
export const prerender = false;

// Category data lookup
const categories: Record<string, { name: string; description: string }> = {
  "introductions": { 
    name: "Introductions", 
    description: "New members introduce themselves and their cyberdeck goals" 
  },
  "build-help": { 
    name: "Build Help", 
    description: "Questions and troubleshooting during builds" 
  },
  "build-logs": { 
    name: "Build Logs", 
    description: "Step-by-step documentation of builds in progress" 
  },
  "showcase": { 
    name: "Showcase", 
    description: "Completed cyberdeck show-and-tell" 
  },
  "parts-sourcing": { 
    name: "Parts & Sourcing", 
    description: "Where to find components, group buys, deals" 
  },
  "meetups-events": { 
    name: "Meetups & Events", 
    description: "Organizing and announcing local build meetups" 
  },
  "off-topic": { 
    name: "Off-Topic", 
    description: "General community chat" 
  },
};

// Get category from URL params
const { category } = Astro.params;

// Validate category
if (!category || !categories[category]) {
  return Astro.redirect("/forum");
}

const categoryData = categories[category];

// Placeholder threads data
const threads = [
  {
    id: "1",
    title: "Hey from Portland! Building my first deck",
    author: "NeonBuilder",
    replyCount: 12,
    lastActivity: "2h ago",
    isPinned: true,
  },
  {
    id: "2",
    title: "Introduce yourself here!",
    author: "Admin",
    replyCount: 847,
    lastActivity: "1h ago",
    isPinned: true,
  },
  {
    id: "3",
    title: "Hello from Berlin! Retro ThinkPad build in progress",
    author: "GermanCyber",
    replyCount: 8,
    lastActivity: "5h ago",
    isPinned: false,
  },
  {
    id: "4",
    title: "NYC builder checking in - looking for local meetup info",
    author: "EmpireStateDeck",
    replyCount: 23,
    lastActivity: "1d ago",
    isPinned: false,
  },
  {
    id: "5",
    title: "First time builder from Australia!",
    author: "DownUnderDeck",
    replyCount: 15,
    lastActivity: "2d ago",
    isPinned: false,
  },
  {
    id: "6",
    title: "Long time lurker, finally joining the community",
    author: "SilentWatcher",
    replyCount: 6,
    lastActivity: "3d ago",
    isPinned: false,
  },
];

// Sort threads: pinned first, then by last activity
const sortedThreads = [...threads].sort((a, b) => {
  if (a.isPinned && !b.isPinned) return -1;
  if (!a.isPinned && b.isPinned) return 1;
  return 0;
});

// Pagination (placeholder)
const currentPage = 1;
const totalPages = 1;

// Sort options
const sortOptions = [
  { value: "latest", label: "Latest Activity" },
  { value: "newest", label: "Newest" },
  { value: "replies", label: "Most Replies" },
];
---

<ForumLayout 
  title={categoryData.name}
  description={categoryData.description}
  currentCategory={category}
  breadcrumb={[
    { label: categoryData.name, href: `/forum/${category}` }
  ]}
>
  <div class="category-page">
    <!-- Category Header -->
    <header class="category-header">
      <div class="header-content">
        <h1 class="category-title">{categoryData.name}</h1>
        <p class="category-description">{categoryData.description}</p>
      </div>
      <a href={`/forum/${category}/new`} class="new-thread-btn">
        <svg class="btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        New Thread ✨
      </a>
    </header>

    <!-- Sort & Filter Bar -->
    <div class="thread-controls">
      <div class="sort-tabs">
        {sortOptions.map((option) => (
          <button class="sort-tab" data-sort={option.value}>
            {option.label}
          </button>
        ))}
      </div>
      <div class="thread-count">
        {threads.length} thread{threads.length !== 1 ? 's' : ''}
      </div>
    </div>

    <!-- Thread List -->
    <section class="thread-list">
      {sortedThreads.map((thread) => (
        <ForumThreadPreview 
          title={thread.title}
          category={categoryData.name}
          replyCount={thread.replyCount}
          lastActivity={thread.lastActivity}
          href={`/forum/thread/${thread.id}`}
        />
      ))}
    </section>

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav class="pagination">
        <button class="page-btn" disabled>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Previous
        </button>
        <span class="page-info">Page {currentPage} of {totalPages}</span>
        <button class="page-btn" disabled>
          Next
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </nav>
    )}
  </div>
</ForumLayout>

<style>
  .category-page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Category Header */
  .category-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
  }

  .header-content {
    flex: 1;
  }

  .category-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .category-description {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .new-thread-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    background: var(--color-primary);
    border: 3px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    box-shadow: 4px 4px 0 var(--border);
    white-space: nowrap;
  }

  .new-thread-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 6px 6px 0 var(--border);
  }

  .btn-icon {
    flex-shrink: 0;
  }

  /* Thread Controls */
  .thread-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 10px;
  }

  .sort-tabs {
    display: flex;
    gap: 0.5rem;
  }

  .sort-tab {
    padding: 0.4rem 0.85rem;
    background: transparent;
    border: 2px solid transparent;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .sort-tab:hover {
    background: var(--color-primary);
    color: white;
  }

  .sort-tab.active {
    background: var(--color-secondary);
    color: white;
  }

  .thread-count {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  /* Thread List */
  .thread-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding-top: 1rem;
  }

  .page-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .page-btn:hover:not(:disabled) {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .page-info {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .category-header {
      flex-direction: column;
      gap: 1rem;
    }

    .category-title {
      font-size: 1.5rem;
    }

    .new-thread-btn {
      width: 100%;
      justify-content: center;
    }

    .thread-controls {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }

    .sort-tabs {
      overflow-x: auto;
      padding-bottom: 0.25rem;
    }
  }
</style>

<script>
  // Sort tabs functionality (placeholder for real implementation)
  const sortTabs = document.querySelectorAll('.sort-tab');
  sortTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      sortTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });
</script>
