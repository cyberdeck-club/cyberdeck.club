  }

  .edit-post-btn:hover {
    text-decoration: underline;
  }

  .edit-post-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* Edit Form Container */
  .edit-form-container {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--surface);
    border: 2px solid var(--color-primary);
    border-radius: 4px;
  }

  /* Hidden utility class */
  .hidden {
    display: none !important;
  }
</style>

<script>
  // Client-side script to handle edit and delete button clicks
  document.addEventListener('DOMContentLoaded', () => {
    // Edit button handlers
    const editButtons = document.querySelectorAll('.edit-post-btn');
    
    editButtons.forEach((button) => {
      button.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const postId = btn.dataset.postId;
        if (!postId) return;
        
        const contentEl = document.getElementById(`post-content-${postId}`);
        const editFormEl = document.getElementById(`edit-form-${postId}`);
        
        if (contentEl && editFormEl) {
          contentEl.classList.toggle('hidden');
          editFormEl.classList.toggle('hidden');
        }
      });
    });

    // Delete thread handler
    const deleteThreadBtn = document.querySelector('.delete-thread-btn') as HTMLButtonElement | null;
    if (deleteThreadBtn) {
      deleteThreadBtn.addEventListener('click', async () => {
        const threadId = deleteThreadBtn.dataset.threadId;
        if (!threadId) return;

        if (!confirm('Are you sure you want to delete this thread? This will remove the thread and all its replies.')) {
          return;
        }

        deleteThreadBtn.disabled = true;
        deleteThreadBtn.textContent = 'Deleting...';

        try {
          const res = await fetch(`/api/forum/threads/${threadId}`, { method: 'DELETE' });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.error || 'Failed to delete thread');
          }
          window.location.href = '/forum';
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Failed to delete thread');
          deleteThreadBtn.disabled = false;
          deleteThreadBtn.textContent = 'Delete Thread';
        }
      });
    }

    // Delete post handlers
    const deletePostButtons = document.querySelectorAll('.delete-post-btn');
    deletePostButtons.forEach((button) => {
      button.addEventListener('click', async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const postId = btn.dataset.postId;
        if (!postId) return;

        if (!confirm('Are you sure you want to delete this reply?')) {
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Deleting...';

        try {
          const res = await fetch(`/api/forum/posts/${postId}`, { method: 'DELETE' });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.error || 'Failed to delete post');
          }
          // Remove the post element from the page
          const postWrapper = document.getElementById(`post-wrapper-${postId}`);
          if (postWrapper) {
            postWrapper.style.opacity = '0.5';
            postWrapper.style.pointerEvents = 'none';
            postWrapper.innerHTML = '<div style="padding: 1rem; color: var(--text-muted, #888); font-style: italic;">This reply has been deleted.</div>';
          }
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Failed to delete post');
          btn.disabled = false;
          btn.textContent = 'Delete';
        }
      });
    });
  });
</script>
