---
/**
 * Forum Thread View Page
 * Shows a single thread with its replies
 */

import ForumLayout from "@/layouts/ForumLayout.astro";
import { getForumThread, getForumPosts } from "@/lib/forum";
import { renderMarkdownToHtml } from "@/utils/MarkdownRenderer";
import { hasAcceptedGuidelines } from "@/lib/guidelines";
import { ReplyForm } from "@/components/forum/ReplyForm";

export const prerender = false;

const db = Astro.locals.db!;
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/forum");
}

// Fetch thread data
const threadResult = await getForumThread(db, id);
const notFound = !threadResult || threadResult.length === 0;

let threadData = notFound ? null : threadResult[0];
if (!threadData) {
  return Astro.redirect("/forum");
}
const td = threadData;
let postsResult: Awaited<ReturnType<typeof getForumPosts>> = [];

// Fetch posts if thread exists
if (!notFound && threadData) {
  postsResult = await getForumPosts(db, id);
}

// Get current user from session (populated by middleware)
const currentUser = Astro.locals.user;

// Check guidelines acceptance for reply form
let guidelinesAccepted = false;
if (currentUser) {
  guidelinesAccepted = await hasAcceptedGuidelines(db, currentUser.id);
}

// Fetch posts including the first post (for thread body)
let posts: Array<{
  post: { id: string; threadId: string; authorId: string; content: string; createdAt: number; updatedAt: number };
  authorName: string;
}> = [];
if (!notFound && threadData) {
  postsResult = await getForumPosts(db, id);
  posts = postsResult;
}

// The first post's content is the thread body
const threadBodyContent = posts.length > 0 ? posts[0].post.content : "";

function formatDate(timestamp: number): string {
  const date = new Date(timestamp);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatRelativeTime(timestamp: number | null): string {
  if (!timestamp) return "Unknown";
  const date = new Date(timestamp);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);
  
  if (diffMins < 1) return "Just now";
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHours < 24) return `${diffHours}h ago`;
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString();
}
---
{notFound ? (
  <ForumLayout
    title="Thread Not Found"
    description="The requested forum thread could not be found"
  >
    <div class="not-found">
      <h1 class="not-found-title">Thread Not Found</h1>
      <p class="not-found-text">The requested forum thread could not be found or has been deleted.</p>
      <a href="/forum" class="back-link">← Back to Forum</a>
    </div>
  </ForumLayout>
) : (
  <ForumLayout
    title={td.thread.title}
    description={`Forum thread: ${td.thread.title}`}
    currentCategory={td.categorySlug}
    breadcrumb={[
      { label: td.categoryName, href: `/forum/${td.categorySlug}` },
      { label: td.thread.title, href: `/forum/thread/${td.thread.id}` }
    ]}
  >
    <article class="thread-view">
      {/* Thread Header */}
      <header class="thread-header">
        <div class="thread-badges">
          <a href={`/forum/${td.categorySlug}`} class="category-badge">
            {threadData.categoryName}
          </a>
          {threadData.thread.isPinned === 1 && <span class="badge pin">📌 Pinned</span>}
          {threadData.thread.isLocked === 1 && <span class="badge lock">🔒 Locked</span>}
        </div>
        
        <h1 class="thread-title">{threadData.thread.title}</h1>
        
        <div class="thread-meta">
          <span class="meta-item">
            <svg class="meta-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="6" r="4" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 14C2 11.2386 4.23858 9 7 9H9C11.7614 9 14 11.2386 14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>Started by <strong>{threadData.authorName}</strong></span>
          </span>
          <span class="meta-separator">•</span>
          <span class="meta-item">{formatDate(threadData.thread.createdAt)}</span>
          <span class="meta-separator">•</span>
          <span class="meta-item">{threadData.thread.postCount ?? 0} replies</span>
        </div>
      </header>

      <div class="thread-layout">
        {/* Main Content */}
        <div class="thread-main">
          {/* Original Post */}
          <div class="post original-post">
            <div class="post-sidebar">
              <div class="user-avatar">
                {threadData.authorName.charAt(0).toUpperCase()}
              </div>
              <div class="user-name">{threadData.authorName}</div>
              <div class="user-badge">Member</div>
            </div>
            <div class="post-content">
              <div class="post-header">
                <span class="post-time">{formatRelativeTime(threadData.thread.createdAt)}</span>
              </div>
              <div class="post-body prose" set:html={renderMarkdownToHtml(threadBodyContent)} />
            </div>
          </div>

          {/* Replies */}
          <section class="replies-section">
            <h2 class="replies-title">
              Replies ({posts.length - 1})
            </h2>
            
            {posts.slice(1).map((item) => (
              <div class="post reply">
                <div class="post-sidebar">
                  <div class="user-avatar secondary">
                    {item.authorName.charAt(0).toUpperCase()}
                  </div>
                  <div class="user-name">{item.authorName}</div>
                  <div class="user-badge">Member</div>
                </div>
                <div class="post-content">
                  <div class="post-header">
                    <span class="post-time">{formatRelativeTime(item.post.createdAt)}</span>
                  </div>
                  <div class="post-body prose" set:html={renderMarkdownToHtml(item.post.content)} />
                </div>
              </div>
            ))}
          </section>

          {/* Reply Form */}
          {currentUser && threadData.thread.isLocked !== 1 ? (
            <div id="reply-form-container" class="reply-form-wrapper">
              <ReplyForm
                client:load
                threadId={id}
                guidelinesAccepted={guidelinesAccepted}
                redirectUrl={`/forum/thread/${id}`}
              />
            </div>
          ) : (
            <div class="reply-form-disabled">
              <p>
                {threadData.thread.isLocked === 1
                  ? "🔒 This thread is locked and cannot receive new replies."
                  : "💬 Log in to post a reply."}
              </p>
              {!currentUser && (
                <a href={`/login?redirect=/forum/thread/${id}`} class="login-link">Sign in to reply →</a>
              )}
            </div>
          )}
        </div>

        {/* Sidebar */}
        <aside class="thread-sidebar">
          <div class="sidebar-card">
            <h3 class="sidebar-title">Thread Info</h3>
            <dl class="thread-info-list">
              <div class="info-item">
                <dt>Category</dt>
                <dd>
                  <a href={`/forum/${threadData.categorySlug}`} class="info-link">
                    {threadData.categoryName}
                  </a>
                </dd>
              </div>
              <div class="info-item">
                <dt>Started</dt>
                <dd>{formatDate(threadData.thread.createdAt)}</dd>
              </div>
              <div class="info-item">
                <dt>Last Reply</dt>
                <dd>{formatRelativeTime(threadData.thread.lastReplyAt)}</dd>
              </div>
              <div class="info-item">
                <dt>Replies</dt>
                <dd>{threadData.thread.postCount ?? 0}</dd>
              </div>
            </dl>
          </div>

          <div class="sidebar-card">
            <h3 class="sidebar-title">Author</h3>
            <div class="author-info">
              <div class="author-avatar">
                {threadData.authorName.charAt(0).toUpperCase()}
              </div>
              <div class="author-details">
                <span class="author-name">{threadData.authorName}</span>
                <span class="author-role">Member</span>
              </div>
            </div>
            <button class="subscribe-btn">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 2V8L10 11M2 11H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Subscribe
            </button>
          </div>

          <div class="sidebar-card">
            <h3 class="sidebar-title">Actions</h3>
            <div class="action-list">
              <button class="action-list-btn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M12 5L5 12L3 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Share Thread
              </button>
              <button class="action-list-btn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 8H12M4 4H12M4 12H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Report Thread
              </button>
            </div>
          </div>
        </aside>
      </div>
    </article>
  </ForumLayout>
)}

<style>
  .thread-view {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Thread Header */
  .thread-header {
    padding-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
  }

  .thread-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .category-badge {
    padding: 0.25rem 0.75rem;
    background: var(--color-secondary);
    color: var(--text-inverse);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .category-badge:hover {
    background: var(--color-primary);
  }

  .category-badge:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .badge {
    padding: 0.25rem 0.5rem;
    font-size: 0.7rem;
    border-radius: 4px;
  }

  .badge.pin {
    background: var(--color-accent);
  }

  .badge.lock {
    background: var(--color-accent);
  }

  .thread-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 4vw, 1.75rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .thread-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .meta-icon {
    opacity: 0.7;
  }

  .meta-separator {
    opacity: 0.5;
  }

  /* Thread Layout */
  .thread-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: start;
  }

  .thread-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Posts */
  .post {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
  }

  .post.original-post {
    border-color: var(--color-primary);
    border-width: 3px;
  }

  .post-sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 70px;
    flex-shrink: 0;
  }

  .user-avatar {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--text-inverse);
    font-weight: 800;
    font-size: 1.25rem;
    border-radius: 50%;
    border: 3px solid var(--border);
  }

  .user-avatar.secondary {
    background: var(--color-secondary);
  }

  .user-name {
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
    color: var(--text);
  }

  .user-badge {
    font-size: 0.6rem;
    padding: 0.15rem 0.4rem;
    background: var(--color-accent);
    border-radius: 4px;
    font-weight: 600;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-header {
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-time {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
  }

  .post-body p {
    margin: 0;
  }

  .post-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: transparent;
    border: 2px solid var(--border);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .action-btn:hover {
    background: var(--color-primary);
    color: var(--text-inverse);
    border-color: var(--color-primary);
  }

  .action-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* Replies Section */
  .replies-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .replies-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  /* Reply Form */
  .reply-form {
    padding: 1.5rem;
    background: var(--surface);
    border: 3px solid var(--color-secondary);
    border-radius: 4px;
  }

  .reply-form-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .reply-textarea {
    width: 100%;
    padding: 1rem;
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.6;
    resize: vertical;
    min-height: 120px;
  }

  .reply-textarea:focus {
    outline: none;
    border-color: var(--focus);
  }

  .reply-form-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 1rem;
  }

  .submit-btn {
    padding: 0.75rem 1.5rem;
    background: var(--color-primary);
    border: 3px solid var(--border);
    border-radius: 4px;
    font-weight: 700;
    color: var(--text-inverse);
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 3px 3px 0 var(--shadow-hard);
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 5px 5px 0 var(--shadow-hard);
  }

  .submit-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .reply-form-disabled {
    padding: 1.5rem;
    background: var(--surface);
    border: 2px dashed var(--border);
    border-radius: 4px;
    text-align: center;
  }

  .reply-form-disabled p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Thread Sidebar */
  .thread-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 2rem;
  }

  .sidebar-card {
    padding: 1rem;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 4px;
  }

  .sidebar-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
    margin: 0 0 0.75rem;
  }

  .thread-info-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
  }

  .info-item dt {
    color: var(--text-muted);
    font-weight: 500;
  }

  .info-item dd {
    margin: 0;
    font-weight: 600;
    color: var(--text);
  }

  .info-link {
    color: var(--color-secondary);
    text-decoration: none;
  }

  .info-link:hover {
    text-decoration: underline;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--text-inverse);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 50%;
    border: 2px solid var(--border);
  }

  .author-details {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .author-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .author-role {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .subscribe-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: var(--color-secondary);
    border: 2px solid var(--border);
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-inverse);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .subscribe-btn:hover {
    background: var(--color-primary);
  }

  .subscribe-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .action-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .action-list-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: transparent;
    border: 2px solid var(--border);
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
    text-align: left;
  }

  .action-list-btn:hover {
    background: var(--surface);
    color: var(--text);
    border-color: var(--color-primary);
  }

  .action-list-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .thread-layout {
      grid-template-columns: 1fr;
    }

    .thread-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .sidebar-card {
      flex: 1;
      min-width: 200px;
    }
  }

  @media (max-width: 640px) {
    .thread-title {
      font-size: 1.35rem;
    }

    .post {
      flex-direction: column;
      gap: 0.75rem;
    }

    .post-sidebar {
      flex-direction: row;
      width: auto;
      justify-content: flex-start;
    }

    .user-badge {
      display: none;
    }

    .thread-meta {
      font-size: 0.75rem;
    }
  }
</style>
