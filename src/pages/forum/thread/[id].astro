---
/**
 * Forum Thread View Page
 * Shows a single thread with its replies
 */

import ForumLayout from "@/layouts/ForumLayout.astro";
import { getForumThread, getForumPosts } from "@/lib/forum";
import { getBlockedUserIds } from "@/lib/blocking";
import { renderMarkdownToHtml } from "@/utils/MarkdownRenderer";
import { epochToDate } from "@/lib/timestamp";
import { hasAcceptedGuidelines } from "@/lib/guidelines";
import { ReplyForm } from "@/components/forum/ReplyForm";
import { EditPostForm } from "@/components/forum/EditPostForm";
import ReportButton from "@/components/reports/ReportButton";
import { ROLES, requireRole, getRoleLevel } from "@/lib/roles";
import { getLatestEdit } from "@/lib/edit-history";
import * as schema from "../../../db/schema";
import { eq } from "drizzle-orm";

export const prerender = false;

const db = Astro.locals.db!;
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/forum");
}

// Fetch thread data
const threadResult = await getForumThread(db, id);
const notFound = !threadResult || threadResult.length === 0;

let threadData = notFound ? null : threadResult[0];
if (!threadData) {
  return Astro.redirect("/forum");
}
const td = threadData;
let postsResult: Awaited<ReturnType<typeof getForumPosts>> = [];

// Get current user from session (populated by middleware)
const currentUser = Astro.locals.user;

// Get blocked user IDs for content filtering
const blockedUserIds = currentUser ? await getBlockedUserIds(db, currentUser.id) : [];
const isThreadAuthorBlocked = blockedUserIds.includes(threadData.thread.authorId);

// Fetch posts if thread exists (filtered by blocked users)
if (!notFound && threadData) {
  postsResult = await getForumPosts(db, id, { excludeUserIds: blockedUserIds });
}

// Check guidelines acceptance for reply form
let guidelinesAccepted = false;
if (currentUser) {
  guidelinesAccepted = await hasAcceptedGuidelines(db, currentUser.id);
}

// Check if user can edit this thread
const isThreadAuthor = currentUser && threadData.thread.authorId === currentUser.id;
const isModOrAdmin = currentUser && requireRole(currentUser.role, ROLES.MODERATOR);
const canEditThread = isThreadAuthor || isModOrAdmin;

// Fetch posts including the first post (for thread body)
let posts: Array<{
  post: { id: string; threadId: string; authorId: string; content: string; createdAt: number; updatedAt: number };
  authorName: string;
  authorId: string;
}> = [];
if (!notFound && threadData) {
  posts = postsResult;
}

// The first post's content is the thread body
const threadBodyContent = posts.length > 0 ? posts[0].post.content : "";

function formatDate(timestamp: number): string {
  const date = epochToDate(timestamp);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatRelativeTime(timestamp: number | null): string {
  if (!timestamp) return "Unknown";
  const date = epochToDate(timestamp);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);
  
  if (diffMins < 1) return "Just now";
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHours < 24) return `${diffHours}h ago`;
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString();
}

// Check if current user can edit a specific post
// Moderators/admins can always edit, authors only within 30-minute window
function canEditPost(post: { id: string; authorId: string; createdAt: number }): boolean {
  if (!currentUser) return false;
  if (requireRole(currentUser.role, ROLES.MODERATOR)) return true;
  const isPostAuthor = post.authorId === currentUser.id;
  if (!isPostAuthor) return false;
  // 30-minute window for author-only edits
  const thirtyMinutesInSeconds = 30 * 60;
  const now = Math.floor(Date.now() / 1000);
  return (now - post.createdAt) < thirtyMinutesInSeconds;
}

// Check if current user can delete a specific post
// Authors, moderators, and admins can delete (no time limit)
function canDeletePost(post: { id: string; authorId: string }): boolean {
  if (!currentUser) return false;
  if (requireRole(currentUser.role, ROLES.MODERATOR)) return true;
  return post.authorId === currentUser.id;
}

// Check if current user can delete this thread
const canDeleteThread = isThreadAuthor || isModOrAdmin;

// Pre-fetch edit history for all posts (batched approach)
const postEditCache = new Map<string, { editorName: string; editedAt: number } | null>();

// Fetch edit info for all posts that have been edited
for (const item of posts) {
  // Only fetch if post was edited (updatedAt > createdAt)
  if (item.post.updatedAt > item.post.createdAt) {
    try {
      const latestEdit = await getLatestEdit(db, "forum_post", item.post.id);
      if (latestEdit) {
        const [editor] = await db
          .select({ name: schema.user.name })
          .from(schema.user)
          .where(eq(schema.user.id, latestEdit.editorId))
          .limit(1);
        if (editor) {
          postEditCache.set(item.post.id, {
            editorName: editor.name,
            editedAt: latestEdit.editedAt,
          });
        } else {
          postEditCache.set(item.post.id, null);
        }
      } else {
        postEditCache.set(item.post.id, null);
      }
    } catch {
      postEditCache.set(item.post.id, null);
    }
  }
}
---
{notFound ? (
  <ForumLayout
    title="Thread Not Found"
    description="The requested forum thread could not be found"
  >
    <div class="not-found">
      <h1 class="not-found-title">Thread Not Found</h1>
      <p class="not-found-text">The requested forum thread could not be found or has been deleted.</p>
      <a href="/forum" class="back-link">← Back to Forum</a>
    </div>
  </ForumLayout>
) : (
  <ForumLayout
    title={td.thread.title}
    description={`Forum thread: ${td.thread.title}`}
    currentCategory={td.categorySlug}
    breadcrumb={[
      { label: td.categoryName, href: `/forum/${td.categorySlug}` },
      { label: td.thread.title, href: `/forum/thread/${td.thread.id}` }
    ]}
  >
    <article class="thread-view">
      {/* Blocked author notice */}
      {isThreadAuthorBlocked && (
        <div class="blocked-notice" role="status">
          <p>This thread was created by a user you've blocked. Their content is hidden.</p>
        </div>
      )}

      {/* Thread Header */}
      <header class="thread-header">
        <div class="thread-badges">
          <a href={`/forum/${td.categorySlug}`} class="category-badge">
            {threadData.categoryName}
          </a>
          {threadData.thread.isPinned === 1 && <span class="badge pin">📌 Pinned</span>}
          {threadData.thread.isLocked === 1 && <span class="badge lock">🔒 Locked</span>}
        </div>
        
        <h1 class="thread-title">
          {threadData.thread.title}
          <span class="thread-actions">
            {canEditThread && (
              <a
                href={`/forum/thread/${threadData.thread.id}/edit`}
                class="text-sm text-blue-600 hover:text-blue-800 ml-2"
              >
                Edit Thread
              </a>
            )}
            {canDeleteThread && (
              <button
                class="delete-thread-btn text-sm ml-2"
                data-thread-id={threadData.thread.id}
                style="color: var(--color-danger, #e53e3e); cursor: pointer; background: none; border: none; font-size: inherit;"
              >
                Delete Thread
              </button>
            )}
          </span>
        </h1>
        
        <div class="thread-meta">
          <span class="meta-item">
            <svg class="meta-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="6" r="4" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 14C2 11.2386 4.23858 9 7 9H9C11.7614 9 14 11.2386 14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>Started by <strong><a href={`/user/${threadData.authorId}`} class="author-link">{threadData.authorName}</a></strong></span>
          </span>
          <span class="meta-separator">•</span>
          <span class="meta-item">{formatDate(threadData.thread.createdAt)}</span>
          <span class="meta-separator">•</span>
          <span class="meta-item">{threadData.thread.postCount ?? 0} replies</span>
        </div>
      </header>

      <div class="thread-layout">
        {/* Main Content */}
        <div class="thread-main">
          {/* Original Post */}
          <div class="post original-post" id={`post-wrapper-${threadData.thread.id}`}>
            <div class="post-sidebar">
              <div class="user-avatar">
                {threadData.authorName.charAt(0).toUpperCase()}
              </div>
              <div class="user-name"><a href={`/user/${threadData.authorId}`} class="author-link">{threadData.authorName}</a></div>
              <div class="user-badge">Member</div>
            </div>
            <div class="post-content">
              <div class="post-header">
                <span class="post-time">{formatRelativeTime(threadData.thread.createdAt)}</span>
              </div>
              <div id={`post-content-${threadData.thread.id}`} class="post-body prose" set:html={renderMarkdownToHtml(threadBodyContent)} />
            </div>
          </div>

          {/* Replies */}
          <section class="replies-section">
            <h2 class="replies-title">
              Replies ({posts.length - 1})
            </h2>
            
            {posts.slice(1).map((item) => (
              <div class="post reply" id={`post-wrapper-${item.post.id}`}>
                <div class="post-sidebar">
                  <div class="user-avatar secondary">
                    {item.authorName.charAt(0).toUpperCase()}
                  </div>
                  <div class="user-name"><a href={`/user/${item.authorId}`} class="author-link">{item.authorName}</a></div>
                  <div class="user-badge">Member</div>
                </div>
                <div class="post-content">
                  <div class="post-header">
                    <span class="post-time">{formatRelativeTime(item.post.createdAt)}</span>
                    {canEditPost(item.post) && (
                      <button
                        class="edit-post-btn text-sm text-blue-600 hover:text-blue-800 ml-2"
                        data-post-id={item.post.id}
                        data-post-content-id={`post-content-${item.post.id}`}
                        data-edit-form-id={`edit-form-${item.post.id}`}
                      >
                        Edit
                      </button>
                    )}
                    {canDeletePost(item.post) && (
                      <button
                        class="delete-post-btn text-sm ml-2"
                        data-post-id={item.post.id}
                        style="color: var(--color-danger, #e53e3e); cursor: pointer; background: none; border: none;"
                      >
                        Delete
                      </button>
                    )}
                    {currentUser && (
                      <span class="ml-2">
                        <ReportButton
                          client:visible
                          entityType="forum_post"
                          entityId={item.post.id}
                          userRole={getRoleLevel(currentUser.role)}
                        />
                      </span>
                    )}
                  </div>
                  <div id={`post-content-${item.post.id}`} class="post-body prose" set:html={renderMarkdownToHtml(item.post.content)} />
                  {(() => {
                    const postEditInfo = postEditCache.get(item.post.id);
                    return postEditInfo && (
                      <p class="text-xs text-[var(--text-muted)] mt-2">
                        Last edited by {postEditInfo.editorName} on {new Date(postEditInfo.editedAt * 1000).toLocaleDateString()}
                      </p>
                    );
                  })()}
                  <div id={`edit-form-${item.post.id}`} class="hidden edit-form-container">
                    <EditPostForm
                      client:load
                      postId={item.post.id}
                      initialContent={item.post.content}
                      threadId={threadData.thread.id}
                      surface="forum"
                    />
                  </div>
                </div>
              </div>
            ))}
          </section>

          {/* Reply Form */}
          {currentUser && threadData.thread.isLocked !== 1 ? (
            <div id="reply-form-container" class="reply-form-wrapper">
              <ReplyForm
                client:load
                threadId={id}
                guidelinesAccepted={guidelinesAccepted}
                redirectUrl={`/forum/thread/${id}`}
              />
            </div>
          ) : threadData.thread.isLocked === 1 ? (
            <div class="reply-form-disabled">
              <p>🔒 This thread is locked and cannot receive new replies.</p>
            </div>
          ) : !currentUser ? (
            <div class="reply-form-disabled">
              <p>Want to join the conversation? Create an account to reply.</p>
              <a href={`/register?redirect=/forum/thread/${id}`} class="login-link">Create an account →</a>
            </div>
          ) : null}
        </div>

        {/* Sidebar */}
        <aside class="thread-sidebar">
          <div class="sidebar-card">
            <h3 class="sidebar-title">Thread Info</h3>
            <dl class="thread-info-list">
              <div class="info-item">
                <dt>Category</dt>
                <dd>
                  <a href={`/forum/${threadData.categorySlug}`} class="info-link">
                    {threadData.categoryName}
                  </a>
                </dd>
              </div>
              <div class="info-item">
                <dt>Started</dt>
                <dd>{formatDate(threadData.thread.createdAt)}</dd>
              </div>
              <div class="info-item">
                <dt>Last Reply</dt>
                <dd>{formatRelativeTime(threadData.thread.lastReplyAt)}</dd>
              </div>
              <div class="info-item">
                <dt>Replies</dt>
                <dd>{threadData.thread.postCount ?? 0}</dd>
              </div>
            </dl>
          </div>

          <div class="sidebar-card">
            <h3 class="sidebar-title">Author</h3>
            <div class="author-info">
              <div class="author-avatar">
                {threadData.authorName.charAt(0).toUpperCase()}
              </div>
              <div class="author-details">
                <span class="author-name"><a href={`/user/${threadData.authorId}`} class="author-link">{threadData.authorName}</a></span>
                <span class="author-role">Member</span>
              </div>
            </div>
            <button class="subscribe-btn opacity-55 cursor-not-allowed" disabled>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 2V8L10 11M2 11H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Subscribe
            </button>
          </div>

          <div class="sidebar-card">
            <h3 class="sidebar-title">Actions</h3>
            <div class="action-list">
              <button class="action-list-btn" disabled>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M12 5L5 12L3 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Share Thread
              </button>
              {currentUser && (
                <div class="action-list-report">
                  <ReportButton
                    client:visible
                    entityType="forum_thread"
                    entityId={threadData.thread.id}
                    userRole={getRoleLevel(currentUser.role)}
                  />
                </div>
              )}
            </div>
          </div>
        </aside>
      </div>
    </article>
  </ForumLayout>
)}

<style>
  .thread-view {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .blocked-notice {
    padding: 1rem 1.25rem;
    background: var(--color-accent);
    border: 3px solid var(--border);
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .blocked-notice p {
    margin: 0;
  }

  /* Thread Header */
  .thread-header {
    padding-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
  }

  .thread-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .category-badge {
    padding: 0.25rem 0.75rem;
    background: var(--color-secondary);
    color: var(--text-inverse);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .category-badge:hover {
    background: var(--color-primary);
  }

  .category-badge:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .badge {
    padding: 0.25rem 0.5rem;
    font-size: 0.7rem;
    border-radius: 4px;
  }

  .badge.pin {
    background: var(--color-accent);
  }

  .badge.lock {
    background: var(--color-accent);
  }

  .thread-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 4vw, 1.75rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .thread-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .meta-icon {
    opacity: 0.7;
  }

  .meta-separator {
    opacity: 0.5;
  }

  /* Thread Layout */
  .thread-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: start;
  }

  .thread-main {
    max-width: calc(100vw - 2rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Posts */
  .post {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
  }

  .post.original-post {
    border-color: var(--color-primary);
    border-width: 3px;
  }

  .post-sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 70px;
    flex-shrink: 0;
  }

  .user-avatar {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--text-inverse);
    font-weight: 800;
    font-size: 1.25rem;
    border-radius: 50%;
    border: 3px solid var(--border);
  }

  .user-avatar.secondary {
    background: var(--color-secondary);
  }

  .user-name {
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
    color: var(--text);
  }

  .user-badge {
    font-size: 0.6rem;
    padding: 0.15rem 0.4rem;
    background: var(--color-accent);
    border-radius: 4px;
    font-weight: 600;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-header {
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-time {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
  }

  .post-body p {
    margin: 0;
  }

  .post-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: transparent;
    border: 2px solid var(--border);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .action-btn:hover {
    background: var(--color-primary);
    color: var(--text-inverse);
    border-color: var(--color-primary);
  }

  .action-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* Replies Section */
  .replies-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .replies-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  /* Reply Form */
  .reply-form {
    padding: 1.5rem;
    background: var(--surface);
    border: 3px solid var(--color-secondary);
    border-radius: 4px;
  }

  .reply-form-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .reply-textarea {
    width: 100%;
    padding: 1rem;
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.6;
    resize: vertical;
    min-height: 120px;
  }

  .reply-textarea:focus {
    outline: none;
    border-color: var(--focus);
  }

  .reply-form-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 1rem;
  }

  .submit-btn {
    padding: 0.75rem 1.5rem;
    background: var(--color-primary);
    border: 3px solid var(--border);
    border-radius: 4px;
    font-weight: 700;
    color: var(--text-inverse);
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 3px 3px 0 var(--shadow-hard);
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 5px 5px 0 var(--shadow-hard);
  }

  .submit-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .reply-form-disabled {
    padding: 1.5rem;
    background: var(--surface);
    border: 2px dashed var(--border);
    border-radius: 4px;
    text-align: center;
  }

  .reply-form-disabled p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Thread Sidebar */
  .thread-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 2rem;
  }

  .sidebar-card {
    padding: 1rem;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 4px;
  }

  .sidebar-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
    margin: 0 0 0.75rem;
  }

  .thread-info-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
  }

  .info-item dt {
    color: var(--text-muted);
    font-weight: 500;
  }

  .info-item dd {
    margin: 0;
    font-weight: 600;
    color: var(--text);
  }

  .info-link {
    color: var(--color-secondary);
    text-decoration: none;
  }

  .info-link:hover {
    text-decoration: underline;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--text-inverse);
