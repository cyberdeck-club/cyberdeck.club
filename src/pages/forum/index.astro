---
/**
 * Forum Index Page
 * Landing page showing all forum categories
 */

import ForumLayout from "@/layouts/ForumLayout.astro";
import { getForumCategories } from "@/lib/forum";

export const prerender = false;

const db = Astro.locals.db!;
const categoriesResult = await getForumCategories(db);
const categories = categoriesResult.map((cat) => ({
  slug: cat.slug,
  name: cat.name,
  description: cat.description ?? "",
  threadCount: 0,
  latestThread: "No threads yet",
  isHighlighted: cat.slug === "introductions",
}));
---

<ForumLayout 
  title="Forum" 
  description="Join the conversation with fellow cyberdeck builders"
>
  <div class="forum-landing">
    <!-- Hero Section -->
    <header class="forum-hero">
      <h1 class="forum-title">Forum ✨</h1>
      <p class="forum-subtitle">Join the conversation</p>
    </header>

    <!-- Categories Grid -->
    <section class="categories-section">
      <div class="categories-grid">
        {categories.map((category) => (
          <a 
            href={`/forum/${category.slug}`}
            class:list={["category-card", { highlighted: category.isHighlighted }]}
          >
            {category.isHighlighted && (
              <span class="highlight-badge">👋 Introduce yourself!</span>
            )}
            <div class="category-header">
              <h2 class="category-name">{category.name}</h2>
              <span class="thread-count">{category.threadCount} threads</span>
            </div>
            <p class="category-description">{category.description}</p>
            <div class="category-latest">
              <span class="latest-label">Latest:</span>
              <span class="latest-thread">{category.latestThread}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Community CTA -->
    <section class="community-cta">
      <div class="cta-content">
        <h2 class="cta-title">Ready to dive in?</h2>
        <p class="cta-text">
          Join thousands of cyberdeck builders sharing builds, helping each other, and pushing the limits of portable computing.
        </p>
        <a href="/forum/introductions" class="cta-button">
          Introduce Yourself →
        </a>
      </div>
    </section>
  </div>
</ForumLayout>

<style>
  .forum-landing {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Hero Section */
  .forum-hero {
    text-align: center;
    padding: 3rem 0;
  }

  .forum-title {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 0.5rem;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .forum-subtitle {
    font-size: 1.25rem;
    color: var(--color-secondary);
    margin: 0;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Categories Section */
  .categories-section {
    width: 100%;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s ease;
    box-shadow: 6px 6px 0 var(--color-primary);
  }

  .category-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: none;
    border-color: var(--color-secondary);
  }

  .category-card.highlighted {
    background: var(--color-pop-mint);
    border-color: var(--color-secondary);
    box-shadow: 8px 8px 0 var(--color-secondary);
  }

  .highlight-badge {
    position: absolute;
    top: -14px;
    right: 1rem;
    padding: 0.4rem 0.85rem;
    background: var(--color-secondary);
    color: white;
    font-size: 0.7rem;
    font-weight: 800;
    border-radius: 8px;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
  }

  .category-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .category-name {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .thread-count {
    flex-shrink: 0;
    padding: 0.3rem 0.7rem;
    background: var(--color-secondary);
    color: white;
    font-size: 0.65rem;
    font-weight: 800;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--text);
  }

  .category-description {
    font-size: 0.9rem;
    color: var(--text);
    margin: 0;
    line-height: 1.5;
    font-weight: 500;
  }

  .category-latest {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 1rem;
    border-top: 3px solid var(--color-primary);
    margin-top: auto;
  }

  .latest-label {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
  }

  .latest-thread {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Community CTA */
  .community-cta {
    padding: 4rem 3rem;
    background: var(--color-secondary);
    border: 4px solid var(--text);
    border-radius: 16px;
    text-align: center;
    box-shadow: 10px 10px 0 var(--color-primary);
  }

  .cta-content {
    max-width: 500px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: 2rem;
    font-weight: 800;
    color: white;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .cta-text {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 0 2rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: white;
    color: var(--color-secondary);
    font-weight: 800;
    font-size: 1rem;
    text-decoration: none;
    border: 4px solid var(--text);
    border-radius: 10px;
    transition: all 0.2s ease;
    box-shadow: 5px 5px 0 var(--text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 8px 8px 0 var(--text);
    background: var(--color-pop-mint);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .forum-title {
      font-size: 2.25rem;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }

    .category-card {
      padding: 1.5rem;
    }

    .community-cta {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
