---
/**
 * Forum Index Page
 * Landing page showing all forum categories
 */

import ForumLayout from "@/layouts/ForumLayout.astro";
import { getForumCategories } from "@/lib/forum";
import { requireRole, ROLES } from "@/lib/roles";

export const prerender = false;

const db = Astro.locals.db!;
const user = Astro.locals.user;
const categoriesResult = await getForumCategories(db);
const categories = categoriesResult.map((cat) => ({
  slug: cat.slug,
  name: cat.name,
  description: cat.description ?? "",
  threadCount: 0,
  latestThread: "No threads yet",
  isHighlighted: cat.slug === "introductions",
}));

// Permission checks
const canCreateThread = requireRole(user?.role, ROLES.MAKER);
const isLoggedIn = !!user;

---

<ForumLayout 
  title="Forum" 
  description="Join the conversation with fellow cyberdeck builders"
>
  <div class="forum-landing">
    <!-- Hero Section -->
    <header class="forum-hero">
      <div class="hero-content">
        <h1 class="forum-title">Forum ✨</h1>
        <p class="forum-subtitle">Join the conversation</p>
      </div>
      {canCreateThread ? (
        <a href="/forum/new" class="new-thread-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Start a Thread
        </a>
      ) : isLoggedIn ? (
        <p class="thread-cta-message">
          Want to start a thread? Share a build first — after your first build is published, you'll be able to create threads.
        </p>
      ) : null}
    </header>

    <!-- Categories Grid -->
    <section class="categories-section">
      <div class="categories-grid">
        {categories.map((category) => (
          <a 
            href={`/forum/${category.slug}`}
            class:list={["category-card", { highlighted: category.isHighlighted }]}
          >
            {category.isHighlighted && (
              <span class="highlight-badge">👋 Introduce yourself!</span>
            )}
            <div class="category-header">
              <h2 class="category-name">{category.name}</h2>
              <span class="thread-count">{category.threadCount} threads</span>
            </div>
            <p class="category-description">{category.description}</p>
            <div class="category-latest">
              <span class="latest-label">Latest:</span>
              <span class="latest-thread">{category.latestThread}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Community CTA -->
    <section class="community-cta">
      <div class="cta-content">
        <h2 class="cta-title">Ready to dive in?</h2>
        <p class="cta-text">
          Join cyberdeck builders sharing builds, helping each other, and exploring what's possible with portable computing.
        </p>
        <a href="/forum/introductions" class="cta-button">
          Introduce Yourself →
        </a>
      </div>
    </section>
  </div>
</ForumLayout>

<style>
  .forum-landing {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Hero Section */
  .forum-hero {
    text-align: center;
    padding: 3rem 0;
  }

  .thread-cta-message {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: italic;
    max-width: 400px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .forum-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--text);
    margin: 0 0 0.5rem;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .forum-subtitle {
    font-size: 1.25rem;
    color: var(--color-secondary);
    margin: 0;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Categories Section */
  .categories-section {
    width: 100%;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s ease;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .category-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: none;
    border-color: var(--color-secondary);
  }

  .category-card.highlighted {
    background: var(--color-accent);
    border-color: var(--border);
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .highlight-badge {
    position: absolute;
    top: -14px;
    right: 1rem;
    padding: 0.4rem 0.85rem;
    background: var(--color-secondary);
    color: var(--text-inverse);
    font-size: 0.7rem;
    font-weight: 800;
    border-radius: 4px;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
  }

  .category-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .category-name {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .thread-count {
    flex-shrink: 0;
    padding: 0.3rem 0.7rem;
    background: var(--color-secondary);
    color: var(--text-inverse);
    font-size: 0.65rem;
    font-weight: 800;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--text);
  }

  .category-description {
    font-size: 0.9rem;
    color: var(--text);
    margin: 0;
    line-height: 1.5;
    font-weight: 500;
  }

  .category-latest {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 1rem;
    border-top: 3px solid var(--color-primary);
    margin-top: auto;
  }

  .latest-label {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
  }

  .latest-thread {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Community CTA */
  .community-cta {
    padding: 4rem 3rem;
    background: var(--color-secondary);
    border: 4px solid var(--text);
    border-radius: 4px;
    text-align: center;
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .cta-content {
    max-width: 500px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    color: var(--text-inverse);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .cta-text {
    font-size: 1.05rem;
    color: var(--text-inverse);
    margin: 0 0 2rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: var(--surface);
    color: var(--text);
    font-weight: 800;
    font-size: 1rem;
    text-decoration: none;
    border: 3px solid var(--border);
    border-radius: 4px;
    transition: all 0.2s ease;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0 var(--shadow-hard);
    background: var(--color-accent);
  }

  .cta-button:focus-visible {
    outline: none;
    ring: 2px solid var(--focus);
    ring-offset: 2px;
  }

  /* New Thread Button */
  .new-thread-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--color-primary);
    color: var(--text-inverse);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    border: 3px solid var(--border);
    border-radius: 4px;
    transition: all 0.2s ease;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    white-space: nowrap;
  }

  .new-thread-btn:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0 var(--shadow-hard);
    background: var(--color-secondary);
  }

  .new-thread-btn:focus-visible {
    outline: none;
    ring: 2px solid var(--focus);
    ring-offset: 2px;
  }

  .login-link {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    background: var(--color-secondary);
    color: var(--text-inverse);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.2s ease;
  }

  .login-link:hover {
    background: var(--color-primary);
  }

  .login-link:focus-visible {
    outline: none;
    ring: 2px solid var(--focus);
    ring-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .forum-title {
      font-size: 2.25rem;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }

    .category-card {
      padding: 1.5rem;
    }

    .community-cta {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
