---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import WikiArticleCard from "@/components/WikiArticleCard.astro";
import ForumThreadPreview from "@/components/ForumThreadPreview.astro";
import MeetupCard from "@/components/MeetupCard.astro";
import BuildCard from "@/components/BuildCard.astro";
import { MarkdownRenderer } from '@/utils/MarkdownRenderer';

// Placeholder data until Phase 5 seed data is loaded
const homepageHeroTitle = "Build the future.\nFor you.\nBy you.";
const homepageHeroSubtitle = "💅 the girls, gays, and theys are coming together: designing and creating cyberdecks that represent who they are, regardless of skill level — from first-timers to seasoned modders.";
const homepageGetStartedBtn = "Get Started";
const homepageJoinForumBtn = "Join the Forum";

const homepageWhatIsCyberdeckTitle = "What is a Cyberdeck?";
const homepageWhatIsCyberdeck = "A cyberdeck is a portable, custom-built computing rig that combines vintage aesthetics with modern technology. Think of it as a laptop you designed yourself — inside and out.";
const homepagePortableLabel = "Portable";
const homepageCustomLabel = "Custom";
const homepageYoursLabel = "Yours";

const homepageFeaturedWikiTitle = "Featured Wiki Articles";
const homepageActiveThreadsTitle = "Active Forum Threads";
const homepageUpcomingMeetupsTitle = "Upcoming Meetups";
const homepageRecentBuildsTitle = "Recent Builds";

const homepageCtaTitle = "Ready to Start Building?";
const homepageCtaText = "Join our community of makers, hackers, and cyberdeck enthusiasts.";
const homepageIntroduceBtn = "Introduce Yourself";
const homepageReadWikiBtn = "Read the Wiki";

// Empty arrays until Phase 5 seed data is loaded
const wikiArticles: Array<{title: string; category: string; excerpt: string; href: string}> = [];
const forumThreads: Array<{title: string; category: string; replyCount: number; lastActivity: string; href: string}> = [];
const meetups: Array<{title: string; date: string; location: string; region: string; status: "upcoming"; attendeeCount: number; href: string}> = [];
const builds: Array<{title: string; builderName: string; imageGradient: string; difficulty: "beginner" | "intermediate" | "advanced"; href: string}> = [];

const communityStats = {
  members: 0,
  builds: 0,
  wikiArticles: 0
};
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="hero">
    <!-- Decorative blobs for neobrutalist punch -->
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="hero-blob hero-blob-3"></div>
    <div class="hero-blob hero-blob-4"></div>
    
    <div class="hero-content">
      <div class="hero-sparkles">
        <span class="sparkle">✦</span>
        <span class="sparkle">✧</span>
        <span class="sparkle">✦</span>
        <span class="sparkle">✧</span>
      </div>
      <h1 class="hero-title"><MarkdownRenderer content={homepageHeroTitle}/></h1>
      <p class="hero-subtitle">
        {homepageHeroSubtitle}
      </p>
      <div class="hero-actions">
        <a href="/wiki/category/getting-started" class="btn btn-primary">
          {homepageGetStartedBtn}
        </a>
        <a href="/forum" class="btn btn-secondary">
          {homepageJoinForumBtn}
        </a>
      </div>
    </div>
  </section>

  <!-- What is a Cyberdeck Section -->
  <section class="what-is-section">
    <div class="container">
      <div class="what-is-content">
        <h2 class="what-is-title">{homepageWhatIsCyberdeckTitle}</h2>
        <p class="what-is-intro">
          {homepageWhatIsCyberdeck}
        </p>
        <div class="what-is-features">
          <div class="feature">
            <span class="feature-icon">💻</span>
            <span class="feature-text">{homepagePortableLabel}</span>
          </div>
          <div class="feature">
            <span class="feature-icon">🔧</span>
            <span class="feature-text">{homepageCustomLabel}</span>
          </div>
          <div class="feature">
            <span class="feature-icon">✨</span>
            <span class="feature-text">{homepageYoursLabel}</span>
          </div>
        </div>
        <a href="/wiki/getting-started" class="what-is-link">
          Start your journey →
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Wiki Articles -->
  <section class="section">
    <div class="container">
      <SectionHeader
        title={homepageFeaturedWikiTitle}
        linkText="View all wiki articles"
        linkHref="/wiki"
      />
      <div class="card-grid card-grid-3">
        {wikiArticles.map((article) => (
          <WikiArticleCard 
            title={article.title}
            category={article.category}
            excerpt={article.excerpt}
            href={article.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Active Forum Threads -->
  <section class="section section-alt">
    <div class="container">
      <SectionHeader
        title={homepageActiveThreadsTitle}
        linkText="Visit the forum"
        linkHref="/forum"
      />
      <div class="card-grid card-grid-2">
        {forumThreads.map((thread) => (
          <ForumThreadPreview 
            title={thread.title}
            category={thread.category}
            replyCount={thread.replyCount}
            lastActivity={thread.lastActivity}
            href={thread.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Upcoming Meetups -->
  <section class="section">
    <div class="container">
      <SectionHeader
        title={homepageUpcomingMeetupsTitle}
        linkText="See all meetups"
        linkHref="/meetups"
      />
      <div class="card-grid card-grid-3">
        {meetups.map((meetup) => (
          <MeetupCard
            title={meetup.title}
            date={meetup.date}
            location={meetup.location}
            region={meetup.region}
            status={meetup.status}
            attendeeCount={meetup.attendeeCount}
            href={meetup.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Builds -->
  <section class="section section-alt">
    <div class="container">
      <SectionHeader
        title={homepageRecentBuildsTitle}
        linkText="Browse all builds"
        linkHref="/builds"
      />
      <div class="card-grid card-grid-3">
        {builds.map((build) => (
          <BuildCard
            title={build.title}
            builderName={build.builderName}
            difficulty={build.difficulty}
            href={build.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Join the Community CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">{homepageCtaTitle}</h2>
        <p class="cta-text">{homepageCtaText}</p>
        <div class="cta-actions">
          <a href="/forum" class="btn btn-secondary">{homepageIntroduceBtn}</a>
          <a href="/wiki" class="btn btn-outline">{homepageReadWikiBtn}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Community Stats -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number">{communityStats.members}</span>
          <span class="stat-label">Members</span>
        </div>
        <div class="stat">
          <span class="stat-number">{communityStats.builds}</span>
          <span class="stat-label">Builds Shared</span>
        </div>
        <div class="stat">
          <span class="stat-number">{communityStats.wikiArticles}</span>
          <span class="stat-label">Wiki Articles</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    overflow: hidden;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-blob-1 {
    width: 400px;
    height: 400px;
    background: var(--color-primary);
    top: -100px;
    left: -100px;
    opacity: 0.15;
  }

  .hero-blob-2 {
    width: 300px;
    height: 300px;
    background: var(--color-secondary);
    bottom: -50px;
    right: -50px;
    opacity: 0.2;
  }

  .hero-blob-3 {
    width: 200px;
    height: 200px;
    background: var(--color-accent);
    top: 50%;
    right: 20%;
    opacity: 0.1;
  }

  .hero-blob-4 {
    width: 150px;
    height: 150px;
    background: var(--color-pop-lemon);
    bottom: 20%;
    left: 10%;
    opacity: 0.15;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }

  .hero-sparkles {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    opacity: 0.6;
  }

  .sparkle {
    display: inline-block;
    animation: sparkle 2s ease-in-out infinite;
  }

  .sparkle:nth-child(2) { animation-delay: 0.3s; }
  .sparkle:nth-child(3) { animation-delay: 0.6s; }
  .sparkle:nth-child(4) { animation-delay: 0.9s; }

  @keyframes sparkle {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-title :global(p) {
    margin: 0;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.6;
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* What is Section */
  .what-is-section {
    padding: 6rem 2rem;
  }

  .what-is-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .what-is-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .what-is-intro {
    font-size: 1.125rem;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 2.5rem;
  }

  .what-is-features {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .feature-icon {
    font-size: 2rem;
  }

  .feature-text {
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .what-is-link {
    display: inline-block;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 2px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .what-is-link:hover {
    opacity: 0.7;
  }

  /* Section Styles */
  .section {
    padding: 5rem 2rem;
  }

  .section-alt {
    background: var(--surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .card-grid {
    display: grid;
    gap: 1.5rem;
  }

  .card-grid-2 {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .card-grid-3 {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 2rem;
    background: var(--color-primary);
    color: white;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-text {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Stats Section */
  .stats-section {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .stat-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0;
    border: 3px solid transparent;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-primary);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
  }

  .btn-outline {
    background: transparent;
    color: white;
    border-color: white;
  }

  .btn-outline:hover {
    background: white;
    color: var(--color-primary);
  }
</style>
