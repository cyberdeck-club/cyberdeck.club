---
export const prerender = false;
// This page handles the signup verification flow after user clicks email link
// It reads the token from URL, validates it, then guides user to create a passkey
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Email - cyberdeck.club</title>
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        font-family: "InterVariable", system-ui, sans-serif;
        background-color: #faf8f5;
        color: #1a1a1a;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        margin: 0;
      }
      @media (prefers-color-scheme: dark) {
        body {
          background-color: #1a0a1a;
          color: #f5f0fa;
        }
      }
      .verify-container {
        background: white;
        border: 3px solid #1a1a1a;
        border-radius: 0;
        box-shadow: 6px 6px 0 #1a1a1a;
        padding: 2.5rem;
        max-width: 420px;
        width: 100%;
      }
      @media (prefers-color-scheme: dark) {
        .verify-container {
          background: #2a1a2a;
          border-color: #f5f0fa;
          box-shadow: 6px 6px 0 #a855f7;
        }
      }
      .verify-header {
        text-align: center;
        margin-bottom: 2rem;
      }
      .verify-title {
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
        text-transform: lowercase;
        letter-spacing: -0.02em;
      }
      .verify-subtitle {
        font-size: 0.95rem;
        opacity: 0.7;
        margin: 0;
      }
      .form-group {
        margin-bottom: 1.25rem;
      }
      .form-label {
        display: block;
        font-weight: 600;
        font-size: 0.875rem;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 2px solid #1a1a1a;
        border-radius: 0;
        background: white;
        color: #1a1a1a;
        transition: box-shadow 0.15s ease;
      }
      .form-input:read-only {
        background: #f5f5f5;
        cursor: not-allowed;
      }
      @media (prefers-color-scheme: dark) {
        .form-input {
          background: #1a0a1a;
          border-color: #a855f7;
          color: #f5f0fa;
        }
        .form-input:read-only {
          background: #2a1a2a;
        }
      }
      .form-input:focus {
        outline: none;
        box-shadow: 3px 3px 0 #a855f7;
      }
      .passkey-btn {
        width: 100%;
        padding: 0.875rem 1.5rem;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: #a855f7;
        color: white;
        border: 2px solid #1a1a1a;
        border-radius: 0;
        cursor: pointer;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        box-shadow: 3px 3px 0 #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }
      .passkey-btn:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0 #1a1a1a;
      }
      .passkey-btn:active {
        transform: translate(2px, 2px);
        box-shadow: 1px 1px 0 #1a1a1a;
      }
      .passkey-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
        box-shadow: 3px 3px 0 #1a1a1a;
      }
      .passkey-btn.loading {
        pointer-events: none;
      }
      .passkey-btn .spinner {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      .error-message {
        background: #fee2e2;
        border: 2px solid #dc2626;
        color: #991b1b;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        display: none;
      }
      @media (prefers-color-scheme: dark) {
        .error-message {
          background: #450a0a;
          border-color: #f87171;
          color: #fecaca;
        }
      }
      .info-box {
        background: #f3e8ff;
        border: 2px solid #a855f7;
        color: #581c87;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
      }
      @media (prefers-color-scheme: dark) {
        .info-box {
          background: #3b0764;
          border-color: #c084fc;
          color: #e9d5ff;
        }
      }
      .info-box strong {
        display: block;
        margin-bottom: 0.25rem;
      }
      .success-box {
        background: #d1fae5;
        border: 2px solid #059669;
        color: #065f46;
        padding: 1.5rem;
        text-align: center;
        display: none;
      }
      @media (prefers-color-scheme: dark) {
        .success-box {
          background: #064e3b;
          border-color: #34d399;
          color: #a7f3d0;
        }
      }
      .success-box strong {
        display: block;
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
      }
      .success-box p {
        margin: 0.5rem 0;
      }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: inherit;
        opacity: 0.7;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .back-link:hover {
        opacity: 1;
      }
      .hidden {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <div class="verify-container">
      <header class="verify-header">
        <h1 class="verify-title">✨ cyberdeck.club</h1>
        <p class="verify-subtitle">Create your account</p>
      </header>

      <!-- Error display -->
      <div id="error-box" class="error-message"></div>

      <!-- Success display -->
      <div id="success-box" class="success-box">
        <strong>🎉 You're all set!</strong>
        <p>Your account has been created and you're now signed in.</p>
        <p><a href="/" style="color: #a855f7; font-weight: 600;">Go to homepage →</a></p>
      </div>

      <!-- Loading state -->
      <div id="loading-box" class="info-box" style="text-align: center;">
        <strong>⏳ Checking your link...</strong>
        <p style="margin: 0.5rem 0 0 0;">Please wait while we verify your email.</p>
      </div>

      <!-- Verification form -->
      <div id="verify-form-container" class="hidden">
        <div id="info-box" class="info-box">
          <strong>📧 Email verified!</strong>
          <span id="email-display"></span>
        </div>

        <form id="verify-form">
          <div class="form-group">
            <label class="form-label" for="name">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="Ada Lovelace"
              required
              autocomplete="name"
            />
          </div>

          <button type="submit" class="passkey-btn" id="submit-btn">
            <span id="btn-text">Create Account</span>
            <span id="btn-spinner" class="spinner hidden"></span>
          </button>
        </form>
      </div>

      <a href="/" class="back-link">← Back to home</a>
    </div>

    <script is:inline>
      (function() {
        // Get token from URL
        const urlParams = new URLSearchParams(window.location.search);
        const token = urlParams.get('token');

        const errorBox = document.getElementById('error-box');
        const successBox = document.getElementById('success-box');
        const loadingBox = document.getElementById('loading-box');
        const formContainer = document.getElementById('verify-form-container');
        const verifyForm = document.getElementById('verify-form');
        const emailDisplay = document.getElementById('email-display');
        const submitBtn = document.getElementById('submit-btn');
        const btnText = document.getElementById('btn-text');
        const btnSpinner = document.getElementById('btn-spinner');

        let verifiedEmail = null;

        function showError(message) {
          errorBox.textContent = message;
          errorBox.style.display = 'block';
          loadingBox.style.display = 'none';
          formContainer.classList.add('hidden');
        }

        function showSuccess() {
          successBox.style.display = 'block';
          loadingBox.style.display = 'none';
          formContainer.classList.add('hidden');
        }

        function showForm(email) {
          verifiedEmail = email;
          emailDisplay.textContent = ' Account for: ' + email;
          loadingBox.style.display = 'none';
          formContainer.classList.remove('hidden');
        }

        function setLoading(loading) {
          submitBtn.disabled = loading;
          btnText.textContent = loading ? 'Creating account...' : 'Create Account';
          btnSpinner.classList.toggle('hidden', !loading);
        }

        // Check for token
        if (!token) {
          showError('Invalid verification link. Please use the link from your email.');
          return;
        }

        // Step 1: Validate token by calling the verify API
        fetch('/_emdash/api/auth/signup/verify?token=' + encodeURIComponent(token))
          .then(function(res) {
            return res.json().then(function(data) {
              return { ok: res.ok, status: res.status, data: data };
            });
          })
          .then(function(result) {
            if (!result.ok) {
              var errorCode = result.data?.error?.code;
              var errorMsg = result.data?.error?.message || 'Verification failed';

              if (result.status === 404 || errorCode === 'INVALID_TOKEN') {
                showError('This verification link is invalid or has already been used.');
              } else if (result.status === 410 || errorCode === 'TOKEN_EXPIRED') {
                showError('This verification link has expired. Please sign up again.');
              } else if (result.status === 409 || errorCode === 'USER_EXISTS') {
                showError('An account with this email already exists. Try signing in instead.');
              } else if (result.status === 403 || errorCode === 'DOMAIN_NOT_ALLOWED') {
                showError('Your email domain is not allowed for self-signup. Please contact an administrator.');
              } else {
                showError(errorMsg);
              }
              return;
            }

            // Token is valid - show the form
            var email = result.data?.data?.email;
            if (!email) {
              showError('Invalid response from server. Please try again.');
              return;
            }

            showForm(email);
          })
          .catch(function(err) {
            console.error('Verification error:', err);
            showError('An unexpected error occurred. Please try again.');
          });

        // Step 2: Handle form submission - simplified (no passkey)
        verifyForm.addEventListener('submit', function(e) {
          e.preventDefault();

          var name = document.getElementById('name').value.trim();
          if (!name) {
            errorBox.textContent = 'Please enter your name';
            errorBox.style.display = 'block';
            return;
          }

          errorBox.style.display = 'none';
          setLoading(true);

          // Complete signup - no passkey required
          fetch('/api/auth/signup/complete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              token: token,
              name: name
            })
          })
          .then(function(res) {
            return res.json().then(function(data) {
              return { ok: res.ok, status: res.status, data: data };
            });
          })
          .then(function(result) {
            if (!result.ok) {
              console.error('Signup failed:', result.status, result.data);
              var errorMsg = result.data?.error?.message || 'Failed to complete signup';
              throw new Error(errorMsg);
            }

            // Success! Redirect to home page
            showSuccess();
          })
          .catch(function(err) {
            console.error('Signup error:', err);
            setLoading(false);
            errorBox.textContent = err.message || 'Failed to create account. Please try again.';
            errorBox.style.display = 'block';
          });
        });

        // Helper function to convert registration options from API format to WebAuthn format
        function convertToPublicKeyCredentialsCreateOptions(options) {
          // Decode base64url strings to ArrayBuffer
          function base64urlToBuffer(str) {
            // Replace URL-safe characters
            var base64 = str.replace(/-/g, '+').replace(/_/g, '/');
            // Pad with = to make it valid base64
            var pad = base64.length % 4;
            if (pad) {
              base64 += new Array(5 - pad).join('=');
            }
            var binary = atob(base64);
            var bytes = new Uint8Array(binary.length);
            for (var i = 0; i < binary.length; i++) {
              bytes[i] = binary.charCodeAt(i);
            }
            return bytes.buffer;
          }

          var pubKeyCredParams = [];
          for (var i = 0; i < options.pubKeyCredParams.length; i++) {
            pubKeyCredParams.push({
              type: options.pubKeyCredParams[i].type,
              alg: options.pubKeyCredParams[i].alg
            });
          }

          var excludeCredentials = [];
          if (options.excludeCredentials) {
            for (var j = 0; j < options.excludeCredentials.length; j++) {
              excludeCredentials.push({
                type: options.excludeCredentials[j].type,
                id: base64urlToBuffer(options.excludeCredentials[j].id),
                transports: options.excludeCredentials[j].transports
              });
            }
          }

          var createOptions = {
            challenge: base64urlToBuffer(options.challenge),
            rp: {
              name: options.rp.name,
              id: options.rp.id
            },
            user: {
              id: base64urlToBuffer(options.user.id),
              name: options.user.name,
              displayName: options.user.displayName
            },
            pubKeyCredParams: pubKeyCredParams
          };

          if (options.timeout) {
            createOptions.timeout = options.timeout;
          }

          if (options.attestation) {
            createOptions.attestation = options.attestation;
          }

          if (options.authenticatorSelection) {
            createOptions.authenticatorSelection = {};
            if (options.authenticatorSelection.authenticatorAttachment) {
              createOptions.authenticatorSelection.authenticatorAttachment =
                options.authenticatorSelection.authenticatorAttachment;
            }
            if (options.authenticatorSelection.residentKey) {
              createOptions.authenticatorSelection.residentKey = options.authenticatorSelection.residentKey;
            }
            if (options.authenticatorSelection.requireResidentKey !== undefined) {
              createOptions.authenticatorSelection.requireResidentKey =
                options.authenticatorSelection.requireResidentKey;
            }
            if (options.authenticatorSelection.userVerification) {
              createOptions.authenticatorSelection.userVerification =
                options.authenticatorSelection.userVerification;
            }
          }

          if (excludeCredentials.length > 0) {
            createOptions.excludeCredentials = excludeCredentials;
          }

          return createOptions;
        }

        // Helper function to convert PublicKeyCredential to plain object
        function publicKeyCredentialToObject(credential) {
          var response = credential.response;

          var obj = {
            id: credential.id,
            rawId: arrayBufferToBase64url(credential.rawBuffer),
            type: credential.type,
            response: {
              clientDataJSON: arrayBufferToBase64url(response.clientDataJSON)
            }
          };

          if (response.attestationObject) {
            obj.response.attestationObject = arrayBufferToBase64url(response.attestationObject);
          }

          if (response.transports) {
            obj.response.transports = response.transports;
          }

          if (credential.authenticatorAttachment) {
            obj.authenticatorAttachment = credential.authenticatorAttachment;
          }

          return obj;
        }

        function arrayBufferToBase64url(buffer) {
          var bytes = new Uint8Array(buffer);
          var binary = '';
          for (var i = 0; i < bytes.length; i++) {
            binary += String.fromCharCode(bytes[i]);
          }
          return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
        }
      })();
    </script>
  </body>
</html>