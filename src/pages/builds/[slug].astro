<script>
  import { createElement as h, createRoot } from "react-dom/client";
  import { CommentForm } from "@/components/builds/CommentForm";

  // Mount comment form if container exists
  const commentFormContainer = document.getElementById("comment-form-container");
  if (commentFormContainer) {
    const slug = commentFormContainer.dataset.slug ?? "";
    const guidelinesAccepted = true; // Already checked server-side
    
    const root = createRoot(commentFormContainer);
    root.render(
      h(CommentForm, {
        buildSlug: slug,
        guidelinesAccepted: guidelinesAccepted,
      })
    );
  }

  // Handle reply buttons
  document.querySelectorAll(".reply-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const parentId = target.dataset.parentId;
      if (!parentId) return;

      const container = document.getElementById("comment-form-container");
      if (!container) return;

      // Clear existing form and mount new one with parentId
      const root = createRoot(container);
      root.render(
        h(CommentForm, {
          buildSlug: container.dataset.slug ?? "",
          guidelinesAccepted: true,
          parentId: parentId,
        })
      );

      // Scroll to form
      container.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });
</script>

<script>
  // Delete build handler
  document.addEventListener('DOMContentLoaded', () => {
    const deleteBtn = document.querySelector('.delete-build-btn') as HTMLButtonElement | null;
    if (!deleteBtn) return;

    deleteBtn.addEventListener('click', async () => {
      const buildSlug = deleteBtn.dataset.buildSlug;
      if (!buildSlug) return;

      if (!confirm('Are you sure you want to delete this build? This action cannot be easily undone.')) {
        return;
      }

      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/builds/${buildSlug}`, { method: 'DELETE' });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to delete build');
        }
        window.location.href = '/builds';
      } catch (err) {
        alert(err instanceof Error ? err.message : 'Failed to delete build');
        deleteBtn.disabled = false;
        deleteBtn.textContent = 'Delete Build';
      }
    });
  });
</script>
