---
import BuildLayout from "@/layouts/BuildLayout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BuildCard from "@/components/BuildCard.astro";
import ReportButton from "@/components/reports/ReportButton";
import SubscribeButton from "@/components/subscriptions/SubscribeButton";
import { getBuild, getBuildForReview, getBuilds, parseBuildJsonFields } from "@/lib/builds";
import { getBlockedUserIds } from "@/lib/blocking";
import { eq, isNull, and, notInArray } from "drizzle-orm";
import * as schema from "../../db/schema";
import { hasAcceptedGuidelines } from "@/lib/guidelines";
import { renderMarkdownToHtml } from "@/utils/MarkdownRenderer";
import { getLatestEdit } from "@/lib/edit-history";
import { requireRole, ROLES, getRoleLevel } from "@/lib/roles";
import { isSubscribed } from "@/lib/notifications";

// Import new section components
import BuildMetaBar from "@/components/builds/BuildMetaBar.astro";
import WiringSection from "@/components/builds/WiringSection.astro";
import CodebaseSection from "@/components/builds/CodebaseSection.astro";
import Models3DSection from "@/components/builds/Models3DSection.astro";
import PhotoGallery from "@/components/builds/PhotoGallery.astro";
import VideoSection from "@/components/builds/VideoSection.astro";
import TikTokEmbed from "@/components/builds/TikTokEmbed.astro";
import BOMTable from "@/components/builds/BOMTable.astro";
import CircuitBoardSection from "@/components/builds/CircuitBoardSection.astro";
import InspirationsSection from "@/components/builds/InspirationsSection.astro";

// Server-rendered page
export const prerender = false;

// Get slug from URL params
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/builds");
}

// Fetch build from database
const db = Astro.locals.db!;
const user = Astro.locals.user;
let buildResult = await getBuild(db, slug);

// If published build not found, try privileged access for mods/admins/authors
let isReviewMode = false;
if (!buildResult || buildResult.length === 0) {
  // Check if user is a moderator/admin (or we'll check author match after fetch)
  const isModerator = requireRole(user?.role, ROLES.TRUSTED_MAKER);
  if (user && isModerator) {
    buildResult = await getBuildForReview(db, slug);
    if (buildResult && buildResult.length > 0) {
      isReviewMode = true;
    }
  } else if (user) {
    // Non-mod user — still check if they're the author
    buildResult = await getBuildForReview(db, slug);
    if (buildResult && buildResult.length > 0) {
      if (buildResult[0].build.authorId === user.id) {
        isReviewMode = true;
      } else {
        // Not the author and not a mod — treat as not found
        buildResult = [];
      }
    }
  }
}

// Build not found - redirect to builds list
const notFound = !buildResult || buildResult.length === 0;

if (notFound) {
  return Astro.redirect("/builds");
}

const result = buildResult[0];
const build = result.build;
const authorName = result.authorName;
const authorId = build.authorId;

// Determine the review banner status label
const buildStatusLabel: Record<string, { label: string; tone: string }> = {
  pending_human: { label: "Pending Review", tone: "warning" },
  pending_auto: { label: "Pending Auto-Review", tone: "warning" },
  rejected: { label: "Rejected", tone: "danger" },
  rejected_auto: { label: "Auto-Rejected", tone: "danger" },
  draft: { label: "Draft", tone: "info" },
};
const reviewStatus = isReviewMode
  ? (buildStatusLabel[build.status] ?? { label: build.status, tone: "info" })
  : null;

// Check if current user can perform mod actions on this build
const canModerate = isReviewMode && user && requireRole(user.role, ROLES.TRUSTED_MAKER) && build.status === "pending_human";

// Get blocked user IDs for content filtering
const blockedUserIds = user ? await getBlockedUserIds(db, user.id) : [];
const isBuildAuthorBlocked = typeof build.authorId === "string" && blockedUserIds.includes(build.authorId);

// Parse JSON fields to get typed data
const parsedBuild = parseBuildJsonFields(build);

// Fetch latest edit info for this build
let latestEditInfo: { editorName: string; editedAt: number } | null = null;
try {
  const latestEdit = await getLatestEdit(db, "build", build.id);
  if (latestEdit) {
    const [editor] = await db
      .select({ name: schema.user.name })
      .from(schema.user)
      .where(eq(schema.user.id, latestEdit.editorId))
      .limit(1);
    if (editor) {
      latestEditInfo = {
        editorName: editor.name,
        editedAt: latestEdit.editedAt,
      };
    }
  }
} catch (err) {
  console.error("Failed to fetch edit history:", err);
}

// Transform build data for the template
interface BuildData {
  title: string;
  builderName: string;
  builderId?: string | null;
  difficulty: "beginner" | "intermediate" | "advanced";
  computePlatform: string;
  estimatedCost: number;
  buildTime: string;
  featuredImage?: { url: string; alt: string };
  gallery: { url: string; alt: string }[];
  description: string;
  content: string;
  partsList: { name: string; link?: string; price?: number; notes?: string }[];
  tags: string[];
  linkedBuildLog?: string;
  linkedWikiArticles?: string[];
}

const buildData: BuildData = {
  title: build.title,
  builderName: authorName,
  builderId: authorId,
  difficulty: (parsedBuild.difficulty as "beginner" | "intermediate" | "advanced") || "intermediate",
  computePlatform: parsedBuild.computePlatform || "Raspberry Pi",
  estimatedCost: parsedBuild.estimatedCost ?? 0,
  buildTime: parsedBuild.buildTime || "Varies",
  featuredImage: build.heroImageUrl ? { url: build.heroImageUrl, alt: build.title } : undefined,
  gallery: parsedBuild.photos?.buildStepImages?.map((url, i) => ({ url, alt: `Build step ${i + 1}` })) || [],
  description: build.description || "",
  content: build.content || "",
  partsList: parsedBuild.billOfMaterials?.items?.map(item => ({
    name: item.item,
    link: item.link,
    price: item.estimatedCost,
    notes: item.notes
  })) || [],
  tags: parsedBuild.tags || [],
  linkedBuildLog: undefined as string | undefined,
  linkedWikiArticles: undefined as string[] | undefined
};

// Fetch related builds (same difficulty)
const allBuildsResult = await getBuilds(db, { limit: 20 });
const relatedBuilds = allBuildsResult
  .filter(({ build: b }) => b.slug !== slug)
  .slice(0, 2)
  .map(({ build: b, authorName: name }) => ({
    slug: b.slug,
    title: b.title,
    builderName: name,
    builderId: b.authorId,
    difficulty: "intermediate" as const,
    computePlatform: "Raspberry Pi",
    estimatedCost: 0,
    featuredImage: b.heroImageUrl ? { url: b.heroImageUrl, alt: b.title } : undefined
  }));

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(amount);
};

// Build comment query conditions (filtered by blocked users)
const commentConditions = [
  eq(schema.buildComments.buildId, build.id),
  isNull(schema.buildComments.deletedAt),
];
if (blockedUserIds.length > 0) {
  commentConditions.push(notInArray(schema.buildComments.authorId, blockedUserIds));
}

// Fetch build comments
const commentsResult = await db
  .select({
    id: schema.buildComments.id,
    content: schema.buildComments.content,
    parentId: schema.buildComments.parentId,
    createdAt: schema.buildComments.createdAt,
    updatedAt: schema.buildComments.updatedAt,
    authorId: schema.buildComments.authorId,
    authorName: schema.user.name,
  })
  .from(schema.buildComments)
  .innerJoin(schema.user, eq(schema.buildComments.authorId, schema.user.id))
  .where(and(...commentConditions))
  .orderBy(schema.buildComments.createdAt);

const comments = commentsResult.map(c => ({
  ...c,
  contentHtml: renderMarkdownToHtml(c.content),
}));

// Get guidelines status (user already fetched above for blocking)
let guidelinesAccepted = false;
let isAuthorOrModerator = false;

if (user) {
  guidelinesAccepted = await hasAcceptedGuidelines(db, user.id);
  isAuthorOrModerator = build.authorId === user.id || requireRole(user.role, ROLES.MODERATOR);
}

// Check subscription status for current user
let isUserSubscribed = false;
if (user && db) {
  isUserSubscribed = await isSubscribed(db as any, user.id, "build", build.id);
}
---

{isBuildAuthorBlocked ? (
<BaseLayout title="Build Unavailable" description="This build is from a user you've blocked.">
  <section class="blocked-build-page">
    <div class="blocked-build-content">
      <h1 class="blocked-build-title">Build Unavailable</h1>
      <p class="blocked-build-text">This build is from a user you've blocked. Their content is hidden.</p>
      <a href="/builds" class="blocked-build-link">← Back to Builds</a>
    </div>
  </section>
</BaseLayout>
) : (
<BuildLayout
  title={buildData.title}
  description={`${buildData.title} by ${buildData.builderName} - ${buildData.computePlatform} cyberdeck build`}
  featuredImage={buildData.featuredImage}
  builderName={buildData.builderName}
  builderId={buildData.builderId}
  difficulty={buildData.difficulty}
  computePlatform={buildData.computePlatform}
  estimatedCost={buildData.estimatedCost}
  buildTime={buildData.buildTime}
  tags={buildData.tags}
>
  <!-- Review Mode Banner — shown when viewing a non-published build -->
  {reviewStatus && (
    <div class={`review-banner review-banner--${reviewStatus.tone}`} role="alert">
      <div class="review-banner-content">
        <svg class="review-banner-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <span class="review-banner-text">
          <strong>Status: {reviewStatus.label}</strong> — This build is not yet visible to the public.
        </span>
        <a href="/admin/builds" class="review-banner-link">← Back to Mod Queue</a>
      </div>
      {canModerate && (
        <div class="review-banner-actions" data-build-slug={build.slug}>
          <button class="review-approve-btn" data-action="approve">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            Approve
          </button>
          <button class="review-reject-btn" data-action="reject">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
            Needs Revision
          </button>
        </div>
      )}
    </div>
  )}

  <!-- Reject Feedback Form (hidden by default, shown when "Needs Revision" is clicked) -->
  {canModerate && (
    <div class="review-reject-form hidden" id="review-reject-form">
      <label class="review-reject-label">
        <span>Feedback for the builder (required — be kind and specific):</span>
        <textarea
          class="review-reject-textarea"
          id="review-reject-reason"
          placeholder="What could be improved? Be encouraging and specific..."
          rows="3"
        ></textarea>
      </label>
      <div class="review-reject-form-actions">
        <button class="review-cancel-btn" id="review-cancel-reject">Cancel</button>
        <button class="review-submit-reject-btn" id="review-submit-reject" disabled>Send Feedback</button>
      </div>
    </div>
  )}

  <!-- Build Meta Bar -->
  <BuildMetaBar
    difficulty={parsedBuild.difficulty}
    computePlatform={parsedBuild.computePlatform}
    estimatedCost={parsedBuild.estimatedCost}
    buildTime={parsedBuild.buildTime}
  />

  <!-- New Section Components - conditionally rendered -->
  <WiringSection wiring={parsedBuild.wiring} />
  <CodebaseSection codebase={parsedBuild.codebase} />
  <Models3DSection models3d={parsedBuild.models3d} />
  <PhotoGallery photos={parsedBuild.photos} />
  <VideoSection videos={parsedBuild.videos} />
  <TikTokEmbed tiktokLinks={parsedBuild.tiktokLinks} />
  <BOMTable billOfMaterials={parsedBuild.billOfMaterials?.items} />
  <CircuitBoardSection circuitBoards={parsedBuild.circuitBoards} />
  <InspirationsSection inspirations={parsedBuild.inspirations} />

  <!-- Description Section -->
  <section class="build-section">
    <h2 class="section-title">About This Build</h2>
    <div class="description-content">
      <Fragment set:html={renderMarkdownToHtml(buildData.description || buildData.content || "")}/>
    </div>
    {latestEditInfo && (
      <p class="text-xs text-[var(--text-muted)] mt-4">
        Last edited by {latestEditInfo.editorName} on {new Date(latestEditInfo.editedAt * 1000).toLocaleDateString()}
      </p>
    )}
  </section>
  <!-- Description Section -->
  <section class="build-section">
    <h2 class="section-title">About This Build</h2>
    <div class="description-content">
      <Fragment set:html={renderMarkdownToHtml(buildData.description || buildData.content || "")}/>
    </div>
    {latestEditInfo && (
      <p class="text-xs text-[var(--text-muted)] mt-4">
        Last edited by {latestEditInfo.editorName} on {new Date(latestEditInfo.editedAt * 1000).toLocaleDateString()}
      </p>
    )}
  </section>

  <!-- Parts List Section - Show message if no parts list in schema -->
  {buildData.partsList.length === 0 && (
    <section class="build-section">
      <h2 class="section-title">Parts List</h2>
      <p class="parts-placeholder">Parts list not available for this build yet.</p>
    </section>
  )}

  <!-- Image Gallery Section -->
  {buildData.gallery.length > 0 && (
    <section class="build-section">
      <h2 class="section-title">Gallery</h2>
      <div class="gallery-grid">
        {buildData.gallery.map((image, index) => (
          <button
            class="gallery-item"
            data-gallery-index={index}
            aria-label={`View ${image.alt}`}
          >
            <img
              src={image.url}
              alt={image.alt}
              loading="lazy"
            />
          </button>
        ))}
      </div>
    </section>
  )}

  <!-- Linked Build Log -->
  {buildData.linkedBuildLog && (
    <section class="build-section">
      <h2 class="section-title">Build Log</h2>
      <a href={buildData.linkedBuildLog} class="build-log-link" target="_blank" rel="noopener">
        <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
        </svg>
        View Build Log on the Forum
        <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </section>
  )}

  <!-- Linked Wiki Articles -->
  {buildData.linkedWikiArticles && buildData.linkedWikiArticles.length > 0 && (
    <section class="build-section">
      <h2 class="section-title">Related Wiki Articles</h2>
      <ul class="wiki-links">
        {buildData.linkedWikiArticles.map((article: string) => (
          <li>
            <a href={`/wiki/${article}`} class="wiki-link">
              <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
              </svg>
              {article.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Related Builds Section -->
  {relatedBuilds.length > 0 && (
    <section class="build-section related-section">
      <h2 class="section-title">Related Builds</h2>
      <div class="related-grid">
        {relatedBuilds.slice(0, 2).map(related => (
          <BuildCard
            title={related.title}
            builderName={related.builderName}
            builderId={related.builderId}
            featuredImage={related.featuredImage}
            difficulty={related.difficulty}
            computePlatform={related.computePlatform}
            estimatedCost={related.estimatedCost}
            href={`/builds/${related.slug}`}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Sidebar slot content -->
  <!-- <div slot="sidebar">
    <div class="sidebar-section">
      <h3 class="sidebar-title">Quick Stats</h3>
      <dl class="stats-list">
        <dt>Platform</dt>
        <dd>{buildData.computePlatform}</dd>
        <dt>Est. Cost</dt>
        <dd>{formatCurrency(buildData.estimatedCost)}</dd>
        <dt>Build Time</dt>
        <dd>{buildData.buildTime}</dd>
        <dt>Difficulty</dt>
        <dd>
          <span
            class="difficulty-inline"
            style={`background: ${buildData.difficulty === 'beginner' ? 'var(--color-secondary)' : buildData.difficulty === 'intermediate' ? 'var(--color-accent)' : 'var(--color-primary)'}; color: ${buildData.difficulty === 'advanced' ? 'var(--text-inverse)' : 'var(--text)'}`}
          >
            {buildData.difficulty.charAt(0).toUpperCase() + buildData.difficulty.slice(1)}
          </span>
        </dd>
      </dl>
    </div>
  </div> -->

  <!-- Comments Section -->
  <section class="build-section comments-section">
    <h2 class="section-title">Comments ({comments.length})</h2>
    
    {comments.length === 0 ? (
      <p class="no-comments">No comments yet. Be the first to share your thoughts!</p>
    ) : (
      <div class="comments-list">
        {comments.map(comment => (
          <div class="comment" data-comment-id={comment.id}>
            <div class="comment-header">
              <a href={`/user/${comment.authorId}`} class="author-link">{comment.authorName}</a>
              <span class="comment-time">
                {new Date(comment.createdAt * 1000).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                })}
              </span>
            </div>
            <div class="comment-content" set:html={comment.contentHtml}></div>
            {user && (
              <button class="reply-btn" data-parent-id={comment.id}>
                Reply
              </button>
            )}
          </div>
        ))}
      </div>
    )}

    {user && guidelinesAccepted ? (
      <div id="comment-form-container" class="comment-form-wrapper" data-slug={slug}></div>
    ) : user && !guidelinesAccepted ? (
      <div class="guidelines-prompt">
        <p>You need to accept the community guidelines before commenting.</p>
        <a href="/guidelines" class="btn-primary">Accept Guidelines</a>
      </div>
    ) : (
      <div class="login-prompt">
        <p>Want to join the conversation?</p>
        <a href="/login" class="btn-primary">Sign in to Comment</a>
      </div>
    )}
  </section>

  <!-- Subscribe & Report Buttons -->
  <div class="build-actions-row" style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 1rem;">
    <SubscribeButton
      client:visible
      targetType="build"
      targetId={build.id}
      initialSubscribed={isUserSubscribed}
      isLoggedIn={!!user}
    />
    {user && (
      <ReportButton
        client:visible
        entityType="build"
        entityId={build.id}
        userRole={getRoleLevel(user.role)}
      />
    )}
  </div>

  <!-- Edit / Delete Buttons (visible to author or moderator/admin) -->
  {isAuthorOrModerator && (
    <div class="edit-build-action">
      <a href={`/builds/${slug}/edit`} class="edit-build-btn">
        <svg class="edit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Edit Build
      </a>
      <button
        class="delete-build-btn"
        data-build-slug={slug}
      >
        <svg class="delete-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          <line x1="10" y1="11" x2="10" y2="17"/>
          <line x1="14" y1="11" x2="14" y2="17"/>
        </svg>
        Delete Build
      </button>
    </div>
  )}
</BuildLayout>
)}

<style>
  /* Review Mode Banner */
  .review-banner {
    padding: 1rem 1.5rem;
    border: 3px solid var(--border);
    border-radius: 4px;
    margin-bottom: 2rem;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .review-banner--warning {
    background: var(--color-accent);
    border-color: var(--border);
  }

  .review-banner--danger {
    background: var(--color-danger, #fee2e2);
    border-color: var(--border);
  }

  .review-banner--info {
    background: var(--surface);
    border-color: var(--border);
  }

  .review-banner-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .review-banner-icon {
    flex-shrink: 0;
    color: var(--text);
  }

  .review-banner-text {
    flex: 1;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
  }

  .review-banner-text strong {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .review-banner-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .review-banner-link:hover {
    color: var(--color-primary);
  }

  .review-banner-link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .review-banner-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 2px solid var(--border);
  }

  .review-approve-btn,
  .review-reject-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: inherit;
    border: 3px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--shadow-hard);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .review-approve-btn {
    background: var(--color-primary);
    color: var(--text-inverse);
  }

  .review-reject-btn {
    background: var(--surface);
    color: var(--text);
  }

  .review-approve-btn:hover,
  .review-reject-btn:hover {
    transform: translateY(-2px);
    box-shadow: 5px 5px 0 var(--shadow-hard);
  }

  .review-approve-btn:focus-visible,
  .review-reject-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .review-approve-btn:disabled,
  .review-reject-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* Review reject form */
  .review-reject-form {
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .review-reject-form.hidden {
    display: none;
  }

  .review-reject-label {
    display: block;
    font-size: 0.9rem;
