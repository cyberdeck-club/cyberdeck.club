---
import BuildLayout from "@/layouts/BuildLayout.astro";
import BuildCard from "@/components/BuildCard.astro";
import { getBuild, getBuilds } from "@/lib/builds";
import { eq, isNull, and } from "drizzle-orm";
import * as schema from "../../db/schema";
import { hasAcceptedGuidelines } from "@/lib/guidelines";
import { renderMarkdownToHtml } from "@/utils/MarkdownRenderer";

// Server-rendered page
export const prerender = false;

// Get slug from URL params
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/builds");
}

// Fetch build from database
const db = Astro.locals.db!;
const buildResult = await getBuild(db, slug);

// Build not found - redirect to builds list
const notFound = !buildResult || buildResult.length === 0;

if (notFound) {
  return Astro.redirect("/builds");
}

const result = buildResult[0];
const build = result.build;
const authorName = result.authorName;
const authorId = build.authorId;

// Transform build data for the template
interface BuildData {
  title: string;
  builderName: string;
  builderId?: string | null;
  difficulty: "beginner" | "intermediate" | "advanced";
  computePlatform: string;
  estimatedCost: number;
  buildTime: string;
  featuredImage?: { url: string; alt: string };
  gallery: { url: string; alt: string }[];
  description: string;
  content: string;
  partsList: { name: string; link?: string; price?: number; notes?: string }[];
  tags: string[];
  linkedBuildLog?: string;
  linkedWikiArticles?: string[];
}

const buildData: BuildData = {
  title: build.title,
  builderName: authorName,
  builderId: authorId,
  difficulty: "intermediate" as const, // Default - schema doesn't have difficulty yet
  computePlatform: "Raspberry Pi", // Default - schema doesn't have computePlatform yet
  estimatedCost: 0, // Default - schema doesn't have estimatedCost yet
  buildTime: "Varies", // Default - schema doesn't have buildTime yet
  featuredImage: build.heroImageUrl ? { url: build.heroImageUrl, alt: build.title } : undefined,
  gallery: [] as { url: string; alt: string }[], // Default - schema doesn't have gallery yet
  description: build.description || "",
  content: build.content || "",
  partsList: [] as { name: string; link?: string; price?: number; notes?: string }[], // Default - schema doesn't have partsList yet
  tags: [] as string[], // Default - schema doesn't have tags yet
  linkedBuildLog: undefined as string | undefined,
  linkedWikiArticles: undefined as string[] | undefined
};

// Fetch related builds (same difficulty)
const allBuildsResult = await getBuilds(db, { limit: 20 });
const relatedBuilds = allBuildsResult
  .filter(({ build: b }) => b.slug !== slug)
  .slice(0, 2)
  .map(({ build: b, authorName: name }) => ({
    slug: b.slug,
    title: b.title,
    builderName: name,
    builderId: b.authorId,
    difficulty: "intermediate" as const,
    computePlatform: "Raspberry Pi",
    estimatedCost: 0,
    featuredImage: b.heroImageUrl ? { url: b.heroImageUrl, alt: b.title } : undefined
  }));

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(amount);
};

// Fetch build comments
const commentsResult = await db
  .select({
    id: schema.buildComments.id,
    content: schema.buildComments.content,
    parentId: schema.buildComments.parentId,
    createdAt: schema.buildComments.createdAt,
    updatedAt: schema.buildComments.updatedAt,
    authorId: schema.buildComments.authorId,
    authorName: schema.user.name,
  })
  .from(schema.buildComments)
  .innerJoin(schema.user, eq(schema.buildComments.authorId, schema.user.id))
  .where(
    and(
      eq(schema.buildComments.buildId, build.id),
      isNull(schema.buildComments.deletedAt)
    )
  )
  .orderBy(schema.buildComments.createdAt);

const comments = commentsResult.map(c => ({
  ...c,
  contentHtml: renderMarkdownToHtml(c.content),
}));

// Get current user and guidelines status
const user = Astro.locals.user;
let guidelinesAccepted = false;
let isAuthorOrModerator = false;

if (user) {
  guidelinesAccepted = await hasAcceptedGuidelines(db, user.id);
  isAuthorOrModerator = build.authorId === user.id || user.role === "moderator" || user.role === "admin";
}
---

<BuildLayout
  title={buildData.title}
  description={`${buildData.title} by ${buildData.builderName} - ${buildData.computePlatform} cyberdeck build`}
  featuredImage={buildData.featuredImage}
  builderName={buildData.builderName}
  builderId={buildData.builderId}
  difficulty={buildData.difficulty}
  computePlatform={buildData.computePlatform}
  estimatedCost={buildData.estimatedCost}
  buildTime={buildData.buildTime}
  tags={buildData.tags}
>
  <!-- Description Section -->
  <section class="build-section">
    <h2 class="section-title">About This Build</h2>
    <div class="description-content">
      <Fragment set:html={renderMarkdownToHtml(buildData.description || buildData.content || "")}/>
    </div>
  </section>

  <!-- Parts List Section - Show message if no parts list in schema -->
  {buildData.partsList.length === 0 && (
    <section class="build-section">
      <h2 class="section-title">Parts List</h2>
      <p class="parts-placeholder">Parts list not available for this build yet.</p>
    </section>
  )}

  <!-- Image Gallery Section -->
  {buildData.gallery.length > 0 && (
    <section class="build-section">
      <h2 class="section-title">Gallery</h2>
      <div class="gallery-grid">
        {buildData.gallery.map((image, index) => (
          <button
            class="gallery-item"
            data-gallery-index={index}
            aria-label={`View ${image.alt}`}
          >
            <img
              src={image.url}
              alt={image.alt}
              loading="lazy"
            />
          </button>
        ))}
      </div>
    </section>
  )}

  <!-- Linked Build Log -->
  {buildData.linkedBuildLog && (
    <section class="build-section">
      <h2 class="section-title">Build Log</h2>
      <a href={buildData.linkedBuildLog} class="build-log-link" target="_blank" rel="noopener">
        <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
        </svg>
        View Build Log on the Forum
        <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </section>
  )}

  <!-- Linked Wiki Articles -->
  {buildData.linkedWikiArticles && buildData.linkedWikiArticles.length > 0 && (
    <section class="build-section">
      <h2 class="section-title">Related Wiki Articles</h2>
      <ul class="wiki-links">
        {buildData.linkedWikiArticles.map((article: string) => (
          <li>
            <a href={`/wiki/${article}`} class="wiki-link">
              <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
              </svg>
              {article.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Related Builds Section -->
  {relatedBuilds.length > 0 && (
    <section class="build-section related-section">
      <h2 class="section-title">Related Builds</h2>
      <div class="related-grid">
        {relatedBuilds.slice(0, 2).map(related => (
          <BuildCard
            title={related.title}
            builderName={related.builderName}
            builderId={related.builderId}
            featuredImage={related.featuredImage}
            difficulty={related.difficulty}
            computePlatform={related.computePlatform}
            estimatedCost={related.estimatedCost}
            href={`/builds/${related.slug}`}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Sidebar slot content -->
  <div slot="sidebar">
    <div class="sidebar-section">
      <h3 class="sidebar-title">Quick Stats</h3>
      <dl class="stats-list">
        <dt>Platform</dt>
        <dd>{buildData.computePlatform}</dd>
        <dt>Est. Cost</dt>
        <dd>{formatCurrency(buildData.estimatedCost)}</dd>
        <dt>Build Time</dt>
        <dd>{buildData.buildTime}</dd>
        <dt>Difficulty</dt>
        <dd>
          <span
            class="difficulty-inline"
            style={`background: ${buildData.difficulty === 'beginner' ? 'var(--color-secondary)' : buildData.difficulty === 'intermediate' ? 'var(--color-accent)' : 'var(--color-primary)'}; color: ${buildData.difficulty === 'advanced' ? 'var(--text-inverse)' : 'var(--text)'}`}
          >
            {buildData.difficulty.charAt(0).toUpperCase() + buildData.difficulty.slice(1)}
          </span>
        </dd>
      </dl>
    </div>
  </div>

  <!-- Comments Section -->
  <section class="build-section comments-section">
    <h2 class="section-title">Comments ({comments.length})</h2>
    
    {comments.length === 0 ? (
      <p class="no-comments">No comments yet. Be the first to share your thoughts!</p>
    ) : (
      <div class="comments-list">
        {comments.map(comment => (
          <div class="comment" data-comment-id={comment.id}>
            <div class="comment-header">
              <a href={`/user/${comment.authorId}`} class="author-link">{comment.authorName}</a>
              <span class="comment-time">
                {new Date(comment.createdAt * 1000).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                })}
              </span>
            </div>
            <div class="comment-content" set:html={comment.contentHtml}></div>
            {user && (
              <button class="reply-btn" data-parent-id={comment.id}>
                Reply
              </button>
            )}
          </div>
        ))}
      </div>
    )}

    {user && guidelinesAccepted ? (
      <div id="comment-form-container" class="comment-form-wrapper" data-slug={slug}></div>
    ) : user && !guidelinesAccepted ? (
      <div class="guidelines-prompt">
        <p>You need to accept the community guidelines before commenting.</p>
        <a href="/guidelines" class="btn-primary">Accept Guidelines</a>
      </div>
    ) : (
      <div class="login-prompt">
        <p>Want to join the conversation?</p>
        <a href="/login" class="btn-primary">Sign in to Comment</a>
      </div>
    )}
  </section>

  <!-- Edit Button (visible to author or moderator/admin) -->
  {isAuthorOrModerator && (
    <div class="edit-build-action">
      <a href={`/builds/${slug}/edit`} class="edit-build-btn">
        <svg class="edit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Edit Build
      </a>
    </div>
  )}
</BuildLayout>

<style>
  /* Build Sections */
  .build-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 3px solid var(--border);
  }

  /* Description */
  .description-content {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
  }

  .description-content p {
    margin: 0 0 1rem;
  }

  .description-content p:last-child {
    margin-bottom: 0;
  }

  /* Parts Table */
  .parts-table-wrapper {
    overflow-x: auto;
    border: 3px solid var(--border);
    border-radius: 4px;
  }

  .parts-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .parts-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background: var(--surface);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 3px solid var(--border);
  }

  .parts-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .parts-table tr:last-child td {
    border-bottom: none;
  }

  .parts-table tr:hover td {
    background: var(--surface);
  }

  .price-col {
    text-align: right;
    white-space: nowrap;
    font-weight: 600;
  }

  .notes-col {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .part-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .part-link:hover {
    text-decoration: underline;
  }

  .external-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  .total-row {
    background: var(--surface);
    font-weight: 700;
  }

  .total-row td {
    padding: 1rem;
    border-bottom: none;
  }

  .total-row .price-col {
    color: var(--color-primary);
    font-size: 1.1rem;
  }

  /* Gallery */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .gallery-item {
    aspect-ratio: 4/3;
    overflow: hidden;
    border: 3px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    padding: 0;
    background: none;
    transition: all 0.2s ease;
  }

  .gallery-item:hover {
    border-color: var(--color-primary);
    transform: scale(1.02);
  }

  .gallery-item:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Build Log Link */
  .build-log-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    border: 3px solid var(--border);
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .build-log-link:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .build-log-link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .link-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Wiki Links */
  .wiki-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .wiki-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    border: 2px solid var(--border);
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .wiki-link:hover {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  /* Related Builds */
  .related-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 3px solid var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .parts-table th {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .parts-table tr:hover td {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .total-row {
    background: var(--surface);
  }

  :global([data-theme="dark"]) .gallery-item:hover {
    border-color: var(--color-primary);
  }

  :global([data-theme="dark"]) .wiki-link:hover {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .section-title {
      font-size: 1.25rem;
    }

    .parts-table {
      font-size: 0.85rem;
    }

    .parts-table th,
    .parts-table td {
      padding: 0.5rem 0.75rem;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Comments Section */
  .comments-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 4px solid var(--border);
  }

  .no-comments {
    color: var(--text-muted);
    font-style: italic;
    padding: 1rem 0;
  }

  .comments-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .comment {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 3px solid var(--color-secondary-300);
    border-radius: 4px;
  }

  .comment-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .comment-author {
    font-weight: 700;
    color: var(--color-primary);
  }

  .comment-time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .comment-content {
    line-height: 1.6;
    color: var(--text);
  }

  .comment-content p {
    margin: 0 0 0.75rem;
  }

  .comment-content p:last-child {
    margin-bottom: 0;
  }

  .reply-btn {
    margin-top: 0.75rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.8rem;
    font-family: inherit;
    font-weight: 600;
    background: var(--color-surface-alt);
    border: 2px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    cursor: pointer;
    transition: background 0.2s;
  }

  .reply-btn:hover {
    background: var(--color-secondary-200);
  }

  .reply-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .comment-form-wrapper {
    margin-top: 2rem;
  }

  .guidelines-prompt,
  .login-prompt {
    padding: 1.5rem;
    background: var(--color-surface-alt);
    border: 3px solid var(--border);
    border-radius: 4px;
    text-align: center;
  }

  .guidelines-prompt p,
  .login-prompt p {
    margin: 0 0 1rem;
    color: var(--text);
  }

  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    background: var(--color-primary);
    border: 3px solid var(--border);
    border-radius: 4px;
    color: var(--text-inverse);
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .edit-build-action {
    margin-top: 2rem;
    text-align: right;
  }

  .edit-build-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    background: var(--color-secondary);
    border: 3px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .edit-build-btn:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .edit-build-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .edit-icon {
    width: 1rem;
    height: 1rem;
  }
</style>

<script>
  import { createElement as h, createRoot } from "react-dom/client";
  import { CommentForm } from "@/components/builds/CommentForm";

  // Mount comment form if container exists
  const commentFormContainer = document.getElementById("comment-form-container");
  if (commentFormContainer) {
    const slug = commentFormContainer.dataset.slug ?? "";
    const guidelinesAccepted = true; // Already checked server-side
    
    const root = createRoot(commentFormContainer);
    root.render(
      h(CommentForm, {
        buildSlug: slug,
        guidelinesAccepted: guidelinesAccepted,
      })
    );
  }

  // Handle reply buttons
  document.querySelectorAll(".reply-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const parentId = target.dataset.parentId;
      if (!parentId) return;

      const container = document.getElementById("comment-form-container");
      if (!container) return;

      // Clear existing form and mount new one with parentId
      const root = createRoot(container);
      root.render(
        h(CommentForm, {
          buildSlug: container.dataset.slug ?? "",
          guidelinesAccepted: true,
          parentId: parentId,
        })
      );

      // Scroll to form
      container.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });
</script>
