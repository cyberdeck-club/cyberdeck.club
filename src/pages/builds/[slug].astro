<script>
  import { createElement as h, createRoot } from "react-dom/client";
  import { CommentForm } from "@/components/builds/CommentForm";

  // Mount comment form if container exists
  const commentFormContainer = document.getElementById("comment-form-container");
  if (commentFormContainer) {
    const slug = commentFormContainer.dataset.slug ?? "";
    const guidelinesAccepted = true; // Already checked server-side
    
    const root = createRoot(commentFormContainer);
    root.render(
      h(CommentForm, {
        buildSlug: slug,
        guidelinesAccepted: guidelinesAccepted,
      })
    );
  }

  // Handle reply buttons
  document.querySelectorAll(".reply-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const parentId = target.dataset.parentId;
      if (!parentId) return;

      const container = document.getElementById("comment-form-container");
      if (!container) return;

      // Clear existing form and mount new one with parentId
      const root = createRoot(container);
      root.render(
        h(CommentForm, {
          buildSlug: container.dataset.slug ?? "",
          guidelinesAccepted: true,
          parentId: parentId,
        })
      );

      // Scroll to form
      container.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });
</script>

<script>
  // Delete build handler
  document.addEventListener('DOMContentLoaded', () => {
    const deleteBtn = document.querySelector('.delete-build-btn') as HTMLButtonElement | null;
    if (!deleteBtn) return;

    deleteBtn.addEventListener('click', async () => {
      const buildSlug = deleteBtn.dataset.buildSlug;
      if (!buildSlug) return;

      if (!confirm('Are you sure you want to delete this build? This action cannot be easily undone.')) {
        return;
      }

      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/builds/${buildSlug}`, { method: 'DELETE' });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to delete build');
        }
        window.location.href = '/builds';
      } catch (err) {
        alert(err instanceof Error ? err.message : 'Failed to delete build');
        deleteBtn.disabled = false;
        deleteBtn.textContent = 'Delete Build';
      }
    });
  });
</script>

<script>
  // Review mode moderation actions (approve/reject from build detail page)
  document.addEventListener('DOMContentLoaded', () => {
    const bannerActions = document.querySelector('.review-banner-actions');
    if (!bannerActions) return;

    const buildSlug = (bannerActions as HTMLElement).dataset.buildSlug;
    if (!buildSlug) return;

    const approveBtn = bannerActions.querySelector('.review-approve-btn');
    const rejectBtn = bannerActions.querySelector('.review-reject-btn');
    const rejectForm = document.getElementById('review-reject-form');
    const cancelRejectBtn = document.getElementById('review-cancel-reject');
    const submitRejectBtn = document.getElementById('review-submit-reject') as HTMLButtonElement | null;
    const rejectReason = document.getElementById('review-reject-reason') as HTMLTextAreaElement | null;

    // Approve
    approveBtn?.addEventListener('click', async () => {
      if (!confirm('Approve this build? It will be published and visible to everyone.')) return;

      try {
        (approveBtn as HTMLButtonElement).disabled = true;
        const response = await fetch(`/api/builds/${buildSlug}/review`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'approve' }),
        });

        if (response.ok) {
          window.location.reload();
        } else {
          const data = await response.json();
          alert(data.error || 'Failed to approve build');
          (approveBtn as HTMLButtonElement).disabled = false;
        }
      } catch {
        alert('Failed to approve build');
        (approveBtn as HTMLButtonElement).disabled = false;
      }
    });

    // Show reject form
    rejectBtn?.addEventListener('click', () => {
      rejectForm?.classList.remove('hidden');
      (rejectBtn as HTMLElement).style.display = 'none';
      (approveBtn as HTMLElement).style.display = 'none';
    });

    // Cancel reject
    cancelRejectBtn?.addEventListener('click', () => {
      rejectForm?.classList.add('hidden');
      (rejectBtn as HTMLElement).style.display = '';
      (approveBtn as HTMLElement).style.display = '';
      if (rejectReason) rejectReason.value = '';
    });

    // Enable submit when reason is long enough
    rejectReason?.addEventListener('input', () => {
      if (submitRejectBtn) {
        submitRejectBtn.disabled = rejectReason.value.trim().length < 10;
      }
    });

    // Submit reject
    submitRejectBtn?.addEventListener('click', async () => {
      const reason = rejectReason?.value.trim();
      if (!reason || reason.length < 10) {
        alert('Please provide feedback of at least 10 characters');
        return;
      }

      try {
        submitRejectBtn.disabled = true;
        const response = await fetch(`/api/builds/${buildSlug}/review`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'reject', reason }),
        });

        if (response.ok) {
          window.location.reload();
        } else {
          const data = await response.json();
          alert(data.error || 'Failed to send feedback');
          submitRejectBtn.disabled = false;
        }
      } catch {
        alert('Failed to send feedback');
        submitRejectBtn.disabled = false;
      }
    });
  });
</script>
