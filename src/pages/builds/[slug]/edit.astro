---
/**
 * Edit Build Page
 * Form for editing an existing cyberdeck build
 * Only accessible by build author or moderator/admin roles
 */

import BaseLayout from "@/layouts/BaseLayout.astro";
import { BuildEditor } from "@/components/editor/BuildEditor";
import { BuildFormFields } from "@/components/builds/BuildFormFields";
import { getBuildForReview, parseBuildJsonFields } from "@/lib/builds";
import { eq } from "drizzle-orm";
import * as schema from "../../../db/schema";
import { hasAcceptedGuidelines } from "@/lib/guidelines";
import { requireRole, ROLES, getRoleLevel } from "@/lib/roles";

export const prerender = false;

// Check if user is logged in
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login?redirect=" + encodeURIComponent(Astro.url.pathname));
}

// Guidelines check
const db = Astro.locals.db!;
const guidelinesAccepted = await hasAcceptedGuidelines(db, user.id);
if (!guidelinesAccepted) {
  return Astro.redirect(`/guidelines?redirect=/builds/${Astro.params.slug}/edit`);
}

// Get slug from URL params
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/builds");
}

// Fetch the existing build — getBuildForReview returns all statuses (not just published)
// so authors can edit their pending/needs-revision builds
const buildResult = await getBuildForReview(db, slug);

if (!buildResult || buildResult.length === 0) {
  return Astro.redirect("/builds?error=build_not_found");
}

const existingBuild = buildResult[0].build;

// Check if user is author or moderator/admin using requireRole()
const isAuthor = existingBuild.authorId === user.id;
const isModeratorOrAdmin = requireRole(user.role, ROLES.MODERATOR);

if (!isAuthor && !isModeratorOrAdmin) {
  return Astro.redirect("/builds?error=not_authorized");
}

// Check if this build needs revision — show feedback banner
// IMPORTANT: Never use the word "rejected" in user-facing copy
const needsRevision = existingBuild.status === "rejected" || existingBuild.status === "rejected_auto";
const revisionFeedback = needsRevision ? existingBuild.rejectionReason : null;

// Get initial content for the editor
const initialContent = existingBuild.description || existingBuild.content || "";

// Parse structured JSON fields from the existing build
const parsedBuild = parseBuildJsonFields(existingBuild);

// Helper to safely parse JSON fields
const safeJson = <T,>(val: T | string | null | undefined): T | undefined => {
  if (!val) return undefined;
  if (typeof val === 'object') return val;
  try {
    return JSON.parse(val as string) as T;
  } catch {
    return undefined;
  }
};

const initialStructuredData = {
  difficulty: existingBuild.difficulty || undefined,
  computePlatform: existingBuild.computePlatform || undefined,
  estimatedCost: existingBuild.estimatedCost ? existingBuild.estimatedCost / 100 : undefined,
  buildTime: existingBuild.buildTime || undefined,
  tags: parsedBuild.tags || undefined,
  wiring: parsedBuild.wiring ?? undefined,
  codebase: parsedBuild.codebase ?? undefined,
  models3d: parsedBuild.models3d ?? undefined,
  photos: parsedBuild.photos ?? undefined,
  videos: parsedBuild.videos ?? undefined,
  // TikTok links: check new field first, then fall back to extracting from old inspirations location
  tiktokLinks: parsedBuild.tiktokLinks ??
    parsedBuild.inspirations?.externalLinks?.filter((l: { url: string }) => l.url.includes("tiktok.com")).map((l: { url: string }) => l.url) ??
    undefined,
  billOfMaterials: parsedBuild.billOfMaterials ?? undefined,
  circuitBoards: parsedBuild.circuitBoards ?? undefined,
  // For inspirations, filter out TikTok links (now stored separately)
  inspirations: parsedBuild.inspirations ? {
    ...parsedBuild.inspirations,
    externalLinks: parsedBuild.inspirations.externalLinks?.filter((l: { url: string }) => !l.url.includes("tiktok.com")) ?? []
  } : undefined,
  powerDetails: parsedBuild.powerDetails ?? undefined,
  connectivity: parsedBuild.connectivity ?? undefined,
  displayInfo: parsedBuild.displayInfo ?? undefined,
  enclosure: parsedBuild.enclosureDetails ?? undefined,
};

// Serialize to JSON for passing to React component
const initialStructuredDataJson = JSON.stringify(initialStructuredData);

---

<BaseLayout title={`Edit: ${existingBuild.title}`} description="Edit your cyberdeck build">
  <div class="edit-build-page">
    <header class="page-header">
      <div class="header-sparkles">
        <span class="sparkle">✦</span>
        <span class="sparkle">✧</span>
        <span class="sparkle">✦</span>
      </div>
      <h1 class="page-title">Edit Build ✨</h1>
      <p class="page-subtitle">Update your cyberdeck creation</p>
    </header>

    {needsRevision && revisionFeedback && (
      <div class="revision-banner" role="status">
        <p class="revision-banner-label">▸ REVIEWER FEEDBACK</p>
        <p class="revision-banner-text">{revisionFeedback}</p>
        <p class="revision-banner-hint">
          Make the changes you think are right, then save — your build will go
          back into review automatically. No rush. ✨
        </p>
      </div>
    )}

    <form id="edit-build-form" class="build-form" data-build-slug={existingBuild.slug} data-build-needs-revision={needsRevision ? "true" : "false"} data-build-status={existingBuild.status}>
      <div class="form-group">
        <label for="title" class="form-label">Title <span class="required">*</span></label>
        <input 
          type="text" 
          id="title" 
          name="title" 
          class="form-input" 
          placeholder="Give your build a name"
          required
          maxlength="200"
          value={existingBuild.title}
        />
        <span class="form-hint">Keep it clear and memorable (max 200 characters)</span>
      </div>

      <div class="form-group">
        <label for="slug" class="form-label">URL Slug</label>
        <input 
          type="text" 
          id="slug" 
          name="slug" 
          class="form-input" 
          placeholder="your-build-url-slug"
          maxlength="100"
          pattern="[a-z0-9\-]+"
          value={existingBuild.slug}
        />
        <span class="form-hint">Lowercase letters, numbers, and hyphens only.</span>
      </div>

      <div class="form-group">
        <label for="buildStage" class="form-label">Build Stage</label>
        <select id="buildStage" name="buildStage" class="form-select">
          <option value="" selected={!existingBuild.buildStage}>Not set</option>
          <option value="planning" selected={existingBuild.buildStage === "planning"}>Planning</option>
          <option value="in-progress" selected={existingBuild.buildStage === "in-progress"}>In Progress</option>
          <option value="complete" selected={existingBuild.buildStage === "complete"}>Complete</option>
        </select>
        <span class="form-hint">Let the community know where you are in your build journey</span>
      </div>

      <div class="form-group">
        <label for="description" class="form-label">Description <span class="required">*</span></label>
        <BuildEditor
          client:only="react"
          initialContent={initialContent}
          hiddenInputId="description-input"
        />
        <input type="hidden" name="description" id="description-input" value={initialContent} />
        <span class="form-hint">Describe your build, what makes it special, and your plans</span>
      </div>

      <div class="form-group">
        <label for="imageUrl" class="form-label">Hero Image URL</label>
        <input 
          type="url" 
          id="imageUrl" 
          name="imageUrl" 
          class="form-input" 
          placeholder="https://example.com/your-build-image.jpg"
          value={existingBuild.heroImageUrl ?? ""}
        />
        <span class="form-hint">Optional: Add a hero image for your build showcase</span>
      </div>


      <!-- Structured Build Fields (React Island) -->
      <div id="build-form-fields-container" data-build-form-fields>
        <BuildFormFields
          client:load
          initialData={initialStructuredData}
        />
      </div>

      <div class="form-actions">
        <a href={needsRevision ? "/builds/mine" : `/builds/${existingBuild.slug}`} class="btn-cancel">Cancel</a>
        <button type="submit" class="btn-submit" id="submit-btn">
          <span class="btn-text">{needsRevision ? "Save & Resubmit ✨" : "Save Changes ✨"}</span>
          <span class="btn-loading" style="display: none;">Saving...</span>
        </button>
      </div>

      <div id="form-error" class="form-error" style="display: none;"></div>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById("edit-build-form") as HTMLFormElement;
  const titleInput = document.getElementById("title") as HTMLInputElement;
  const slugInput = document.getElementById("slug") as HTMLInputElement;
  const buildStageSelect = document.getElementById("buildStage") as HTMLSelectElement;
  const descriptionInput = document.getElementById("description-input") as HTMLInputElement;
  const imageUrlInput = document.getElementById("imageUrl") as HTMLInputElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = submitBtn.querySelector(".btn-text") as HTMLSpanElement;
  const btnLoading = submitBtn.querySelector(".btn-loading") as HTMLSpanElement;
  const formError = document.getElementById("form-error") as HTMLDivElement;

  const buildSlug = form.dataset.buildSlug ?? "";
  const currentStatus = form.dataset.buildStatus ?? "";

  // Track if slug was manually edited
  let slugManuallyEdited = true; // Start as true since we're editing existing build

  slugInput.addEventListener("input", () => {
    slugManuallyEdited = true;
  });

  // Form submission
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Validate content
    if (!titleInput.value.trim()) {
      formError.textContent = "Please enter a title for your build.";
      formError.style.display = "block";
      return;
    }

    if (!descriptionInput.value.trim()) {
      formError.textContent = "Please write a description for your build.";
      formError.style.display = "block";
      return;
    }

    // Show loading state
    submitBtn.disabled = true;
    btnText.style.display = "none";
    btnLoading.style.display = "inline";
    formError.style.display = "none";

    // If this build needs revision, resubmit to pending_human on save.
    // Otherwise, only send buildStage (not status) — status is for the
    // moderation pipeline and must not be overwritten by build progress.
    const needsRevision = form.dataset.buildNeedsRevision === "true";

    const payload: Record<string, unknown> = {
      title: titleInput.value.trim(),
      slug: slugManuallyEdited ? slugInput.value.trim() : undefined,
      buildStage: buildStageSelect.value || null,
      description: descriptionInput.value,
      imageUrl: imageUrlInput.value.trim() || undefined,
      // Include structured fields from BuildFormFields component
      ...(window as any).__buildStructuredFields,
    };

    // Only set status when resubmitting after revision
    if (needsRevision) {
      payload.status = "pending_human";
    }

    try {
      const response = await fetch(`/api/builds/${buildSlug}`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (response.status === 403) {
        const data = await response.json();
        if (data.error === "guidelines_required") {
          window.location.href = data.redirect + `?redirect=/builds/${buildSlug}/edit`;
          return;
        }
      }

      if (response.ok) {
        const data = await response.json();
        // If resubmitting after revision, go to My Builds; otherwise go to the build page
        if (needsRevision) {
          window.location.href = "/builds/mine";
        } else {
          window.location.href = `/builds/${data.build.slug}`;
        }
      } else {
        const data = await response.json();
        throw new Error(data.error || "Failed to update build");
      }
    } catch (err) {
      console.error("Submit error:", err);
      formError.textContent = err instanceof Error ? err.message : "Failed to update build. Please try again.";
      formError.style.display = "block";

      // Reset button state
      submitBtn.disabled = false;
      btnText.style.display = "inline";
      btnLoading.style.display = "none";
    }
  });
</script>

<style>
  .edit-build-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
  }

  /* Revision feedback banner */
  .revision-banner {
    background: var(--color-surface-alt);
    border: 3px solid var(--color-secondary, #7c3aed);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .revision-banner-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary, #7c3aed);
    margin: 0 0 0.5rem;
  }

  .revision-banner-text {
    font-size: 0.9375rem;
    color: var(--text);
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }

  .revision-banner-hint {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .header-sparkles {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    opacity: 0.3;
    pointer-events: none;
  }

  .sparkle {
    font-size: 1.5rem;
    animation: sparkle 2s ease-in-out infinite;
  }

  .sparkle:nth-child(2) {
    animation-delay: 0.5s;
  }

  .sparkle:nth-child(3) {
    animation-delay: 1s;
  }

  @keyframes sparkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.2); }
  }

  .page-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 2.5rem);
    color: var(--text);
    margin: 0 0 0.5rem;
    position: relative;
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin: 0;
    position: relative;
  }

  .build-form {
    background: var(--color-surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    padding: 2rem;
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .required {
    color: var(--color-danger);
  }

  .form-input,
  .form-select {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: inherit;
    background: var(--bg);
    border: 3px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-input:focus,
  .form-select:focus {
    outline: none;
    border-color: var(--focus);
  }

  .form-input:focus-visible,
  .form-select:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .form-input::placeholder {
    color: var(--text-muted);
  }

  .form-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.375rem;
  }

  .editor-error {
    color: var(--color-danger);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.75rem;
    background: var(--color-primary-50);
    border: 2px solid var(--color-primary-300);
    border-radius: 8px;
    margin-top: 0.5rem;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--color-border);
  }

  .btn-cancel,
  .btn-submit {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .btn-cancel {
    background: var(--color-surface-alt);
    border: 3px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .btn-cancel:hover {
    transform: translateY(-2px);
    box-shadow: 4px 4px 0 var(--color-shadow-hard);
  }

  .btn-submit {
    background: var(--color-primary);
    border: 3px solid var(--color-border);
    color: var(--color-text-inverse);
    box-shadow: 4px 4px 0 var(--color-shadow-hard);
  }

  .btn-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0 var(--color-shadow-hard);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-error {
    color: var(--color-danger);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.75rem;
    background: var(--color-danger) / 10%;
    border: 2px solid var(--color-danger);
    border-radius: 4px;
    margin-top: 1rem;
  }
</style>
