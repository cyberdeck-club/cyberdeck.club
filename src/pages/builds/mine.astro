---
/**
 * My Builds Page
 * Shows all builds by the authenticated user, regardless of status.
 * Requires MEMBER role minimum.
 *
 * Status badges:
 *  - Published (green)
 *  - Pending Review (amber)
 *  - Needs Revision (with feedback text)
 *  - Draft / other statuses
 *
 * IMPORTANT: Never surfaces the word "rejected" to the user.
 */

import BaseLayout from "@/layouts/BaseLayout.astro";
import { getUserBuilds } from "@/lib/builds";
import { requireRole, ROLES } from "@/lib/roles";

export const prerender = false;

// Require authentication
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login?redirect=/builds/mine");
}

// Require MEMBER role minimum
if (!requireRole(user.role, ROLES.MEMBER)) {
  return Astro.redirect("/");
}

const db = Astro.locals.db!;
const builds = await getUserBuilds(db, user.id);

/**
 * Map internal status values to user-facing labels and styles.
 * NEVER expose "rejected" to the user — it's "Needs Revision."
 */
function getStatusDisplay(status: string): { label: string; styleClass: string } {
  switch (status) {
    case "published":
      return { label: "Published", styleClass: "status-published" };
    case "pending_human":
    case "pending_auto":
      return { label: "Pending Review", styleClass: "status-pending" };
    case "rejected":
    case "rejected_auto":
      return { label: "Needs Revision", styleClass: "status-revision" };
    case "draft":
      return { label: "Draft", styleClass: "status-draft" };
    default:
      return { label: status, styleClass: "status-draft" };
  }
}

function getBuildStageDisplay(stage: string | null): { label: string; styleClass: string } | null {
  if (!stage) return null;
  switch (stage) {
    case "planning":
      return { label: "Planning", styleClass: "status-draft" };
    case "in-progress":
      return { label: "In Progress", styleClass: "status-pending" };
    case "complete":
      return { label: "Complete", styleClass: "status-published" };
    default:
      return null;
  }
}

/**
 * Get the appropriate link for a build based on its status.
 * Published builds link to the detail page; others link to edit.
 */
function getBuildLink(slug: string, status: string): string {
  if (status === "published") {
    return `/builds/${slug}`;
  }
  return `/builds/${slug}/edit`;
}

/**
 * Format a unix timestamp or ISO date to a readable string.
 */
function formatDate(val: number | string | null | undefined): string {
  if (!val) return "";
  const date = typeof val === "number"
    ? new Date(val * 1000)
    : new Date(val);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="My Builds — cyberdeck.club" description="View and manage all your cyberdeck builds">
  <div class="my-builds-page">
    <header class="page-header">
      <div class="header-eyebrow">▸ MY BUILDS</div>
      <h1 class="page-title">Your Builds ✨</h1>
      <p class="page-subtitle">
        Everything you've submitted — published, in review, or waiting for your tweaks.
      </p>
    </header>

    {builds.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">🔧</div>
        <h2 class="empty-heading">No builds yet</h2>
        <p class="empty-text">
          What are you working on? Whether it's a Polly Pocket cyberdeck or a
          lunchbox terminal, we'd love to see it. Start documenting your build
          and share it with the community.
        </p>
        <a href="/builds/new" class="btn-primary">
          Start a New Build ✨
        </a>
      </div>
    ) : (
      <div class="builds-list">
        <div class="builds-header-row">
          <a href="/builds/new" class="btn-primary btn-new-build">
            + New Build
          </a>
        </div>

        {builds.map(({ build }) => {
          const statusDisplay = getStatusDisplay(build.status);
          const stageDisplay = getBuildStageDisplay(build.buildStage);
          const link = getBuildLink(build.slug, build.status);
          const isRevision = build.status === "rejected" || build.status === "rejected_auto";

          return (
            <article class="build-card">
              <div class="build-card-inner">
                {build.heroImageUrl && (
                  <div class="build-thumbnail">
                    <img
                      src={build.heroImageUrl}
                      alt={`Hero image for ${build.title}`}
                      loading="lazy"
                    />
                  </div>
                )}

                <div class="build-info">
                  <div class="build-meta">
                    <span class={`status-badge ${statusDisplay.styleClass}`}>
                      {statusDisplay.label}
                    </span>
                    {stageDisplay && (
                      <span class={`status-badge ${stageDisplay.styleClass}`}>
                        {stageDisplay.label}
                      </span>
                    )}
                    <span class="build-date">
                      {formatDate(build.createdAt)}
                    </span>
                  </div>

                  <h2 class="build-title">
                    <a href={link}>{build.title}</a>
                  </h2>

                  {build.description && (
                    <p class="build-excerpt">
                      {build.description.replace(/<[^>]*>/g, "").slice(0, 150)}
                      {build.description.length > 150 ? "…" : ""}
                    </p>
                  )}

                  {isRevision && build.rejectionReason && (
                    <div class="revision-feedback">
                      <p class="feedback-label">▸ FEEDBACK</p>
                      <p class="feedback-text">{build.rejectionReason}</p>
                    </div>
                  )}

                  <div class="build-actions">
                    {build.status === "published" ? (
                      <>
                        <a href={`/builds/${build.slug}`} class="btn-view">
                          View Build
                        </a>
                        <a href={`/builds/${build.slug}/edit`} class="btn-edit">
                          Edit
                        </a>
                      </>
                    ) : (
                      <a href={`/builds/${build.slug}/edit`} class="btn-edit-primary">
                        {isRevision ? "Edit & Resubmit" : "Edit Build"}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .my-builds-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .header-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 2.5rem);
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 6px 6px 0 var(--shadow-hard);
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .empty-heading {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .empty-text {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  /* Buttons */
  .btn-primary {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.75rem 1.5rem;
    border: 3px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .btn-primary:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 var(--shadow-hard);
  }

  .btn-primary:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--shadow-hard);
  }

  /* Builds list */
  .builds-header-row {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1.5rem;
  }

  .builds-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Build card */
  .build-card {
    background: var(--color-surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
    margin-bottom: 1.25rem;
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .build-card:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 var(--shadow-hard);
  }

  .build-card-inner {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .build-thumbnail {
    flex-shrink: 0;
    width: 120px;
    height: 90px;
    border: 2px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .build-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .build-info {
    flex: 1;
    min-width: 0;
  }

  .build-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .build-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Status badges */
  .status-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.625rem;
    border: 2px solid var(--border);
    border-radius: 2px;
  }

  .status-published {
    background: var(--color-accent-100, #d1fae5);
    color: var(--color-accent-800, #065f46);
    border-color: var(--color-accent-600, #059669);
  }

  :global([data-theme="dark"]) .status-published {
    background: rgba(5, 150, 105, 0.2);
    color: #6ee7b7;
    border-color: #059669;
  }

  .status-pending {
    background: var(--color-accent-50, #fffbeb);
    color: var(--color-accent-700, #b45309);
    border-color: var(--color-accent-500, #f59e0b);
  }

  :global([data-theme="dark"]) .status-pending {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    border-color: #f59e0b;
  }

  .status-revision {
    background: var(--color-primary-50, #fff1f2);
    color: var(--color-primary-700, #be123c);
    border-color: var(--color-primary-500, #f43f5e);
  }

  :global([data-theme="dark"]) .status-revision {
    background: rgba(244, 63, 94, 0.15);
    color: #fb7185;
    border-color: #f43f5e;
  }

  .status-draft {
    background: var(--color-surface-alt);
    color: var(--text-muted);
    border-color: var(--border);
  }

  .build-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.25rem;
    margin: 0 0 0.375rem;
    line-height: 1.3;
  }

  .build-title a {
    color: var(--text);
    text-decoration: none;
  }

  .build-title a:hover {
    color: var(--color-primary);
  }

  .build-excerpt {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  /* Revision feedback block */
  .revision-feedback {
    background: var(--color-surface-alt);
    border: 2px solid var(--color-secondary, #7c3aed);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
  }

  .feedback-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary, #7c3aed);
    margin: 0 0 0.375rem;
  }

  .feedback-text {
    font-size: 0.875rem;
    color: var(--text);
    margin: 0;
    line-height: 1.5;
  }

  /* Build action buttons */
  .build-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-view,
  .btn-edit,
  .btn-edit-primary {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border: 2px solid var(--border);
    border-radius: 2px;
    text-decoration: none;
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .btn-view {
    background: var(--color-primary);
    color: var(--color-text-inverse);
    box-shadow: 2px 2px 0 var(--shadow-hard);
  }

  .btn-view:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--shadow-hard);
  }

  .btn-edit {
    background: var(--color-surface);
    color: var(--text);
    box-shadow: 2px 2px 0 var(--shadow-hard);
  }

  .btn-edit:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--shadow-hard);
  }

  .btn-edit-primary {
    background: var(--color-secondary, #7c3aed);
    color: var(--color-text-inverse);
    box-shadow: 2px 2px 0 var(--shadow-hard);
  }

  .btn-edit-primary:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--shadow-hard);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .build-card-inner {
      flex-direction: column;
    }

    .build-thumbnail {
      width: 100%;
      height: 160px;
    }
  }
</style>
