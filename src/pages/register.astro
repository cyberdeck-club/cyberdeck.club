---
export const prerender = false;

interface Props {
  redirectTo?: string;
}

const { redirectTo = "/" } = Astro.props;

// Handle form submission
let error = "";
let success = false;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get("email")?.toString().trim();

    if (!email) {
      error = "Email is required";
    } else if (!email.includes("@")) {
      error = "Please enter a valid email address";
    } else {
      // Send signup request to EmDash
      const response = await fetch(new URL("/_emdash/api/auth/signup/request", Astro.url.origin), {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ email }),
      });

      if (response.ok) {
        success = true;
      } else {
        const data = await response.json();
        error = data?.error?.message || "Failed to create account";
      }
    }
  } catch (e) {
    error = "An unexpected error occurred";
  }
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - cyberdeck.club</title>
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        font-family: "InterVariable", system-ui, sans-serif;
        background-color: #faf8f5;
        color: #1a1a1a;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        margin: 0;
      }
      @media (prefers-color-scheme: dark) {
        body {
          background-color: #1a0a1a;
          color: #f5f0fa;
        }
      }
      .register-container {
        background: white;
        border: 3px solid #1a1a1a;
        border-radius: 0;
        box-shadow: 6px 6px 0 #1a1a1a;
        padding: 2.5rem;
        max-width: 420px;
        width: 100%;
      }
      @media (prefers-color-scheme: dark) {
        .register-container {
          background: #2a1a2a;
          border-color: #f5f0fa;
          box-shadow: 6px 6px 0 #a855f7;
        }
      }
      .register-header {
        text-align: center;
        margin-bottom: 2rem;
      }
      .register-title {
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
        text-transform: lowercase;
        letter-spacing: -0.02em;
      }
      .register-subtitle {
        font-size: 0.95rem;
        opacity: 0.7;
        margin: 0;
      }
      .form-group {
        margin-bottom: 1.25rem;
      }
      .form-label {
        display: block;
        font-weight: 600;
        font-size: 0.875rem;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 2px solid #1a1a1a;
        border-radius: 0;
        background: white;
        color: #1a1a1a;
        transition: box-shadow 0.15s ease;
      }
      @media (prefers-color-scheme: dark) {
        .form-input {
          background: #1a0a1a;
          border-color: #a855f7;
          color: #f5f0fa;
        }
      }
      .form-input:focus {
        outline: none;
        box-shadow: 3px 3px 0 #a855f7;
      }
      .submit-btn {
        width: 100%;
        padding: 0.875rem 1.5rem;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: #a855f7;
        color: white;
        border: 2px solid #1a1a1a;
        border-radius: 0;
        cursor: pointer;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        box-shadow: 3px 3px 0 #1a1a1a;
      }
      .submit-btn:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0 #1a1a1a;
      }
      .submit-btn:active {
        transform: translate(2px, 2px);
        box-shadow: 1px 1px 0 #1a1a1a;
      }
      .error-message {
        background: #fee2e2;
        border: 2px solid #dc2626;
        color: #991b1b;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
      }
      @media (prefers-color-scheme: dark) {
        .error-message {
          background: #450a0a;
          border-color: #f87171;
          color: #fecaca;
        }
      }
      .success-message {
        background: #d1fae5;
        border: 2px solid #059669;
        color: #065f46;
        padding: 1rem;
        text-align: center;
        font-size: 0.95rem;
      }
      @media (prefers-color-scheme: dark) {
        .success-message {
          background: #064e3b;
          border-color: #34d399;
          color: #a7f3d0;
        }
      }
      .success-message strong {
        display: block;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
      }
      .info-box {
        background: #f3e8ff;
        border: 2px solid #a855f7;
        color: #581c87;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
      }
      @media (prefers-color-scheme: dark) {
        .info-box {
          background: #3b0764;
          border-color: #c084fc;
          color: #e9d5ff;
        }
      }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: inherit;
        opacity: 0.7;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .back-link:hover {
        opacity: 1;
      }
      .divider {
        text-align: center;
        margin: 1.5rem 0;
        position: relative;
        color: inherit;
        opacity: 0.5;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .divider::before,
      .divider::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 35%;
        height: 1px;
        background: currentColor;
      }
      .divider::before {
        left: 0;
      }
      .divider::after {
        right: 0;
      }
    </style>
  </head>
  <body>
    <div class="register-container">
      <header class="register-header">
        <h1 class="register-title">✨ Join cyberdeck.club</h1>
        <p class="register-subtitle">Create your account to post and reply</p>
      </header>

      {error && <div class="error-message">{error}</div>}

      {success ? (
        <div class="success-message">
          <strong>Check your email! ✉️</strong>
          We sent you a verification link. Click the link to activate your account.
        </div>
      ) : (
        <>
          <div class="info-box">
            Enter your email to create an account. We'll send you a verification link to get started.
          </div>

          <form method="POST">
            <div class="form-group">
              <label class="form-label" for="email">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="you@example.com"
                required
                autocomplete="email"
              />
            </div>

            <button type="submit" class="submit-btn">Create Account</button>
          </form>
        </>
      )}

      <div class="divider">or</div>

      <p style="text-align: center; font-size: 0.9rem; opacity: 0.8;">
        Already have an account?<br />
        <a href="/login" style="color: #a855f7; font-weight: 600; text-decoration: underline; text-underline-offset: 3px;">
          Sign in here
        </a>
      </p>

      <a href="/" class="back-link">← Back to home</a>
    </div>
  </body>
</html>
