---
import MeetupLayout from "@/layouts/MeetupLayout.astro";
import { MarkdownRenderer } from "@/utils/MarkdownRenderer";

// Placeholder meetup data - in production this would come from EmDash queries
const placeholderMeetupsData: Record<string, {
  title: string;
  description: string;
  location_name: string;
  location_lat: number;
  location_lng: number;
  date_start: string;
  date_end?: string;
  organizer: string;
  max_attendees?: number;
  rsvp_count: number;
  status: "upcoming" | "in-progress" | "completed" | "cancelled";
  region: string;
}> = {
  "columbus-oh-build-day-march-2025": {
    title: "Columbus OH Build Day",
    description: `Join us for a full day of cyberdeck building at the Columbus Makerspace! Whether you're a beginner just getting started or an experienced builder working on your latest project, there's something for everyone.

We'll have:
- Soldering stations and basic tools
- 3D printers available for case printing
- Show and tell portion in the afternoon
- Pizza and drinks provided

Bring your project or start something new. All skill levels welcome!`,
    location_name: "Columbus Makerspace, Columbus OH",
    location_lat: 39.9612,
    location_lng: -82.9988,
    date_start: "2025-03-15T10:00:00",
    date_end: "2025-03-15T18:00:00",
    organizer: "NeonRaspberry",
    max_attendees: 20,
    rsvp_count: 14,
    status: "completed",
    region: "Ohio"
  },
  "portland-cyberdeck-saturdays": {
    title: "Portland Cyberdeck Saturdays",
    description: `Monthly meetup for Pacific Northwest cyberdeck enthusiasts! This month we're focusing on power systems - battery selection, power management, and safety.

Agenda:
- 10am: Doors open, coffee available
- 11am: Presentation on LiPo safety
- 12pm: Build session with guidance available
- 2pm: Show and tell
- 3pm: Networking and project planning for next month

Bring your project or just come to learn. The makerspace has tools and basic components available.`,
    location_name: "Portland Makerspace, Portland OR",
    location_lat: 45.5152,
    location_lng: -122.6784,
    date_start: "2025-04-19T10:00:00",
    date_end: "2025-04-19T16:00:00",
    organizer: "CircuitWitch",
    max_attendees: 25,
    rsvp_count: 18,
    status: "upcoming",
    region: "Pacific Northwest"
  },
  "austin-tx-workshop-beginners": {
    title: "Austin TX Beginner Workshop",
    description: `New to cyberdeck building? This workshop is specifically designed for beginners! We'll walk through building a basic portable Pi station from scratch.

What you'll learn:
- Basic tool usage (soldering iron, multimeter)
- Simple wiring and connections
- Case design and 3D printing basics
- Software setup for your deck

All materials provided - just bring your enthusiasm! Space is limited to ensure hands-on help is available.`,
    location_name: "Austin Hackerspace, Austin TX",
    location_lat: 30.2672,
    location_lng: -97.7431,
    date_start: "2025-04-26T09:00:00",
    date_end: "2025-04-26T17:00:00",
    organizer: "ByteRunner",
    max_attendees: 12,
    rsvp_count: 12,
    status: "upcoming",
    region: "Texas"
  },
  "nyc-meetup-spring-2025": {
    title: "NYC Spring Meetup",
    description: `The annual NYC cyberdeck community meetup is back! Join us for an afternoon of demos, discussions, and networking with fellow builders from the tri-state area.

Highlights:
- Demos of recent builds from community members
- Discussion panel on "The Future of Portable Computing"
- Speed build competition (bring a kit!)
- Pizza and refreshments provided

This is our biggest meetup of the year - don't miss it!`,
    location_name: "NYC Resilient Labs, Brooklyn NY",
    location_lat: 40.6782,
    location_lng: -73.9442,
    date_start: "2025-05-03T14:00:00",
    date_end: "2025-05-03T20:00:00",
    organizer: "PixelPioneer",
    max_attendees: 50,
    rsvp_count: 31,
    status: "upcoming",
    region: "Northeast"
  },
  "seattle-workshop-intermediate": {
    title: "Seattle Intermediate Build Day",
    description: `This workshop is for builders who've completed at least one project and want to level up. We're focusing on custom enclosures and finishes this month.

Topics covered:
- Vacuum forming basics
- Fiberglass layup techniques
- Surface finishing and painting
- Integrating custom RGB lighting

Prerequisites: Basic soldering skills and your own multimeter. Space is limited!`,
    location_name: "Seattle MakerSpace, Seattle WA",
    location_lat: 47.6062,
    location_lng: -122.3321,
    date_start: "2025-05-10T10:00:00",
    date_end: "2025-05-10T17:00:00",
    organizer: "NeonRaspberry",
    max_attendees: 16,
    rsvp_count: 9,
    status: "upcoming",
    region: "Pacific Northwest"
  }
};

// Get slug from URL - in server mode, Astro.url is available
const slug = Astro.url.pathname.split('/').pop() || '';

// Get meetup data (placeholder - would be EmDash query in production)
const meetup = placeholderMeetupsData[slug] || placeholderMeetupsData["portland-cyberdeck-saturdays"];

// Related meetups (same region, different event)
const relatedMeetups = Object.entries(placeholderMeetupsData)
  .filter(([key, m]) => key !== slug && m.region === meetup.region)
  .slice(0, 2)
  .map(([key, m]) => ({
    slug: key,
    title: m.title,
    date_start: m.date_start,
    location_name: m.location_name,
    region: m.region,
    status: m.status,
    rsvp_count: m.rsvp_count,
    max_attendees: m.max_attendees
  }));

// If not enough related, add some others
if (relatedMeetups.length < 2) {
  const others = Object.entries(placeholderMeetupsData)
    .filter(([key, m]) => key !== slug)
    .slice(0, 2 - relatedMeetups.length)
    .map(([key, m]) => ({
      slug: key,
      title: m.title,
      date_start: m.date_start,
      location_name: m.location_name,
      region: m.region,
      status: m.status,
      rsvp_count: m.rsvp_count,
      max_attendees: m.max_attendees
    }));
  relatedMeetups.push(...others);
}

// Helper to format dates for display
const formatDateShort = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
};
---

<MeetupLayout
  title={meetup.title}
  description={`Join us for ${meetup.title} - a cyberdeck build meetup in ${meetup.location_name}`}
  dateStart={meetup.date_start}
  dateEnd={meetup.date_end}
  locationName={meetup.location_name}
  organizer={meetup.organizer}
  attendeeCount={meetup.rsvp_count}
  maxAttendees={meetup.max_attendees}
  status={meetup.status}
  region={meetup.region}
>
  <!-- Description from meetup data -->
  <MarkdownRenderer content={meetup.description}/>
  
  <!-- Additional placeholder content for the event page -->
  <p>
    This event is a great opportunity to meet fellow cyberdeck builders, share knowledge, 
    and work on your projects in a collaborative environment. Whether you're bringing a 
    project to work on or just want to learn more about cyberdeck building, you'll find 
    a welcoming community here.
  </p>
</MeetupLayout>

<style>
  /* Additional page-specific styles if needed */
</style>
