---
import MeetupLayout from "@/layouts/MeetupLayout.astro";
import { getMeetup, getMeetups } from "@/lib/meetups";
import { marked } from "marked";

// Server-rendered page
export const prerender = false;

// Get slug from URL params
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/meetups");
}

// Fetch meetup from database
const db = Astro.locals.db!;
const meetupResult = await getMeetup(db, slug);

// Meetup not found - redirect to meetups list
const notFound = !meetupResult || meetupResult.length === 0;

if (notFound) {
  return Astro.redirect("/meetups");
}

const result = meetupResult[0];
const meetup = result.meetup;
const organizerName = result.organizerName;

// Transform meetup data
const startDate = new Date(meetup.startsAt! * 1000);
const endDate = meetup.endsAt ? new Date(meetup.endsAt * 1000) : null;
const now = Math.floor(Date.now() / 1000);

// Determine status based on timestamps
let status: "upcoming" | "in-progress" | "completed" | "cancelled" = 
  (meetup.status as "upcoming" | "in-progress" | "completed" | "cancelled") || "upcoming";

if (status === "upcoming" && meetup.startsAt && meetup.startsAt <= now) {
  if (meetup.endsAt && meetup.endsAt > now) {
    status = "in-progress";
  } else if (meetup.endsAt && meetup.endsAt <= now) {
    status = "completed";
  }
}

// Get related meetups (same organizer or just other meetups)
const allMeetupsResult = await getMeetups(db, { limit: 5 });
const relatedMeetups = allMeetupsResult
  .filter(({ meetup: m }) => m.slug !== slug)
  .slice(0, 2)
  .map(({ meetup: m }) => ({
    slug: m.slug,
    title: m.title,
    dateStart: new Date(m.startsAt! * 1000).toISOString(),
    locationName: m.location || "TBD",
    region: "Community", // Schema doesn't have region yet
    status: m.status as "upcoming" | "in-progress" | "completed" | "cancelled",
    rsvpCount: 0, // Schema doesn't have rsvp_count yet
    maxAttendees: undefined // Schema doesn't have max_attendees yet
  }));

// Render markdown content if present
const descriptionHtml = meetup.content 
  ? await marked.parse(meetup.content)
  : meetup.description || "";

// Helper to format dates for display
const formatDateShort = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
};
---

<MeetupLayout
  title={meetup.title}
  description={`Join us for ${meetup.title} - a cyberdeck build meetup`}
  dateStart={startDate.toISOString()}
  dateEnd={endDate ? endDate.toISOString() : undefined}
  locationName={meetup.location || "TBD"}
  organizer={organizerName}
  attendeeCount={0}
  maxAttendees={undefined}
  status={status}
  region={"Community"}
>
  <!-- Description from meetup data -->
  <Fragment set:html={descriptionHtml} />
  
  <!-- Additional context -->
  <p>
    This event is a great opportunity to meet fellow cyberdeck builders, share knowledge, 
    and work on your projects in a collaborative environment. Whether you're bringing a 
    project to work on or just want to learn more about cyberdeck building, you'll find 
    a welcoming community here.
  </p>
</MeetupLayout>

<style>
  /* Additional page-specific styles if needed */
</style>
