---
/**
 * ForumLayout.astro
 * Two-column layout for forum pages: sidebar navigation + main content
 */

import BaseLayout from "./BaseLayout.astro";
import ForumSidebar from "@/components/ForumSidebar.astro";

interface Props {
  title: string;
  description?: string;
  currentCategory?: string;
  breadcrumb?: { label: string; href: string }[];
}

const { 
  title, 
  description = "Forum discussion for cyberdeck builders",
  currentCategory,
  breadcrumb = [] 
} = Astro.props;
---

<BaseLayout title={`${title} | Forum`} description={description}>
  <div class="forum-layout">
    <!-- Mobile sidebar toggle -->
    <button class="mobile-sidebar-toggle" aria-label="Toggle navigation menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span>Forum Categories</span>
    </button>

    <aside class="forum-sidebar-wrapper">
      <ForumSidebar currentCategory={currentCategory} />
    </aside>

    <main class="forum-content">
      <!-- Breadcrumb -->
      {breadcrumb.length > 0 && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/forum">Forum</a>
          {breadcrumb.map((crumb) => (
            <>
              <span class="breadcrumb-separator">→</span>
              <a href={crumb.href}>{crumb.label}</a>
            </>
          ))}
        </nav>
      )}

      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .forum-layout {
    display: flex;
    gap: 2.5rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .mobile-sidebar-toggle {
    display: none;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 4px solid var(--color-primary);
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text);
    cursor: pointer;
    margin-bottom: 1.25rem;
    box-shadow: 5px 5px 0 var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mobile-sidebar-toggle:hover {
    transform: translateY(-2px);
    box-shadow: 7px 7px 0 var(--color-primary);
  }

  .forum-sidebar-wrapper {
    flex-shrink: 0;
    position: sticky;
    top: 2rem;
    height: fit-content;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
  }

  .forum-content {
    flex: 1;
    min-width: 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    font-size: 0.85rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 3px solid var(--color-primary);
    border-radius: 8px;
  }

  .breadcrumb a {
    color: var(--color-secondary);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .breadcrumb-separator {
    color: var(--text-muted);
    font-weight: 700;
  }

  .breadcrumb span {
    color: var(--text);
    font-weight: 700;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .forum-sidebar-wrapper {
      width: 260px;
    }
  }

  @media (max-width: 768px) {
    .forum-layout {
      flex-direction: column;
      padding: 1.5rem 1rem;
    }

    .mobile-sidebar-toggle {
      display: flex;
    }

    .forum-sidebar-wrapper {
      display: none;
      width: 100%;
      position: static;
      max-height: none;
    }

    .forum-sidebar-wrapper.open {
      display: block;
    }
  }
</style>

<script>
  // Mobile sidebar toggle
  const toggle = document.querySelector('.mobile-sidebar-toggle');
  const sidebar = document.querySelector('.forum-sidebar-wrapper');

  if (toggle && sidebar) {
    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('open');
    });
  }
</script>
