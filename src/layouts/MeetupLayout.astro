---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  dateStart: string;
  dateEnd?: string;
  locationName: string;
  organizer: string;
  attendeeCount: number;
  maxAttendees?: number;
  status: "upcoming" | "in-progress" | "completed" | "cancelled";
  region: string;
}

const { 
  title,
  description = "Join us for a cyberdeck build meetup!",
  dateStart,
  dateEnd,
  locationName,
  organizer,
  attendeeCount,
  maxAttendees,
  status,
  region
} = Astro.props;

const statusConfig = {
  "upcoming": { label: "Upcoming", bgColor: "var(--color-pop-mint)", textColor: "var(--color-text)" },
  "in-progress": { label: "In Progress", bgColor: "var(--color-pop-lemon)", textColor: "var(--color-text)" },
  "completed": { label: "Completed", bgColor: "var(--color-base-400)", textColor: "var(--color-white)" },
  "cancelled": { label: "Cancelled", bgColor: "var(--color-accent)", textColor: "var(--color-white)" }
};

const statusStyle = statusConfig[status];

// Format date nicely
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};

const formatTime = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleTimeString('en-US', {
    hour: 'numeric',
    minute: '2-digit',
    hour12: true
  });
};

const formattedDate = formatDate(dateStart);
const formattedStartTime = formatTime(dateStart);
const formattedEndTime = dateEnd ? formatTime(dateEnd) : null;
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="meetup-hero">
    <div class="hero-sparkles">
      <span class="sparkle">✦</span>
      <span class="sparkle">✧</span>
      <span class="sparkle">✦</span>
    </div>
    
    <div class="hero-content">
      <span 
        class="status-badge" 
        style={`background: ${statusStyle.bgColor}; color: ${statusStyle.textColor}`}
      >
        {statusStyle.label}
      </span>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-region">
        <svg class="icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 2C6 2 4 4 4 6.5C4 9.5 8 14 8 14C8 14 12 9.5 12 6.5C12 4 10 2 8 2Z" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="8" cy="6.5" r="2" stroke="currentColor" stroke-width="1.2"/>
        </svg>
        {region}
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="meetup-content">
    <div class="content-grid">
      <!-- Main Column -->
      <div class="main-column">
        <div class="description-card">
          <h2 class="section-title">About This Meetup</h2>
          <div class="description-text">
            <slot />
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-card">
          <h3 class="sidebar-title">Event Details</h3>
          
          <div class="detail-item">
            <div class="detail-label">
              <svg class="detail-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="3" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 7H16" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 1V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M12 1V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Date
            </div>
            <div class="detail-value">{formattedDate}</div>
          </div>

          <div class="detail-item">
            <div class="detail-label">
              <svg class="detail-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 5V9L12 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Time
            </div>
            <div class="detail-value">
              {formattedStartTime}{formattedEndTime ? ` - ${formattedEndTime}` : ''}
            </div>
          </div>

          <div class="detail-item">
            <div class="detail-label">
              <svg class="detail-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 2C6.5 2 4.5 4 4.5 6.5C4.5 9.5 9 14 9 14C9 14 13.5 9.5 13.5 6.5C13.5 4 11.5 2 9 2Z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="9" cy="6.5" r="2" stroke="currentColor" stroke-width="1.2"/>
              </svg>
              Location
            </div>
            <div class="detail-value location-value">{locationName}</div>
          </div>

          <div class="detail-item">
            <div class="detail-label">
              <svg class="detail-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="7" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 15C2 12.5 4 11 7 11C8 11 8.5 11 9 11.5C9.5 12 10 12 10.5 12C11 12 11.5 12 12 11.5C12.5 11 13 11 14 11C16 11 17 12.5 17 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Organizer
            </div>
            <div class="detail-value organizer-value">{organizer}</div>
          </div>

          <div class="detail-item">
            <div class="detail-label">
              <svg class="detail-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 5V9L13 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="1.2"/>
              </svg>
              Attendees
            </div>
            <div class="detail-value">
              {attendeeCount}{maxAttendees ? ` / ${maxAttendees}` : ''} 
              <span class="attendee-label">people attending</span>
            </div>
          </div>
        </div>

        <!-- RSVP Button -->
        <button class="rsvp-button" disabled>
          <svg class="rsvp-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 4L16 9L9 14L2 9L9 4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          RSVP (Coming Soon)
        </button>

        <!-- Back Link -->
        <a href="/meetups" class="back-link">
          <svg class="back-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          View all meetups
        </a>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .meetup-hero {
    position: relative;
    padding: 5rem 2rem;
    background: var(--color-secondary);
    border-bottom: 8px solid var(--color-text);
    color: white;
    overflow: hidden;
  }

  .hero-sparkles {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    opacity: 0.25;
  }

  .sparkle {
    font-size: 4rem;
    animation: sparkle 2s ease-in-out infinite;
  }

  .sparkle:nth-child(2) {
    animation-delay: 0.5s;
  }

  .sparkle:nth-child(3) {
    animation-delay: 1s;
  }

  @keyframes sparkle {
    0%, 100% { transform: scale(1); opacity: 0.2; }
    50% { transform: scale(1.3); opacity: 0.5; }
  }

  .hero-content {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .status-badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 3px solid var(--color-text);
    margin-bottom: 1.5rem;
    box-shadow: 4px 4px 0 var(--color-text);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: white;
    text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
  }

  .hero-region {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.95;
    background: rgba(0, 0, 0, 0.2);
    padding: 0.5rem 1rem;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  /* Main Content */
  .meetup-content {
    padding: 4rem 2rem;
    background: var(--bg);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Main Column */
  .main-column {
    min-width: 0;
  }

  .description-card {
    background: var(--surface);
    border: 4px solid var(--color-text);
    box-shadow: 8px 8px 0 var(--color-text);
    padding: 2.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 4px solid var(--color-text);
    color: var(--text);
  }

  .description-text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }

  .description-text :global(p) {
    margin: 0 0 1.25rem;
  }

  .description-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .description-text :global(ul),
  .description-text :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .description-text :global(li) {
    margin-bottom: 0.5rem;
  }

  .description-text :global(strong) {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-card {
    background: var(--surface);
    border: 4px solid var(--color-text);
    box-shadow: 6px 6px 0 var(--color-text);
    padding: 2rem;
  }

  .sidebar-title {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 4px solid var(--color-text);
    color: var(--text);
  }

  .detail-item {
    margin-bottom: 1.25rem;
  }

  .detail-item:last-child {
    margin-bottom: 0;
  }

  .detail-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .detail-icon {
    opacity: 0.7;
    flex-shrink: 0;
  }

  .detail-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    padding-left: 1.75rem;
  }

  .location-value {
    word-break: break-word;
  }

  .organizer-value {
    color: var(--color-primary);
    font-weight: 800;
  }

  .attendee-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* RSVP Button */
  .rsvp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1.25rem;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-primary);
    color: white;
    border: 4px solid var(--color-text);
    box-shadow: 6px 6px 0 var(--color-text);
    cursor: not-allowed;
    opacity: 0.6;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .rsvp-icon {
    flex-shrink: 0;
  }

  .rsvp-button:hover {
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0 var(--color-text);
  }

  /* Back Link */
  .back-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-decoration: none;
    background: var(--surface);
    border: 3px solid var(--color-text);
    box-shadow: 4px 4px 0 var(--color-text);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-primary);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-text);
  }

  .back-icon {
    flex-shrink: 0;
  }

  /* Dark mode adjustments */
  :global(html.dark) .hero-title {
    text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.4);
  }

  :global(html.dark) .description-card,
  :global(html.dark) .sidebar-card {
    border-color: var(--color-text);
  }

  @media (max-width: 600px) {
    .hero-title {
      font-size: 2rem;
    }

    .sparkle {
      font-size: 2.5rem;
    }

    .description-card {
      padding: 1.5rem;
      margin-left: -1rem;
      margin-right: -1rem;
      width: calc(100% + 2rem);
      border-left: none;
      border-right: none;
      box-shadow: none;
    }

    .sidebar-card {
      margin-left: -1rem;
      margin-right: -1rem;
      width: calc(100% + 2rem);
      border-left: none;
      border-right: none;
      box-shadow: none;
    }
  }
</style>
