---
/**
 * WikiLayout.astro
 * Two-column layout for wiki pages: sidebar navigation + main content
 */

import BaseLayout from "./BaseLayout.astro";
import WikiSidebar from "@/components/WikiSidebar.astro";

interface Props {
  title: string;
  description?: string;
  currentCategory?: string;
  breadcrumb?: { label: string; href: string }[];
}

const { 
  title, 
  description = "Wiki article for cyberdeck builders",
  currentCategory,
  breadcrumb = [] 
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="wiki-layout">
    <!-- Mobile sidebar toggle -->
    <button class="mobile-sidebar-toggle" id="wiki-sidebar-toggle" aria-label="Toggle navigation menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <span>Categories</span>
    </button>

    <aside class="wiki-sidebar-wrapper" id="wiki-sidebar-wrapper">
      <WikiSidebar currentCategory={currentCategory} />
    </aside>

    <article class="wiki-content">
      <!-- Breadcrumb -->
      {breadcrumb.length > 0 && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/wiki">Wiki</a>
          {breadcrumb.map((crumb) => (
            <>
              <span class="breadcrumb-separator">→</span>
              <a href={crumb.href}>{crumb.label}</a>
            </>
          ))}
        </nav>
      )}

      <slot />
    </article>
  </div>
</BaseLayout>

<script>
  const toggle = document.getElementById('wiki-sidebar-toggle');
  const sidebar = document.getElementById('wiki-sidebar-wrapper');
  toggle?.addEventListener('click', () => {
    sidebar?.classList.toggle('open');
  });
</script>

<style>
  .wiki-layout {
    display: flex;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    align-items: flex-start;
  }

  .mobile-sidebar-toggle {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--surface);
    border: 4px solid var(--text);
    border-radius: 0;
    font-weight: 800;
    font-size: 0.9375rem;
    color: var(--text);
    cursor: pointer;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-shadow: 4px 4px 0 var(--border);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .mobile-sidebar-toggle:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--border);
    background: var(--color-secondary-100);
  }

  :global(html.dark) .mobile-sidebar-toggle:hover {
    background: var(--color-secondary-800);
  }

  .wiki-sidebar-wrapper {
    flex-shrink: 0;
    width: 280px;
  }

  .wiki-content {
    flex: 1;
    min-width: 0;
    background: var(--surface);
    border: 4px solid var(--text);
    border-radius: 0;
    padding: 2.5rem;
    box-shadow: 6px 6px 0 var(--border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    padding-bottom: 1rem;
    border-bottom: 3px solid var(--border);
  }

  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 700;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .breadcrumb-separator {
    color: var(--text-muted);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .wiki-layout {
      flex-direction: column;
      padding: 1rem;
      gap: 0;
    }

    .mobile-sidebar-toggle {
      display: flex;
      width: 100%;
      justify-content: center;
    }

    .wiki-sidebar-wrapper {
      display: none;
      width: 100%;
      margin-bottom: 1.25rem;
    }

    .wiki-sidebar-wrapper.open {
      display: block;
    }

    .wiki-content {
      padding: 1.5rem;
      box-shadow: 4px 4px 0 var(--border);
    }
  }
</style>
