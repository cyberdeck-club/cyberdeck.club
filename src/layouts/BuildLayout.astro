---
import BaseLayout from "./BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface ImageData {
  url: string;
  alt?: string;
  width?: number;
  height?: number;
}

interface Props {
  title: string;
  description?: string;
  featuredImage?: ImageData;
  builderName?: string;
  difficulty?: "beginner" | "intermediate" | "advanced";
  computePlatform?: string;
  estimatedCost?: number;
  buildTime?: string;
  tags?: string[];
}

const { 
  title,
  description = "A cyberdeck build from the community",
  featuredImage,
  builderName,
  difficulty,
  computePlatform,
  estimatedCost,
  buildTime,
  tags = []
} = Astro.props;

const difficultyConfig = {
  "beginner": { label: "Beginner", color: "var(--color-accent-300)", textColor: "var(--text)" },
  "intermediate": { label: "Intermediate", color: "var(--color-secondary-300)", textColor: "var(--text)" },
  "advanced": { label: "Advanced", color: "var(--color-accent-600)", textColor: "var(--text-inverse)" }
};

const diff = difficulty ? difficultyConfig[difficulty] : null;

// Placeholder colors if no image (solid fills, no gradients)
const placeholderColors = {
  "beginner": "var(--color-accent-200)",
  "intermediate": "var(--color-secondary-200)",
  "advanced": "var(--color-accent-400)"
};
const defaultColor = difficulty ? placeholderColors[difficulty] : "var(--color-primary-200)";

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(amount);
};
---

<BaseLayout title={title} description={description}>
  <Wrapper variant="standard" class="py-8">
  <!-- Hero Section -->
  <section class="build-hero">
    <div class="hero-image" style={featuredImage?.url ? undefined : `background-color: ${defaultColor}`}>
      {featuredImage?.url ? (
        <img 
          src={featuredImage.url} 
          alt={featuredImage.alt || title}
          class="hero-img"
        />
      ) : (
        <div class="hero-sparkles">
          <span class="sparkle">✦</span>
          <span class="sparkle">✧</span>
          <span class="sparkle">✦</span>
        </div>
      )}
      
      <!-- Floating Metadata Card -->
      <div class="hero-meta-card">
        {diff && (
          <span 
            class="meta-badge difficulty"
            style={`background: ${diff.color}; color: ${diff.textColor}`}
          >
            {diff.label}
          </span>
        )}
        {computePlatform && (
          <span class="meta-badge platform">{computePlatform}</span>
        )}
        {buildTime && (
          <span class="meta-badge time">
            <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            {buildTime}
          </span>
        )}
        {estimatedCost !== undefined && (
          <span class="meta-cost">{formatCurrency(estimatedCost)}</span>
        )}
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="build-container">
    <!-- Header Section -->
    <header class="build-header">
      <h1 class="build-title">{title}</h1>
      {builderName && (
        <p class="build-builder-credit">
          <svg class="credit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
          </svg>
          Built by <span class="builder-name">{builderName}</span>
        </p>
      )}
      {tags.length > 0 && (
        <div class="build-tags">
          {tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Content Grid -->
    <div class="build-content-grid">
      <div class="build-main-content">
        <slot />
      </div>
      
      <aside class="build-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">Quick Stats</h3>
          <dl class="stats-list">
            {computePlatform && (
              <>
                <dt>Platform</dt>
                <dd>{computePlatform}</dd>
              </>
            )}
            {estimatedCost !== undefined && (
              <>
                <dt>Est. Cost</dt>
                <dd>{formatCurrency(estimatedCost)}</dd>
              </>
            )}
            {buildTime && (
              <>
                <dt>Build Time</dt>
                <dd>{buildTime}</dd>
              </>
            )}
            {difficulty && (
              <>
                <dt>Difficulty</dt>
                <dd>
                  <span 
                    class="difficulty-inline"
                    style={`background: ${diff?.color}; color: ${diff?.textColor}`}
                  >
                    {diff?.label}
                  </span>
                </dd>
              </>
            )}
          </dl>
        </div>
        
        {builderName && (
          <div class="sidebar-section">
            <h3 class="sidebar-title">Builder</h3>
            <div class="builder-card">
              <div class="builder-avatar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
                </svg>
              </div>
              <span class="builder-card-name">{builderName}</span>
            </div>
          </div>
        )}
        
        <slot name="sidebar" />
      </aside>
    </div>
  </div>
  </Wrapper>
</BaseLayout>

<style>
  /* Hero Section */
  .build-hero {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .hero-image {
    height: 50vh;
    min-height: 420px;
    max-height: 600px;
    position: relative;
    overflow: hidden;
    border-bottom: 4px solid var(--color-text);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-sparkles {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
  }

  .sparkle {
    font-size: 3rem;
    color: rgba(255, 255, 255, 0.9);
    animation: sparkle 2s ease-in-out infinite;
  }

  .sparkle:nth-child(1) { animation-delay: 0s; }
  .sparkle:nth-child(2) { animation-delay: 0.5s; }
  .sparkle:nth-child(3) { animation-delay: 1s; }

  @keyframes sparkle {
    0%, 100% { opacity: 0.4; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* Floating Metadata Card */
  .hero-meta-card {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    right: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .meta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    background: var(--surface);
    color: var(--text);
    border: 3px solid var(--border);
    box-shadow: 3px 3px 0 var(--shadow-hard);
  }

  .meta-badge.platform,
  .meta-badge.time {
    background: var(--text);
    color: var(--text-inverse);
  }

  .badge-icon {
    width: 1rem;
    height: 1rem;
  }

  .meta-cost {
    margin-left: auto;
    padding: 0.5rem 1rem;
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    background: var(--color-primary-600);
    color: var(--text-inverse);
    border: 3px solid var(--border);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  /* Container */
  .build-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Header */
  .build-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 4px solid var(--color-secondary);
  }

  .build-title {
    font-size: 2.75rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--text);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .build-builder-credit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .credit-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .builder-name {
    font-weight: 800;
    color: var(--color-primary);
  }

  .build-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--bg);
    color: var(--text);
    border: 2px solid var(--color-text);
    border-radius: 0;
    box-shadow: 2px 2px 0 var(--color-text);
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .tag:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--color-primary);
    border-color: var(--color-primary);
  }

  /* Content Grid */
  .build-content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 900px) {
    .build-content-grid {
      grid-template-columns: 1fr 300px;
    }
  }

  .build-main-content {
    min-width: 0;
  }

  /* Sidebar */
  .build-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-section {
    background: var(--surface);
    border: 3px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem;
    box-shadow: 4px 4px 0 var(--shadow-hard);
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid var(--color-secondary);
  }

  .stats-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1rem;
    margin: 0;
  }

  .stats-list dt {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .stats-list dd {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
    text-align: right;
  }

  .difficulty-inline {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 0;
    border: 2px solid var(--color-text);
  }

  .builder-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .builder-avatar {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--color-text);
    border-radius: 0;
    border: 3px solid var(--color-text);
    box-shadow: 2px 2px 0 var(--color-text);
    flex-shrink: 0;
  }

  .builder-avatar svg {
    width: 22px;
    height: 22px;
  }

  .builder-card-name {
    font-weight: 800;
    color: var(--text);
  }

  /* Dark mode */
  :global([data-theme="dark"]) .meta-badge {
    background: var(--surface);
    color: white;
  }

  :global([data-theme="dark"]) .meta-badge.platform,
  :global([data-theme="dark"]) .meta-badge.time {
    background: white;
    color: var(--color-text);
  }

  :global([data-theme="dark"]) .tag {
    background: var(--surface);
    border-color: var(--color-secondary);
    box-shadow: 2px 2px 0 var(--color-secondary);
  }

  :global([data-theme="dark"]) .sidebar-section {
    box-shadow: 6px 6px 0 var(--color-primary);
    border-color: var(--color-secondary);
  }

  :global([data-theme="dark"]) .sidebar-title {
    border-color: var(--color-primary);
  }
</style>
